                    "type": "string",
                    "description": "Calling client identity for HAID attribution.",
                },
            },
            "additionalProperties": False,
        },
    },
    "append_decision": {
        "handler": tool_append_decision,
        "description": "Append a HAID-attributed ADR-lite entry to the ledger's "
        "append-only `decisions.md`. Use to record a coordination decision, a "
        "sequencing call, or a surface-ownership agreement.",
        "inputSchema": {
            "type": "object",
            "properties": {
                "title": {"type": "string", "description": "Short decision title."},
                "body": {
                    "type": "string",
                    "description": "One paragraph: the decision and the why.",
                },
                "client_identity": {
                    "type": "string",
                    "description": "Calling client identity for HAID attribution.",
                },
