def tools_list_payload():
    return {
        "tools": [
            {
                "name": name,
                "description": spec["description"],
                "inputSchema": spec["inputSchema"],
            }
            for name, spec in TOOLS.items()
        ]
    }


# ── JSON-RPC plumbing ──────────────────────────────────────────────────────────
def make_error(req_id, code, message, data=None):
    err = {"code": code, "message": message}
    if data is not None:
        err["data"] = data
    return {"jsonrpc": "2.0", "id": req_id, "error": err}


def make_result(req_id, result):
    return {"jsonrpc": "2.0", "id": req_id, "result": result}


class Session:
    """Per-connection state: the client identity declared at initialize."""

    def __init__(self):
        self.client_identity = None
        self.initialized = False


def handle_initialize(session, params):
    client_info = (params or {}).get("clientInfo") or {}
    session.client_identity = client_info.get("name") or "mcp-client"
    session.initialized = True
    return {
        "protocolVersion": PROTOCOL_VERSION,
        "capabilities": {"tools": {"listChanged": False}},
        "serverInfo": {
            "name": SERVER_NAME,
            "version": TOOL_SCHEMA_VERSION,
        },
        "instructions": (
            "Heimdall Coordination Ledger over MCP. Every tool call is "
            "HAID-attributed to your client identity. Claim surfaces before "
            "editing; read claims first to avoid collisions."
        ),
    }


def handle_tools_call(session, params):
    params = params or {}
    name = params.get("name")
    arguments = params.get("arguments") or {}
    spec = TOOLS.get(name)
    if spec is None:
        raise LedgerError(f"unknown tool: {name}")
    # Resolve the calling identity: per-call arg wins, else the initialize one.
    client_identity = arguments.get("client_identity") or session.client_identity or "mcp-client"
    haid = client_haid(client_identity)
    payload = spec["handler"](arguments, haid)
    # MCP tools/call result: content blocks. We return one JSON text block plus
    # a structuredContent mirror so both text-only and structured clients work.
    text = json.dumps(payload, indent=2, sort_keys=True)
    return {
        "content": [{"type": "text", "text": text}],
        "structuredContent": payload,
        "isError": False,
    }


def dispatch(session, request):
    """Handle one JSON-RPC request object; return a response dict or None (notify)."""
    if not isinstance(request, dict) or request.get("jsonrpc") != "2.0":
        return make_error(None, -32600, "Invalid Request: not JSON-RPC 2.0")
    method = request.get("method")
    req_id = request.get("id")
    params = request.get("params")
    is_notification = "id" not in request

    try:
        if method == "initialize":
            result = handle_initialize(session, params)
        elif method == "notifications/initialized":
            return None  # client ack; no response for notifications
        elif method == "ping":
            result = {}
        elif method == "tools/list":
            result = tools_list_payload()
        elif method == "tools/call":
            result = handle_tools_call(session, params)
        else:
            if is_notification:
                return None
            return make_error(req_id, -32601, f"Method not found: {method}")
    except LedgerError as exc:
        if is_notification:
            return None
        # Tool-execution failures are surfaced as a tools/call error result so the
        # client sees them as a failed tool, per MCP convention; protocol-level
        # method errors use the JSON-RPC error channel.
        if method == "tools/call":
            text = json.dumps({"error": str(exc), "detail": exc.detail}, indent=2)
            return make_result(
                req_id,
                {"content": [{"type": "text", "text": text}], "isError": True},
            )
        return make_error(req_id, -32603, str(exc), data=exc.detail or None)
    except Exception as exc:  # defensive: never crash the loop on one bad request
        if is_notification:
            return None
        return make_error(req_id, -32603, f"internal error: {exc}")

    if is_notification:
        return None
    return make_result(req_id, result)


# ── stdio framing: accept Content-Length frames OR newline-delimited JSON ──────
def read_messages(stream):
    """Yield parsed JSON-RPC objects from stdin, tolerating both framings."""
    buf = stream
    for raw in iter(buf.readline, ""):
        line = raw.strip()
        if not line:
            continue
        if line.lower().startswith("content-length:"):
            # LSP-style framing: read the declared body after the blank line.
            try:
                length = int(line.split(":", 1)[1].strip())
            except ValueError:
                continue
            # consume headers up to the blank separator line
            while True:
                hdr = buf.readline()
                if hdr.strip() == "":
                    break
            body = buf.read(length)
            try:
                yield json.loads(body)
            except json.JSONDecodeError:
                yield {"__parse_error__": True}
            continue
        try:
            yield json.loads(line)
        except json.JSONDecodeError:
            yield {"__parse_error__": True}


def main():
    session = Session()
    out = sys.stdout
    for request in read_messages(sys.stdin):
        if isinstance(request, dict) and request.get("__parse_error__"):
            resp = make_error(None, -32700, "Parse error")
        else:
            resp = dispatch(session, request)
        if resp is not None:
            out.write(json.dumps(resp) + "\n")
            out.flush()


if __name__ == "__main__":
    main()
