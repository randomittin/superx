#!/usr/bin/env bash
# corpus-capture — H-8 field-capture mechanism (the data flywheel intake arm).
#
# When an oracle gate produces a report.json with status=="fail" during a REAL
# run (not a falsify sweep over fixtures), this captures a CANDIDATE corpus case
# so the failure that the gate just caught is never lost. Field-caught failures
# are the part of the corpus a competitor cannot copy: machinery is copyable,
# accumulated scored failure data is not (spec H-8).
#
# A candidate is NOT a corpus case. It lands in evals/corpus/_candidates/ with a
# NEEDS-APPROVAL marker and is never auto-promoted — a human approves it in (see
# --help "APPROVAL"). This keeps flaky / duplicate / low-value failures from
# silently bloating the corpus while still capturing every real catch for review.
#
# Design contract (matches the wiring in hooks/hooks.json):
#   * FAIL-SILENT + NON-BLOCKING. This runs inside a gate-report hook. It must
#     NEVER alter the gate's pass/fail decision and must NEVER abort the run.
#     Any error -> exit 0 with a note on stderr. The gate flow is untouched.
#   * NO-OP when there is no oracle domain / no usable fail report. Exits 0,
#     writes nothing.
#   * Only writes under evals/corpus/_candidates/. Touches nothing else.
#
# Candidate layout: evals/corpus/_candidates/{date}-{gate}-{hash}/
#   case.json   — the candidate case, schema-aligned with evals/corpus/{id}/case.json
#                 {id, source:"field", gates_under_test, difficulty, added_in_version,
#                  seed, status:"NEEDS-APPROVAL", first_divergence, repro, fix_commit}
#   report.json — verbatim copy of the failing gate report (repro pointer +
#                 first_divergence; the SINGLE source of diff-truth per REPORT-CONTRACT).
#   NEEDS-APPROVAL — marker file; a human deletes it on approval.
#
# Usage:
#   corpus-capture --report <path>              capture from a written report.json
#   corpus-capture < report.json                capture from a report on stdin
#   corpus-capture --report <path> --repro <s>  attach an explicit repro pointer
#   corpus-capture --root <dir>                 repo root (default: cwd)
#   -h, --help                                  show help + the approval procedure
#
# Exit: always 0 from the hook's perspective (fail-silent). 0 also = captured or
# correctly no-op'd. The hook calls it with `|| true` regardless.

set -euo pipefail

usage() {
  cat <<'EOF'
corpus-capture — H-8 field-capture: turn a real gate failure into a corpus CANDIDATE.

USAGE
  corpus-capture --report <path>              capture from a report.json file
  corpus-capture < report.json                capture from a report on stdin
  corpus-capture --report <path> --repro <s>  attach an explicit repro pointer
  corpus-capture --root <dir>                 repo root (default: current dir)
  -h, --help                                  this help

WHAT IT DOES
  Reads a gate report.json (REPORT-CONTRACT.md schema). If status != "fail", it
  is a NO-OP (exit 0, nothing written) — only real catches are captured. On a
  fail it writes a CANDIDATE case under:

    evals/corpus/_candidates/{date}-{gate}-{hash}/
      case.json        schema-aligned candidate (source:"field", NEEDS-APPROVAL)
      report.json      verbatim failing gate report (first_divergence + repro)
      NEEDS-APPROVAL    marker file a human removes on approval

  Fail-silent and non-blocking: it never changes the gate's verdict or aborts a
  run. When there is no usable fail report it does nothing.

APPROVAL — how a human promotes a candidate into the corpus proper
  Candidates are NOT auto-promoted (so flaky / duplicate / low-value failures do
  not accumulate). To approve one:

    1. Review evals/corpus/_candidates/<cand>/ — confirm report.json is a real
       defect, the repro is deterministic (seeded state — non-reproducible is not
       a case, spec H-8 determinism law), and it is not a duplicate of an
       existing case.
    2. Fill case.json: set a stable "id", add the deterministic repro alongside
       the report, set "difficulty" and "added_in_version", and record the
       "fix_commit" sha once the fix lands (replaces the empty fix_commit field).
    3. Move it into the corpus and drop the marker:
         mkdir -p evals/corpus/<id>
         git mv evals/corpus/_candidates/<cand>/report.json evals/corpus/<id>/
         git mv evals/corpus/_candidates/<cand>/case.json   evals/corpus/<id>/
         git rm evals/corpus/_candidates/<cand>/NEEDS-APPROVAL
    4. Register it: add { "id": "<id>", ... } to evals/corpus/INDEX.json so
       `bin/corpus run` (the CI-inversion gate) exercises it on every push.
    5. Verify it catches: `bin/corpus run` must stay green (the gate still
       catches what it once caught).
EOF
}

# stderr note + clean exit. Fail-silent: the gate flow must never break.
note() { printf 'corpus-capture: %s\n' "$1" >&2; }

REPORT=""
REPRO=""
ROOT=""

while [ $# -gt 0 ]; do
  case "$1" in
    --report) REPORT="${2:-}"; shift 2 || { note "--report needs a value"; exit 0; } ;;
    --repro)  REPRO="${2:-}";  shift 2 || { note "--repro needs a value";  exit 0; } ;;
    --root)   ROOT="${2:-}";   shift 2 || { note "--root needs a value";   exit 0; } ;;
    -h|--help) usage; exit 0 ;;
    --*) note "unknown flag: $1 (ignored)"; shift ;;
    *)   note "unexpected argument: $1 (ignored)"; shift ;;
  esac
done

# jq is required to read the typed report. Missing jq -> no-op, never block.
if ! command -v jq >/dev/null 2>&1; then
  note "jq not available — skipping capture (no-op)"
  exit 0
fi

# Resolve repo root (default cwd). The candidate tree lives under it.
ROOT="${ROOT:-$PWD}"
if [ ! -d "$ROOT" ]; then
  note "root not a directory: $ROOT — skipping (no-op)"
  exit 0
fi

# Source the report: explicit file, or stdin. Empty -> nothing to capture (no-op).
REPORT_JSON=""
if [ -n "$REPORT" ]; then
  if [ ! -s "$REPORT" ]; then
    note "report not found or empty: $REPORT — skipping (no-op)"
    exit 0
  fi
  REPORT_JSON="$(cat "$REPORT" 2>/dev/null || true)"
elif [ ! -t 0 ]; then
  REPORT_JSON="$(cat 2>/dev/null || true)"
fi

if [ -z "$REPORT_JSON" ]; then
  note "no report.json provided (no --report, empty stdin) — skipping (no-op)"
  exit 0
fi

# Parse the typed fields per REPORT-CONTRACT. Unparseable -> no-op (never block).
if ! printf '%s' "$REPORT_JSON" | jq -e '.' >/dev/null 2>&1; then
  note "report is not valid JSON — skipping (no-op)"
  exit 0
fi

STATUS="$(printf '%s' "$REPORT_JSON" | jq -r '.status // empty' 2>/dev/null || true)"

# ONLY status=="fail" is a real catch worth capturing. pass / missing -> no-op.
if [ "$STATUS" != "fail" ]; then
  note "report status='${STATUS:-<none>}' (not fail) — nothing to capture (no-op)"
  exit 0
fi

GATE="$(printf '%s' "$REPORT_JSON" | jq -r '.gate_id // empty' 2>/dev/null || true)"
if [ -z "$GATE" ]; then
  # A fail report with no gate_id violates the contract; capture under "unknown"
  # so the catch is not lost, but flag it for the human reviewer.
  GATE="unknown"
  note "fail report has no gate_id — capturing under '$GATE' for review"
fi

FIRST_DIV="$(printf '%s' "$REPORT_JSON" | jq -r '.first_divergence // empty' 2>/dev/null || true)"

# Sanitize the gate id for a filesystem path (keep [A-Za-z0-9._-], collapse rest).
GATE_SLUG="$(printf '%s' "$GATE" | tr -c 'A-Za-z0-9._-' '-' | sed 's/-\{1,\}/-/g; s/^-//; s/-$//')"
[ -n "$GATE_SLUG" ] || GATE_SLUG="unknown"

# Content hash of the report -> stable, dedup-friendly candidate dir suffix.
HASH=""
if command -v sha1sum >/dev/null 2>&1; then
  HASH="$(printf '%s' "$REPORT_JSON" | sha1sum | cut -c1-12)"
elif command -v shasum >/dev/null 2>&1; then
  HASH="$(printf '%s' "$REPORT_JSON" | shasum | cut -c1-12)"
else
  HASH="$(printf '%s' "$REPORT_JSON" | cksum | tr -d ' ' | cut -c1-12)"
fi
[ -n "$HASH" ] || HASH="nohash"

DATE="$(date +%Y%m%d)"

CAND_PARENT="$ROOT/evals/corpus/_candidates"
CAND_DIR="$CAND_PARENT/${DATE}-${GATE_SLUG}-${HASH}"

# Idempotent: same failing report -> same dir (hash). If already captured, skip.
if [ -d "$CAND_DIR" ]; then
  note "candidate already captured: ${CAND_DIR#"$ROOT"/} (no-op)"
  exit 0
fi

if ! mkdir -p "$CAND_DIR" 2>/dev/null; then
  note "could not create candidate dir: $CAND_DIR — skipping (no-op)"
  exit 0
fi

# 1) Verbatim failing report (the repro pointer + first_divergence; diff-truth).
printf '%s\n' "$REPORT_JSON" > "$CAND_DIR/report.json" 2>/dev/null || {
  note "could not write report.json — skipping (no-op)"
  exit 0
}

# Repro pointer: explicit --repro, else point at the captured report (which
# carries the gate's own divergence locator). A human upgrades this to a seeded,
# deterministic repro at approval time (determinism law, H-8).
REPRO_PTR="${REPRO:-report.json (gate report.json; attach a seeded deterministic repro at approval)}"

# 2) The candidate case.json — schema-aligned with evals/corpus/{id}/case.json,
#    plus the field-intake extras (status marker, empty fix_commit to fill on the
#    fix landing, repro, captured first_divergence). source is "field". id is
#    provisional (the human assigns the stable id on approval).
jq -n \
  --arg id "candidate-${DATE}-${GATE_SLUG}-${HASH}" \
  --arg gate "$GATE" \
  --arg div "$FIRST_DIV" \
  --arg repro "$REPRO_PTR" \
  --arg added "unversioned-candidate" \
  '{
     id: $id,
     source: "field",
     gates_under_test: [ $gate ],
     difficulty: "unscored",
     added_in_version: $added,
     seed: null,
     status: "NEEDS-APPROVAL",
     first_divergence: (if $div == "" then null else $div end),
     repro: $repro,
     report: "report.json",
     fix_commit: ""
   }' > "$CAND_DIR/case.json" 2>/dev/null || {
  note "could not write case.json — skipping (no-op)"
  exit 0
}

# 3) The human-approval marker. Its presence == not yet promoted.
{
  printf 'NEEDS-APPROVAL\n\n'
  printf 'Field-captured gate failure. Not yet a corpus case.\n'
  printf 'gate_id: %s\n' "$GATE"
  printf 'captured: %s\n' "$DATE"
  printf 'first_divergence: %s\n' "${FIRST_DIV:-<none>}"
  printf '\nTo approve, run `corpus-capture --help` and follow APPROVAL.\n'
} > "$CAND_DIR/NEEDS-APPROVAL" 2>/dev/null || true

note "captured field candidate: ${CAND_DIR#"$ROOT"/} (gate=$GATE, status=NEEDS-APPROVAL)"
exit 0
