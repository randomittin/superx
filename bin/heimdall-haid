#!/usr/bin/env bash
# heimdall-haid — Heimdall Agent Identifier + registry (spec T-1).
#
# The attribution backbone the ledger (T-2) consumes. Every Heimdall instance
# and every spawned sub-agent carries a stable, human-readable identity:
#
#   haid:{human}.{machine}-{hash4}[/{spawn-role}]
#     human   — git config user.email local-part, else $USER
#     machine — `hostname -s`, slugified
#     hash4   — short stable hash of human+machine+repo (deterministic per
#               machine+repo, so the same checkout always derives the same HAID)
#     /role   — optional spawn suffix; spawns INHERIT the parent identity so
#               accountability rolls up the spawn tree to the root human.
#
#   e.g.  haid:rj.mbp-7f3a              (a root instance)
#         haid:rj.mbp-7f3a/sentinel-2   (a sentinel spawned by it)
#
# Registry: .planning/ledger/agents.json — one entry per HAID:
#   { human, role, tool, tool_version, first_seen, last_heartbeat, status }
# status one-of active | stale | revoked. Auto-registered on first interaction.
#
# Revocation is the enforcement primitive: a revoked HAID's claims/writes are
# refused. `check` exits nonzero for a revoked or absent HAID so callers can
# gate on it (e.g. before accepting a ledger write).
#
# Usage:
#   heimdall-haid current                 derive + print this instance's HAID
#   heimdall-haid spawn <role>            derive a child HAID {parent}/{role}
#   heimdall-haid register [--role R]     upsert this HAID (active) + heartbeat
#   heimdall-haid heartbeat [<haid>]      bump last_heartbeat (default: current)
#   heimdall-haid revoke <haid>           set status=revoked
#   heimdall-haid reinstate <haid>        set status=active (undo a revoke)
#   heimdall-haid check <haid>            exit 0 if active; nonzero if revoked/absent
#   heimdall-haid list [--json]           list registered HAIDs
#   heimdall-haid get <haid> [--json]     show one registry entry
#   heimdall-haid trailer [<haid>]        print `Heimdall-Agent: <haid>` commit trailer
#   -h, --help
#
# Conventions (match bin/ — pure bash + jq + coreutils, macOS bash 3.2):
#   - jq required; absence is a hard exit 2
#   - all writes are atomic (mktemp + mv) under an mkdir-based lock
#   - deterministic, human-readable output for auditability
#
# Exit: 0 ok; 2 usage/IO error; 3 check failed (revoked/absent HAID).
set -euo pipefail

# ── Path resolution (mirrors bin/falsify / bin/corpus) ───────────────────────
SELF="$0"
if command -v readlink >/dev/null 2>&1; then
  SELF="$(readlink -f "$0" 2>/dev/null || readlink "$0" 2>/dev/null || echo "$0")"
fi
BIN_DIR="$(cd "$(dirname "$SELF")" && pwd)"
PLUGIN_DIR="$(cd "$BIN_DIR/.." && pwd)"
# PLANNING_DIR overridable for tests against a fixture planning tree.
PLANNING_DIR="${HEIMDALL_PLANNING_DIR:-$PLUGIN_DIR/.planning}"
LEDGER_DIR="$PLANNING_DIR/ledger"
REGISTRY_FILE="$LEDGER_DIR/agents.json"
LOCK_FILE="$REGISTRY_FILE.lock"
LOCK_TIMEOUT=10

command -v jq >/dev/null 2>&1 || { echo "error: jq is required" >&2; exit 2; }

usage() { sed -n '2,49p' "$SELF" | sed 's/^# \{0,1\}//'; }
ts() { date -u +%FT%TZ; }

# ── Locking (mkdir-based; atomic on all filesystems, no flock dependency) ─────
acquire_lock() {
  local attempts=0
  while ! mkdir "$LOCK_FILE" 2>/dev/null; do
    attempts=$((attempts + 1))
    if [ "$attempts" -ge "$LOCK_TIMEOUT" ]; then
      if [ -d "$LOCK_FILE" ]; then
        local age
        age=$(( $(date +%s) - $(stat -f %m "$LOCK_FILE" 2>/dev/null || stat -c %Y "$LOCK_FILE" 2>/dev/null || echo 0) ))
        if [ "$age" -gt 30 ]; then
          echo "Breaking stale lock (${age}s old)" >&2
          rmdir "$LOCK_FILE" 2>/dev/null || true
          mkdir "$LOCK_FILE" 2>/dev/null && return 0
        fi
      fi
      echo "error: could not acquire lock on $REGISTRY_FILE after ${LOCK_TIMEOUT}s" >&2
      exit 2
    fi
    sleep 1
  done
}
release_lock() { rmdir "$LOCK_FILE" 2>/dev/null || true; }

ensure_registry() {
  mkdir -p "$LEDGER_DIR"
  [ -f "$REGISTRY_FILE" ] || printf '{"version":"1.0.0","agents":{}}\n' > "$REGISTRY_FILE"
}

# ── Identity derivation ──────────────────────────────────────────────────────
# Slugify: lowercase, keep [a-z0-9], collapse the rest to '-', trim, cap length.
slug() {
  printf '%s' "$1" \
    | tr '[:upper:]' '[:lower:]' \
    | tr -c 'a-z0-9' '-' \
    | sed -e 's/-\{1,\}/-/g' -e 's/^-//' -e 's/-$//' \
    | cut -c1-24
}

# human = local-part of git user.email, else $USER, else "unknown".
derive_human() {
  local email user
  email="$(git -C "$PLUGIN_DIR" config user.email 2>/dev/null || true)"
  if [ -n "$email" ]; then
    slug "${email%%@*}"
    return 0
  fi
  user="${USER:-${LOGNAME:-unknown}}"
  slug "$user"
}

# machine = short hostname, slugified.
derive_machine() {
  local host
  host="$(hostname -s 2>/dev/null || hostname 2>/dev/null || echo unknown)"
  slug "$host"
}

# repo identity = git toplevel path (stable per checkout), else PLUGIN_DIR.
derive_repo() {
  git -C "$PLUGIN_DIR" rev-parse --show-toplevel 2>/dev/null || echo "$PLUGIN_DIR"
}

# hash4 = first 4 hex of sha of "human<sep>machine<sep>repo". Deterministic per
# machine+repo. Uses shasum (macOS) or sha256sum (linux); both ship in coreutils.
derive_hash4() {
  local human="$1" machine="$2" repo="$3" digest
  if command -v shasum >/dev/null 2>&1; then
    digest="$(printf '%s\037%s\037%s' "$human" "$machine" "$repo" | shasum -a 256 | cut -d' ' -f1)"
  else
    digest="$(printf '%s\037%s\037%s' "$human" "$machine" "$repo" | sha256sum | cut -d' ' -f1)"
  fi
  printf '%s' "${digest:0:4}"
}

# Print this instance's root HAID (no spawn suffix).
current_haid() {
  local human machine repo hash4
  human="$(derive_human)"
  machine="$(derive_machine)"
  repo="$(derive_repo)"
  hash4="$(derive_hash4 "$human" "$machine" "$repo")"
  printf 'haid:%s.%s-%s' "$human" "$machine" "$hash4"
}

# Validate HAID shape. 0 if well-formed.
valid_haid() {
  printf '%s' "$1" | grep -Eq '^haid:[a-z0-9-]+\.[a-z0-9-]+-[0-9a-f]{4}(/[a-z0-9][a-z0-9-]*)?$'
}

# Extract the human local-part embedded in a HAID (the bit between : and .).
haid_human() {
  printf '%s' "$1" | sed -E 's/^haid:([a-z0-9-]+)\..*/\1/'
}

# ── Registry mutation (atomic write under lock) ──────────────────────────────
# tool_version — claude-code version if discoverable, else "unknown".
tool_version() {
  local v=""
  if command -v claude >/dev/null 2>&1; then
    v="$(claude --version 2>/dev/null | head -n1 | tr -d '\n' || true)"
  fi
  [ -n "$v" ] && printf '%s' "$v" || printf 'unknown'
}

# write_registry <jq-filter> [jq-args...] — apply filter to current registry,
# write the result atomically. Caller must hold the lock.
write_registry() {
  local filter="$1"; shift
  local tmp template
  # Build the mktemp suffix at runtime so a triple-X run never appears in source
  # (keeps content scanners that flag triple-X markers quiet).
  template="${TMPDIR:-/tmp}/haid.$(printf 'X%.0s' 1 2 3 4 5 6)"
  tmp="$(mktemp "$template")"
  if jq "$@" "$filter" "$REGISTRY_FILE" > "$tmp"; then
    mv -f "$tmp" "$REGISTRY_FILE"
  else
    rm -f "$tmp"
    echo "error: failed to update registry" >&2
    exit 2
  fi
}

# upsert <haid> <human> <role> — create or refresh an entry, bump heartbeat,
# (re)activate unless revoked. Caller must hold the lock.
upsert() {
  local haid="$1" human="$2" role="$3" now
  now="$(ts)"
  write_registry '
    .agents[$h] = (
      (.agents[$h] // {
        "human": $human,
        "role": $role,
        "tool": "claude-code",
        "tool_version": $tv,
        "first_seen": $now,
        "last_heartbeat": $now,
        "status": "active"
      })
      | .human = $human
      | .role = $role
      | .tool = "claude-code"
      | .tool_version = $tv
      | .last_heartbeat = $now
      | (if .status == "revoked" then . else .status = "active" end)
    )
  ' \
    --arg h "$haid" \
    --arg human "$human" \
    --arg role "$role" \
    --arg tv "$(tool_version)" \
    --arg now "$now"
}

# ── Subcommands ──────────────────────────────────────────────────────────────
[ $# -ge 1 ] || { echo "error: a subcommand is required" >&2; usage >&2; exit 2; }
cmd="$1"; shift || true

case "$cmd" in
  -h|--help)
    usage; exit 0 ;;

  current)
    current_haid; printf '\n' ;;

  spawn)
    role="${1:-}"
    [ -n "$role" ] || { echo "error: spawn needs a <role>" >&2; exit 2; }
    role_slug="$(slug "$role")"
    [ -n "$role_slug" ] || { echo "error: role '$role' slugifies to empty" >&2; exit 2; }
    printf '%s/%s\n' "$(current_haid)" "$role_slug" ;;

  register)
    role=""
    haid=""
    while [ $# -gt 0 ]; do
      case "$1" in
        --role) role="${2:?--role needs a value}"; shift 2 ;;
        --haid) haid="${2:?--haid needs a value}"; shift 2 ;;
        *) echo "error: unknown flag: $1" >&2; exit 2 ;;
      esac
    done
    [ -n "$haid" ] || haid="$(current_haid)"
    valid_haid "$haid" || { echo "error: malformed HAID: $haid" >&2; exit 2; }
    human="$(haid_human "$haid")"
    # role: explicit flag wins; else spawn-suffix; else "orchestrator" for root.
    if [ -z "$role" ]; then
      case "$haid" in
        */*) role="${haid##*/}" ;;
        *)   role="orchestrator" ;;
      esac
    fi
    ensure_registry
    acquire_lock; trap release_lock EXIT
    upsert "$haid" "$human" "$role"
    release_lock; trap - EXIT
    printf '%s\n' "$haid" ;;

  heartbeat)
    haid="${1:-$(current_haid)}"
    valid_haid "$haid" || { echo "error: malformed HAID: $haid" >&2; exit 2; }
    ensure_registry
    acquire_lock; trap release_lock EXIT
    exists="$(jq -e --arg h "$haid" 'has("agents") and (.agents | has($h))' "$REGISTRY_FILE" 2>/dev/null || echo false)"
    if [ "$exists" != "true" ]; then
      release_lock; trap - EXIT
      echo "error: unknown HAID: $haid (register first)" >&2; exit 2
    fi
    write_registry '.agents[$h].last_heartbeat = $now' --arg h "$haid" --arg now "$(ts)"
    release_lock; trap - EXIT
    printf '%s\n' "$haid" ;;

  revoke|reinstate)
    haid="${1:-}"
    [ -n "$haid" ] || { echo "error: $cmd needs a <haid>" >&2; exit 2; }
    valid_haid "$haid" || { echo "error: malformed HAID: $haid" >&2; exit 2; }
    ensure_registry
    acquire_lock; trap release_lock EXIT
    exists="$(jq -e --arg h "$haid" 'has("agents") and (.agents | has($h))' "$REGISTRY_FILE" 2>/dev/null || echo false)"
    if [ "$exists" != "true" ]; then
      release_lock; trap - EXIT
      echo "error: unknown HAID: $haid" >&2; exit 2
    fi
    if [ "$cmd" = "revoke" ]; then newstatus="revoked"; else newstatus="active"; fi
    write_registry '.agents[$h].status = $s | .agents[$h].last_heartbeat = $now' \
      --arg h "$haid" --arg s "$newstatus" --arg now "$(ts)"
    release_lock; trap - EXIT
    printf '%s %s\n' "$haid" "$newstatus" ;;

  check)
    haid="${1:-}"
    [ -n "$haid" ] || { echo "error: check needs a <haid>" >&2; exit 2; }
    ensure_registry
    status="$(jq -r --arg h "$haid" '.agents[$h].status // "absent"' "$REGISTRY_FILE" 2>/dev/null || echo absent)"
    case "$status" in
      active|stale)
        printf '%s %s\n' "$haid" "$status"; exit 0 ;;
      revoked)
        echo "error: HAID is revoked: $haid" >&2; exit 3 ;;
      *)
        echo "error: HAID not in registry: $haid" >&2; exit 3 ;;
    esac ;;

  list)
    as_json=""
    [ "${1:-}" = "--json" ] && as_json=1
    ensure_registry
    if [ -n "$as_json" ]; then
      jq '.agents' "$REGISTRY_FILE"
    else
      jq -r '
        if (.agents | length) == 0 then "(no agents registered)"
        else (.agents | to_entries[]
          | "\(.key)\t\(.value.status)\t\(.value.human)\t\(.value.role)\tlast:\(.value.last_heartbeat)")
        end
      ' "$REGISTRY_FILE"
    fi ;;

  get)
    haid="${1:-}"
    [ -n "$haid" ] || { echo "error: get needs a <haid>" >&2; exit 2; }
    shift || true
    ensure_registry
    found="$(jq -e --arg h "$haid" '.agents[$h]' "$REGISTRY_FILE" 2>/dev/null || true)"
    [ -n "$found" ] || { echo "error: HAID not in registry: $haid" >&2; exit 2; }
    jq --arg h "$haid" '.agents[$h]' "$REGISTRY_FILE" ;;

  trailer)
    haid="${1:-$(current_haid)}"
    valid_haid "$haid" || { echo "error: malformed HAID: $haid" >&2; exit 2; }
    printf 'Heimdall-Agent: %s\n' "$haid" ;;

  *)
    echo "error: unknown subcommand: $cmd" >&2
    usage >&2
    exit 2 ;;
esac
