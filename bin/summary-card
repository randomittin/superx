#!/usr/bin/env bash
# summary-card — heimdall end-of-run summary card.
# Renders a truecolor ASCII box from .planning/STATE.md + heimdall-state.json + git log.
# Pure shell. No network, no model involvement. Missing data → "—", never crashes.
#
# Usage: summary-card [PROJECT_DIR]   (defaults to cwd)
set -uo pipefail

PROJECT="${1:-.}"
PLANNING="$PROJECT/.planning"
STATE_MD="$PLANNING/STATE.md"
# Prefer heimdall-state.json; fall back to legacy superx-state.json (back-compat).
if [ -f "$PROJECT/heimdall-state.json" ]; then
  STATE_JSON="$PROJECT/heimdall-state.json"
elif [ -f "$PROJECT/superx-state.json" ]; then
  STATE_JSON="$PROJECT/superx-state.json"
else
  STATE_JSON="$PROJECT/heimdall-state.json"
fi

# ── Color detection (mirrors install.sh) ──
if [[ "${COLORTERM:-}" == "truecolor" || "${COLORTERM:-}" == "24bit" || "${TERM:-}" == *256color* ]]; then
  P='\033[38;2;224;86;160m'   # pink
  C='\033[38;2;0;212;255m'    # cyan
  G='\033[38;2;78;204;163m'   # green
  W='\033[38;2;255;200;80m'   # warm yellow
  RED='\033[38;2;255;95;110m' # red
  D='\033[38;2;100;100;120m'  # dim
elif [ -t 1 ] || [ -n "${TERM:-}" ]; then
  P='\033[35m'; C='\033[36m'; G='\033[32m'; W='\033[33m'; RED='\033[31m'; D='\033[37m'
else
  P=''; C=''; G=''; W=''; RED=''; D=''
fi
B='\033[1m'; R='\033[0m'

DASH="—"

# ── JSON reader (python3 → jq → defaults) ──
# Emits: tests lint dirty total limit  (space-separated)
read_state_json() {
  [ -f "$STATE_JSON" ] || { echo "- - - - -"; return; }
  if command -v python3 >/dev/null 2>&1; then
    python3 - "$STATE_JSON" <<'PY' 2>/dev/null && return
import json, sys
try:
    s = json.load(open(sys.argv[1]))
except Exception:
    print("- - - - -"); sys.exit(0)
g = s.get("quality_gates", {}) or {}
b = s.get("budget", {}) or {}
def b2s(v): return "1" if v is True else ("0" if v is False else "-")
tot = b.get("total_tokens"); lim = b.get("token_limit")
print(b2s(g.get("tests_passing")), b2s(g.get("lint_clean")), b2s(g.get("dirty")),
      tot if isinstance(tot,(int,float)) else "-",
      lim if isinstance(lim,(int,float)) else "-")
PY
  fi
  if command -v jq >/dev/null 2>&1; then
    jq -r '
      def b2s: if .==true then "1" elif .==false then "0" else "-" end;
      [ (.quality_gates.tests_passing|b2s), (.quality_gates.lint_clean|b2s),
        (.quality_gates.dirty|b2s), (.budget.total_tokens // "-"),
        (.budget.token_limit // "-") ] | join(" ")
    ' "$STATE_JSON" 2>/dev/null && return
  fi
  echo "- - - - -"
}

read -r ST_TESTS ST_LINT ST_DIRTY ST_TOTAL ST_LIMIT <<<"$(read_state_json)"

# ── Bloat scorecard (H-2) — rendered PURELY from the bloat report.json ──
# Zero model tokens: this is hooks/shell reading the deterministic gate report.
# Format: "0 dead exports · 1.2% dup · LOC 0.9× est · −N lines after simplify".
# Each segment honestly shows "—" when its axis was skipped (tool absent), never
# a fake number. Returns an empty string if no bloat report exists yet.
BLOAT_REPORT=""
for cand in \
  "$PLANNING/spawns/reports/bloat.report.json" \
  "$PROJECT/.planning/spawns/reports/bloat.report.json"; do
  [ -f "$cand" ] && { BLOAT_REPORT="$cand"; break; }
done
read_bloat_line() {
  [ -n "$BLOAT_REPORT" ] && [ -f "$BLOAT_REPORT" ] || { echo ""; return; }
  command -v jq >/dev/null 2>&1 || { echo ""; return; }
  jq -r '
    .metrics as $m
    | ($m.dead_code // {})   as $d
    | ($m.duplication // {}) as $u
    | ($m.loc_budget // {})  as $l
    | (if ($d.status=="ran" or $d.status=="n/a") and ($d.new_unreferenced != null)
         then ($d.new_unreferenced|tostring) + " dead exports" else "— dead" end) as $seg_d
    | (if $u.status=="ran" and ($u.pct != null)
         then (($u.pct|tostring) + "% dup") else "—% dup" end) as $seg_u
    | (if $l.status=="ran" and ($l.ratio != null)
         then ("LOC " + ($l.ratio|tostring) + "× est")
         elif ($l.added != null) then ("LOC " + ($l.added|tostring) + " lines")
         else "LOC —" end) as $seg_l
    | (($m.simplification_delta_lines // 0)) as $sd
    | (if ($sd|tonumber) > 0 then "−" + ($sd|tostring) + " lines after simplify" else "" end) as $seg_s
    | ([$seg_d, $seg_u, $seg_l] + (if $seg_s=="" then [] else [$seg_s] end)) | join(" · ")
  ' "$BLOAT_REPORT" 2>/dev/null || echo ""
}
BLOAT_LINE="$(read_bloat_line)"
BLOAT_STATUS=""
if [ -n "$BLOAT_REPORT" ] && command -v jq >/dev/null 2>&1; then
  BLOAT_STATUS="$(jq -r '.status // ""' "$BLOAT_REPORT" 2>/dev/null || echo "")"
fi

# ── Task / phase name from STATE.md ──
TASK="$DASH"
if [ -f "$STATE_MD" ]; then
  # Prefer an explicit task_name/goal/title; else current_phase; else first H1.
  t=$(grep -m1 -iE '^(task_name|goal|title):' "$STATE_MD" 2>/dev/null | sed -E 's/^[^:]*: *//')
  [ -z "$t" ] && t=$(grep -m1 '^current_phase:' "$STATE_MD" 2>/dev/null | sed 's/current_phase: *//')
  [ -z "$t" ] && t=$(grep -m1 '^# ' "$STATE_MD" 2>/dev/null | sed 's/^# *//')
  [ -n "$t" ] && TASK="$t"
fi

# ── Phase ──
PHASE="$DASH"
if [ -f "$STATE_MD" ]; then
  p=$(grep -m1 '^current_phase:' "$STATE_MD" 2>/dev/null | sed 's/current_phase: *//')
  [ -n "$p" ] && PHASE="$p"
fi

# ── Waves completed (scan PLAN-*.md + SUMMARY-*) ──
WAVES="$DASH"
for plan in "$PLANNING"/PLAN-*.md; do
  [ -f "$plan" ] || continue
  phase_num=$(basename "$plan" | grep -oE '[0-9]+' | head -1)
  # Count both legacy "### Task:" headings and the structured "<task " blocks.
  total=$(grep -cE '^### Task:|<task[ >]' "$plan" 2>/dev/null | head -1 | tr -dc '0-9')
  [ -n "$total" ] || total=0
  done_count=0
  for summary in "$PLANNING"/SUMMARY-"$phase_num"-wave-*.md; do
    [ -f "$summary" ] || continue
    d=$(grep -c "| DONE |" "$summary" 2>/dev/null | head -1 | tr -dc '0-9'); [ -n "$d" ] || d=0
    done_count=$((done_count + d))
  done
  # If no SUMMARY rows but the plan has <done>true</done> blocks, count those.
  if [ "$done_count" -eq 0 ]; then
    d=$(grep -c '<done>true</done>' "$plan" 2>/dev/null | head -1 | tr -dc '0-9'); [ -n "$d" ] || d=0
    done_count="$d"
  fi
  WAVES="$done_count/$total"
  break
done

# ── Commits this session ──
# Boundary = most recent heimdall session-end checkpoint commit. Count commits
# AFTER it (i.e. work done since last session closed). If none found, count
# all commits reachable from HEAD (capped display).
# Match both the new 'heimdall:' prefix and the legacy 'superx:' one (back-compat).
COMMITS="$DASH"
if [ -d "$PROJECT/.git" ] || git -C "$PROJECT" rev-parse --git-dir >/dev/null 2>&1; then
  boundary=$(git -C "$PROJECT" log --grep='\(heimdall\|superx\): session-end checkpoint' \
              --format='%H' -n1 2>/dev/null || true)
  if [ -n "$boundary" ]; then
    c=$(git -C "$PROJECT" rev-list --count "${boundary}..HEAD" 2>/dev/null || echo "")
  else
    c=$(git -C "$PROJECT" rev-list --count HEAD 2>/dev/null || echo "")
  fi
  [ -n "$c" ] && COMMITS="$c"
fi

# ── Gate glyphs / labels ──
gate_label() { # value, ok-text, bad-text
  case "$1" in
    1) printf "%bPASS%b" "$G" "$R" ;;
    0) printf "%bFAIL%b" "$RED" "$R" ;;
    *) printf "%b%s%b" "$D" "$DASH" "$R" ;;
  esac
}
TESTS_LBL=$(gate_label "$ST_TESTS")
LINT_LBL=$(gate_label "$ST_LINT")
case "$ST_DIRTY" in
  1) DIRTY_LBL=$(printf "%bdirty ●%b" "$W" "$R") ;;
  0) DIRTY_LBL=$(printf "%bclean ○%b" "$G" "$R") ;;
  *) DIRTY_LBL=$(printf "%b%s%b" "$D" "$DASH" "$R") ;;
esac

# ── Token figures + raw-Claude-Code estimate ──
fmt_tokens() {
  awk -v n="$1" 'BEGIN{
    if (n=="-" ) { print "—"; exit }
    if (n+0 >= 1000000) printf "%.2fM", n/1000000;
    else if (n+0 >= 1000) printf "%.1fk", n/1000;
    else printf "%d", n;
  }'
}
if [ "$ST_TOTAL" != "-" ]; then
  SPENT=$(fmt_tokens "$ST_TOTAL")
  # Estimate of raw (non-heimdall) Claude Code usage at a ~4x efficiency baseline.
  EST_RAW=$(awk -v t="$ST_TOTAL" 'BEGIN{printf "%d", t/0.25}')
  EST_LBL=$(fmt_tokens "$EST_RAW")
else
  SPENT="$DASH"
  EST_LBL="$DASH"
fi

# ── Token-ledger line — the PROTOCOL's own measured delta (mechanism 6). ──
# Distinct from the budget tokens above: this is the per-run protocol message
# cost summed from .planning/protocol/ledger.jsonl, against the v1 baseline in
# baselines.json — the MEASURED, screenshotable savings claim. Honest "—" when
# the ledger is empty / jq is absent. Format: "measured 12.0k vs ~41.0k v1  (−71%)".
LEDGER_FILE="$PLANNING/protocol/ledger.jsonl"
BASELINE_FILE="$PLANNING/protocol/baselines.json"
LEDGER_LINE=""
if [ -f "$LEDGER_FILE" ] && command -v jq >/dev/null 2>&1; then
  measured=$(jq -s '[.[].tokens // 0] | add // 0' "$LEDGER_FILE" 2>/dev/null || echo 0)
  if [ "${measured:-0}" -gt 0 ] 2>/dev/null; then
    base=0
    if [ -f "$BASELINE_FILE" ]; then
      base=$(jq -r '[.baselines[]? // 0] | add // 0' "$BASELINE_FILE" 2>/dev/null || echo 0)
    fi
    m_lbl=$(fmt_tokens "$measured")
    if [ "${base:-0}" -gt 0 ] 2>/dev/null && [ "$base" -ge "$measured" ]; then
      b_lbl=$(fmt_tokens "$base")
      pct=$(awk -v b="$base" -v m="$measured" 'BEGIN{printf "%d", (b-m)*100/b}')
      LEDGER_LINE="measured ${m_lbl} vs ~${b_lbl} v1  (−${pct}%)"
    else
      LEDGER_LINE="measured ${m_lbl}  (no v1 baseline)"
    fi
  fi
fi

# ── Reel line — the run's shareable artifact (the distribution share-unit). ──
# Newest artifact under .planning/reels/ (prefer mp4 > gif > cast > txt). "—" when
# no reel was produced this run.
REEL_LINE=""
REEL_DIR="$PLANNING/reels"
if [ -d "$REEL_DIR" ]; then
  for ext in mp4 gif cast txt; do
    newest=$(ls -t "$REEL_DIR"/*."$ext" 2>/dev/null | head -1)
    if [ -n "$newest" ]; then
      REEL_LINE="$newest"
      break
    fi
  done
fi

# ── Box rendering ──
# Fixed inner width; pad/truncate each line's visible text to fit.
WIDTH=54
hr() { # char
  local c="$1" out="" i
  for ((i=0; i<WIDTH; i++)); do out="${out}${c}"; done
  printf "%s" "$out"
}

# Print a content row: label (dim) + value, padded to WIDTH visible chars.
# Args: label, value-plain, value-colored
row() {
  local label="$1" vplain="$2" vcolored="$3"
  local left="  ${label} "
  # Visible length = left + vplain
  local vis=$(( ${#left} + ${#vplain} ))
  local pad=$(( WIDTH - vis ))
  [ "$pad" -lt 0 ] && pad=0
  local spaces=""; local i
  for ((i=0; i<pad; i++)); do spaces="${spaces} "; done
  printf "%b│%b%b%s%b%b%s%b│%b\n" \
    "$D" "$R" "$D" "$left" "$R" "$vcolored" "$spaces" "$D" "$R"
}

# Title row (centered-ish, bold pink)
title_row() {
  local txt="$1"
  local vis=$(( ${#txt} + 2 ))
  local pad=$(( WIDTH - vis ))
  [ "$pad" -lt 0 ] && pad=0
  local spaces=""; local i
  for ((i=0; i<pad; i++)); do spaces="${spaces} "; done
  printf "%b│%b %b%b%s%b%s %b│%b\n" "$D" "$R" "$B" "$P" "$txt" "$R" "$spaces" "$D" "$R"
}

# Truncate a plain string to a max visible width with ellipsis.
trunc() {
  local s="$1" max="$2"
  if [ "${#s}" -gt "$max" ]; then
    printf "%s…" "${s:0:$((max-1))}"
  else
    printf "%s" "$s"
  fi
}

TASK_T=$(trunc "$TASK" 44)
PHASE_T=$(trunc "$PHASE" 44)

# Compose value plains (for width math) and colored variants.
GATES_PLAIN="tests:$( [ "$ST_TESTS" = 1 ] && echo PASS || { [ "$ST_TESTS" = 0 ] && echo FAIL || echo "$DASH"; }) lint:$( [ "$ST_LINT" = 1 ] && echo PASS || { [ "$ST_LINT" = 0 ] && echo FAIL || echo "$DASH"; }) $( [ "$ST_DIRTY" = 1 ] && echo 'dirty ●' || { [ "$ST_DIRTY" = 0 ] && echo 'clean ○' || echo "$DASH"; })"
GATES_COLORED="${D}tests:${R}${TESTS_LBL} ${D}lint:${R}${LINT_LBL} ${DIRTY_LBL}"

TOKENS_PLAIN="${SPENT} spent  (vs ~${EST_LBL} raw-CC est.)"
TOKENS_COLORED="${C}${SPENT}${R} ${D}spent${R}  ${D}(vs ~${R}${W}${EST_LBL}${R} ${D}raw-CC est.)${R}"

printf "\n"
printf "%b┌%s┐%b\n" "$D" "$(hr "─")" "$R"
title_row "heimdall · run summary"
printf "%b├%s┤%b\n" "$D" "$(hr "─")" "$R"
row "task " "$TASK_T" "${C}${TASK_T}${R}"
row "phase" "$PHASE_T" "${C}${PHASE_T}${R}"
row "waves" "$WAVES" "${G}${WAVES}${R}"
row "commits" "$COMMITS" "${G}${COMMITS}${R}"
printf "%b├%s┤%b\n" "$D" "$(hr "─")" "$R"
row "gates" "$GATES_PLAIN" "$GATES_COLORED"
row "tokens" "$TOKENS_PLAIN" "$TOKENS_COLORED"
# ── Token-ledger row (H-5) — protocol's own measured delta, only when present ──
if [ -n "$LEDGER_LINE" ]; then
  LEDGER_T=$(trunc "$LEDGER_LINE" 44)
  row "ledger" "$LEDGER_T" "${W}${LEDGER_T}${R}"
fi
# ── Bloat row (H-2) — only when a bloat report exists; truncated to fit. ──
if [ -n "$BLOAT_LINE" ]; then
  BLOAT_T=$(trunc "$BLOAT_LINE" 44)
  case "$BLOAT_STATUS" in
    pass)    BLOAT_COLORED="${G}${BLOAT_T}${R}" ;;
    fail)    BLOAT_COLORED="${RED}${BLOAT_T}${R}" ;;
    skipped) BLOAT_COLORED="${D}${BLOAT_T}${R}" ;;
    *)       BLOAT_COLORED="${C}${BLOAT_T}${R}" ;;
  esac
  row "bloat" "$BLOAT_T" "$BLOAT_COLORED"
fi
# ── Reel row (H-5) — the shareable artifact path, only when a reel exists ──
if [ -n "$REEL_LINE" ]; then
  # Show a short relative-ish path (basename under reels/) to fit the box.
  REEL_SHORT="reels/$(basename "$REEL_LINE")"
  REEL_T=$(trunc "$REEL_SHORT" 44)
  row "reel" "$REEL_T" "${P}${REEL_T}${R}"
fi
printf "%b└%s┘%b\n" "$D" "$(hr "─")" "$R"
printf "\n"
