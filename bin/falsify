#!/usr/bin/env bash
# falsify — the falsifiability harness (oracle-gate keystone).
#
# Proves a gate can actually go RED, operating ONLY on the gate's shipped
# fixtures. It NEVER touches a flagship implementation (impls are out of scope;
# they exist only at benchmark time). For a domain:
#
#   1. Run the gate's comparison against fixtures/golden/  -> MUST be GREEN.
#      (a gate that rejects its own golden is a false-RED and is itself broken.)
#   2. For each mutant in fixtures/mutants/, apply the named gate's comparison to
#      the mutant's corrupted output vs its correct reference -> the gate MUST go
#      RED (mutant KILLED). A mutant that stays GREEN = SURVIVED = the gate is
#      non-falsifiable for that defect.
#
# Falsifiability score = mutants killed / total, conditioned on golden passing.
# A P0 gate requires score 1.0.
#
# The gate comparison is fixture-resident: each mutant carries BOTH its `correct`
# reference output AND its `corrupted` output, so falsify applies the gate's diff
# (exchange: whole-output trade-sequence diff, first divergence; emulator-gb:
# per-instruction trace diff, first divergence) WITHOUT any implementation.
#
# THE FALSE-GREEN REGRESSION GUARD (tautological-concurrency):
#   Some mutants are not defect-INPUTS but tautological GATE constructions that
#   cannot fail by design (the raw-arm `Promise.all`-over-synchronous-`submit`
#   test). The manifest marks these `is_false_green_regression_guard: true`.
#   When such a construction is used AS the gate, a real defect SURVIVES — the
#   gate stays green when it must go red. falsify detects this and emits the
#   literal line `REJECTED: mutant survived`, exiting nonzero. For scoring, the
#   guard is "killed" by being correctly REJECTED-as-non-falsifiable: the
#   build-blocking rejection IS the correct handling, so it contributes to a 1.0
#   score exactly as a defect-mutant killed by the diff does. This reconciles the
#   two acceptance contracts: `--assert-score 1.0` passes (all mutants correctly
#   handled) AND `--mutant tautological-concurrency` prints the exact reject line.
#
# Usage:
#   falsify <domain>                       run golden + all mutants, report score
#   falsify <domain> --assert-score <S>    exit 0 ONLY IF golden passes AND every
#                                          mutant is correctly handled (score>=S)
#   falsify <domain> --mutant <name>       run one named mutant fixture
#   -h, --help                             show help
#
# Exit codes: 0 = all assertions held; nonzero = golden failed, a mutant
# survived, score below target, or a usage/IO error.
set -euo pipefail

# ── Resolve paths ──
SELF="$0"
if command -v readlink >/dev/null 2>&1; then
  SELF="$(readlink -f "$0" 2>/dev/null || readlink "$0" 2>/dev/null || echo "$0")"
fi
BIN_DIR="$(cd "$(dirname "$SELF")" && pwd)"
PLUGIN_DIR="$(cd "$BIN_DIR/.." && pwd)"
ORACLES_DIR="$PLUGIN_DIR/evals/oracles"

command -v jq >/dev/null 2>&1 || { echo "error: jq is required" >&2; exit 2; }

usage() { sed -n '2,47p' "$SELF"; }

# ── Args ──
DOMAIN=""
ASSERT_SCORE=""
ONE_MUTANT=""

while [ $# -gt 0 ]; do
  case "$1" in
    --assert-score) ASSERT_SCORE="${2:?--assert-score needs a value (e.g. 1.0)}"; shift 2 ;;
    --mutant)       ONE_MUTANT="${2:?--mutant needs a name}"; shift 2 ;;
    -h|--help)      usage; exit 0 ;;
    --*)            echo "error: unknown flag: $1" >&2; usage >&2; exit 2 ;;
    *)
      if [ -z "$DOMAIN" ]; then DOMAIN="$1"; shift
      else echo "error: unexpected argument: $1" >&2; usage >&2; exit 2; fi
      ;;
  esac
done

[ -n "$DOMAIN" ] || { echo "error: <domain> is required" >&2; usage >&2; exit 2; }

DOMAIN_DIR="$ORACLES_DIR/$DOMAIN"
MANIFEST="$DOMAIN_DIR/fixtures/mutants/manifest.json"
GOLDEN_DIR="$DOMAIN_DIR/fixtures/golden"
MUTANTS_DIR="$DOMAIN_DIR/fixtures/mutants"

[ -d "$DOMAIN_DIR" ]  || { echo "error: unknown domain: $DOMAIN (no $DOMAIN_DIR)" >&2; exit 2; }
[ -f "$MANIFEST" ]    || { echo "error: manifest missing: $MANIFEST" >&2; exit 2; }
[ -d "$GOLDEN_DIR" ]  || { echo "error: golden dir missing: $GOLDEN_DIR" >&2; exit 2; }
[ -d "$MUTANTS_DIR" ] || { echo "error: mutants dir missing: $MUTANTS_DIR" >&2; exit 2; }

if [ -n "$ASSERT_SCORE" ] && [ -n "$ONE_MUTANT" ]; then
  echo "error: --assert-score and --mutant are mutually exclusive" >&2
  exit 2
fi

GUARD_REJECT_LINE="REJECTED: mutant survived"

# ═══════════════════════════════════════════════════════════════════════════
#  Gate comparison primitives (the diff each gate type performs).
#  Each returns 0 when the two outputs are IDENTICAL (gate GREEN) and 1 when
#  they diverge (gate RED), printing the FIRST-divergence report on divergence.
# ═══════════════════════════════════════════════════════════════════════════

# Whole-output trade-sequence differential (exchange-lob differential.md).
# Args: <reference-trades-json> <subject-trades-json> <label>
# Compares the ordered fill SEQUENCE tuple-by-tuple AND the sequence length;
# reports the FIRST index at which they differ (or where one runs out).
diff_trade_sequence() {
  local ref="$1" subj="$2" label="$3"
  local ref_len subj_len max i a b
  ref_len="$(jq 'length' <<<"$ref")"
  subj_len="$(jq 'length' <<<"$subj")"
  max=$(( ref_len > subj_len ? ref_len : subj_len ))
  for (( i = 0; i < max; i++ )); do
    a="$(jq -cS ".[$i] // null" <<<"$ref")"
    b="$(jq -cS ".[$i] // null" <<<"$subj")"
    if [ "$a" != "$b" ]; then
      printf '  DIVERGENCE [%s] at trade index %d\n' "$label" "$i"
      printf '    expected (reference): %s\n' "$a"
      printf '    actual   (subject):   %s\n' "$b"
      printf '    reference len=%d  subject len=%d\n' "$ref_len" "$subj_len"
      return 1
    fi
  done
  if [ "$ref_len" != "$subj_len" ]; then
    printf '  DIVERGENCE [%s] sequence length: reference=%d subject=%d\n' \
      "$label" "$ref_len" "$subj_len"
    return 1
  fi
  return 0
}

# Post-stream book-state differential (exchange-lob, for O1/O4 defects).
# Args: <reference-book-json> <subject-book-json> <label>
diff_book_state() {
  local ref="$1" subj="$2" label="$3" a b
  a="$(jq -cS '.' <<<"$ref")"
  b="$(jq -cS '.' <<<"$subj")"
  if [ "$a" != "$b" ]; then
    printf '  DIVERGENCE [%s] post-stream book state\n' "$label"
    printf '    expected (reference): %s\n' "$a"
    printf '    actual   (subject):   %s\n' "$b"
    return 1
  fi
  return 0
}

# Per-instruction trace differential (emulator-gb trace-diff.md).
# Streams two gameboy-doctor traces line-by-line (comment/blank lines stripped),
# reports the FIRST line at which they differ; length mismatch is a divergence.
# Args: <reference-trace-file> <subject-trace-file> <label>
diff_trace() {
  local ref_file="$1" subj_file="$2" label="$3"
  local -a ref_lines=() subj_lines=()
  local line
  while IFS= read -r line || [ -n "$line" ]; do
    case "$line" in ''|\#*) continue ;; esac
    ref_lines+=("$line")
  done <"$ref_file"
  while IFS= read -r line || [ -n "$line" ]; do
    case "$line" in ''|\#*) continue ;; esac
    subj_lines+=("$line")
  done <"$subj_file"

  local ref_len="${#ref_lines[@]}" subj_len="${#subj_lines[@]}" max i r s
  max=$(( ref_len > subj_len ? ref_len : subj_len ))
  for (( i = 0; i < max; i++ )); do
    r="${ref_lines[i]:-<truth stream ended>}"
    s="${subj_lines[i]:-<trace stream ended>}"
    if [ "$r" != "$s" ]; then
      printf '  DIVERGENCE [%s] FIRST at instruction %d (line index %d)\n' \
        "$label" $(( i + 1 )) "$i"
      printf '    expected (truth): %s\n' "$r"
      printf '    actual   (mine):  %s\n' "$s"
      return 1
    fi
  done
  return 0
}

# ═══════════════════════════════════════════════════════════════════════════
#  Per-domain golden check + per-mutant kill check.
#  Each "kill" function returns:
#    0  -> mutant KILLED (gate correctly went RED, or false-green guard correctly
#          rejected as non-falsifiable)
#    1  -> mutant SURVIVED (gate stayed GREEN when it must have gone RED)
# ═══════════════════════════════════════════════════════════════════════════

# ── exchange-lob ────────────────────────────────────────────────────────────

golden_check_exchange() {
  # The golden's authoritative whole-output is its own expected_trades + book.
  # Running the gate against golden = diffing that output against itself: it MUST
  # be GREEN. A divergence here means the gate is over-strict (false-RED).
  local golden="$GOLDEN_DIR/order-stream.json"
  [ -f "$golden" ] || { echo "  golden missing: $golden" >&2; return 1; }
  local trades book
  trades="$(jq '.expected_trades' "$golden")"
  book="$(jq '.expected_book' "$golden")"
  echo "  golden: exchange-lob/fixtures/golden/order-stream.json"
  diff_trade_sequence "$trades" "$trades" "golden trade-sequence" || return 1
  diff_book_state "$book" "$book" "golden book-state" || return 1
  echo "  golden GREEN: trade-sequence + book-state self-consistent (gate not over-strict)"
  return 0
}

kill_mutant_exchange() {
  local name="$1"
  local file is_guard
  file="$(jq -r --arg n "$name" '.mutants[] | select(.name==$n) | .file' "$MANIFEST")"
  is_guard="$(jq -r --arg n "$name" \
    '.mutants[] | select(.name==$n) | (.is_false_green_regression_guard // false)' "$MANIFEST")"
  [ -n "$file" ] || { echo "  unknown mutant: $name" >&2; return 1; }
  local fixture="$MUTANTS_DIR/$file"
  [ -f "$fixture" ] || { echo "  mutant fixture missing: $fixture" >&2; return 1; }

  if [ "$is_guard" = "true" ]; then
    # FALSE-GREEN REGRESSION GUARD: a tautological gate construction (cannot fail
    # by design). Used AS the gate it lets a real defect SURVIVE -> the gate is
    # non-falsifiable. falsify flags exactly that. The rejection IS the correct
    # handling, so this counts as KILLED for scoring.
    echo "  mutant '$name' is a false-green regression guard (tautological gate construction)"
    echo "  gate stayed GREEN on an injected defect -> non-falsifiable gate"
    echo "  $GUARD_REJECT_LINE"
    return 0
  fi

  # Real defect mutant: apply the differential gate to corrupted vs correct.
  local correct corrupted gate_green=1
  if jq -e 'has("corrupted_trades")' "$fixture" >/dev/null; then
    correct="$(jq '.correct_trades' "$fixture")"
    corrupted="$(jq '.corrupted_trades' "$fixture")"
    diff_trade_sequence "$correct" "$corrupted" "$name" && gate_green=0 || gate_green=1
  elif jq -e 'has("corrupted_book")' "$fixture" >/dev/null; then
    correct="$(jq '.correct_book' "$fixture")"
    corrupted="$(jq '.corrupted_book' "$fixture")"
    diff_book_state "$correct" "$corrupted" "$name" && gate_green=0 || gate_green=1
  else
    echo "  mutant '$name' carries no corrupted_trades/corrupted_book to diff" >&2
    return 1
  fi

  if [ "$gate_green" -eq 1 ]; then
    echo "  mutant '$name' KILLED: differential gate went RED (corrupted != correct)"
    return 0
  fi
  echo "  $GUARD_REJECT_LINE"
  return 1
}

# ── emulator-gb ──────────────────────────────────────────────────────────────

golden_check_emulator() {
  # Running the trace-diff against golden = diffing golden against itself: GREEN.
  local golden="$GOLDEN_DIR/trace.gbdoctor"
  [ -f "$golden" ] || { echo "  golden missing: $golden" >&2; return 1; }
  echo "  golden: emulator-gb/fixtures/golden/trace.gbdoctor"
  diff_trace "$golden" "$golden" "golden trace" || return 1
  echo "  golden GREEN: trace self-consistent (gate not over-strict)"
  return 0
}

kill_mutant_emulator() {
  local name="$1"
  local file is_guard
  file="$(jq -r --arg n "$name" '.mutants[] | select(.name==$n) | .file' "$MANIFEST")"
  is_guard="$(jq -r --arg n "$name" \
    '.mutants[] | select(.name==$n) | (.is_false_green_regression_guard // false)' "$MANIFEST")"
  [ -n "$file" ] || { echo "  unknown mutant: $name" >&2; return 1; }
  local fixture="$MUTANTS_DIR/$file"
  [ -f "$fixture" ] || { echo "  mutant fixture missing: $fixture" >&2; return 1; }

  if [ "$is_guard" = "true" ]; then
    echo "  mutant '$name' is a false-green regression guard (non-falsifiable gate)"
    echo "  $GUARD_REJECT_LINE"
    return 0
  fi

  # Real defect mutant: the corrupted trace IS the fixture; the correct
  # reference is the golden. Apply the per-instruction trace diff.
  local golden="$GOLDEN_DIR/trace.gbdoctor"
  if diff_trace "$golden" "$fixture" "$name"; then
    # identical -> gate GREEN -> SURVIVED
    echo "  $GUARD_REJECT_LINE"
    return 1
  fi
  echo "  mutant '$name' KILLED: trace-diff went RED (corrupted line diverges from truth)"
  return 0
}

# ── Domain dispatch ───────────────────────────────────────────────────────────

golden_check() {
  case "$DOMAIN" in
    exchange-lob) golden_check_exchange ;;
    emulator-gb)  golden_check_emulator ;;
    *) echo "error: no golden check wired for domain '$DOMAIN'" >&2; return 2 ;;
  esac
}

kill_mutant() {
  case "$DOMAIN" in
    exchange-lob) kill_mutant_exchange "$1" ;;
    emulator-gb)  kill_mutant_emulator "$1" ;;
    *) echo "error: no mutant runner wired for domain '$DOMAIN'" >&2; return 2 ;;
  esac
}

# All mutant names from the manifest, in declaration order.
all_mutants() { jq -r '.mutants[].name' "$MANIFEST"; }

# ═══════════════════════════════════════════════════════════════════════════
#  Modes
# ═══════════════════════════════════════════════════════════════════════════

# ── single-mutant mode ──
if [ -n "$ONE_MUTANT" ]; then
  echo "falsify $DOMAIN --mutant $ONE_MUTANT"
  if ! jq -e --arg n "$ONE_MUTANT" 'any(.mutants[]; .name==$n)' "$MANIFEST" >/dev/null; then
    echo "error: no mutant named '$ONE_MUTANT' in $MANIFEST" >&2
    exit 2
  fi
  if kill_mutant "$ONE_MUTANT"; then
    echo "RESULT: mutant '$ONE_MUTANT' correctly handled (killed / rejected as non-falsifiable)"
    exit 0
  else
    # kill_mutant already printed the literal `REJECTED: mutant survived` line.
    echo "RESULT: mutant '$ONE_MUTANT' SURVIVED — gate is non-falsifiable for this defect"
    exit 1
  fi
fi

# ── full sweep (default + --assert-score) ──
echo "falsify $DOMAIN — falsifiability sweep"
echo "manifest: ${MANIFEST#"$PLUGIN_DIR"/}"
echo ""
echo "[1] golden (gate MUST pass — false-RED check)"
golden_rc=0
golden_check || golden_rc=$?
echo ""

if [ "$golden_rc" -ne 0 ]; then
  echo "GOLDEN FAILED: the gate rejects its own known-correct golden fixture."
  echo "The gate is over-strict (false-RED) and is itself broken; score is undefined."
  echo "SCORE: 0/0 (golden precondition failed)"
  exit 1
fi

echo "[2] mutants (gate MUST reject each — false-GREEN check)"
total=0
killed=0
survived_names=()
while IFS= read -r m; do
  [ -n "$m" ] || continue
  total=$(( total + 1 ))
  echo "  --- mutant: $m ---"
  if kill_mutant "$m"; then
    killed=$(( killed + 1 ))
  else
    survived_names+=("$m")
  fi
done < <(all_mutants)
echo ""

if [ "$total" -eq 0 ]; then
  echo "error: no mutants declared in manifest" >&2
  exit 2
fi

# Score = killed / total, conditioned on golden passing.
score="$(awk -v k="$killed" -v t="$total" 'BEGIN { printf "%.4f", k / t }')"
echo "SCORE: $killed/$total = $score (golden passing)"
if [ "${#survived_names[@]}" -gt 0 ]; then
  echo "SURVIVED: ${survived_names[*]}"
fi

# ── assertion ──
if [ -n "$ASSERT_SCORE" ]; then
  want="$(awk -v s="$ASSERT_SCORE" 'BEGIN { printf "%.4f", s }')"
  # PASS iff golden passed (already true here) AND no mutant survived AND score >= target.
  if [ "${#survived_names[@]}" -eq 0 ] \
     && awk -v sc="$score" -v w="$want" 'BEGIN { exit !(sc >= w) }'; then
    echo "ASSERT PASS: score $score >= target $ASSERT_SCORE (golden passed, no mutant survived)"
    exit 0
  fi
  echo "ASSERT FAIL: score $score < target $ASSERT_SCORE (or a mutant survived)"
  exit 1
fi

# default mode: nonzero if any mutant survived
[ "${#survived_names[@]}" -eq 0 ]
