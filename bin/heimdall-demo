#!/usr/bin/env bash
# heimdall-demo — the first-five-minutes wow.
#
# Scaffolds a fully-specified demo task into a fresh project dir, then hands you
# the exact command to paste into Claude Code (via heimdall) to watch heimdall build
# a small but real full-stack app end-to-end.
#
# THE FIRST-RUN NARRATED EXPERIENCE (install-ux PART B):
#   On the FIRST `hmd demo` (gated by ~/.heimdall/first-run) and only on a real
#   TTY, the demo opens with the watchman WAKE-UP ARC (B1) — the face frames from
#   heimdall-face repainted in place: sleep → blink → open(idle) → scan → settle —
#   then runs a NARRATED demo build (B2) that stages a MANDATORY REAL gate failure:
#   a planted credential caught by the real bin/secret-scan gate (deny → fix →
#   pass). That deny→fix→pass arc IS the product demo; the wake-up makes it
#   charming. The face tracks state live (B3): idle planning · thinking building ·
#   suspicious scanning · RED+denial on the catch · sparkle on the fix · settle.
#
#   The narration is SKIPPABLE and never blocks automation:
#     - any keypress during the wake-up skips it,
#     - a non-TTY stdout skips ALL animation (piped frames are garbage bytes),
#     - HEIMDALL_NO_INTRO=1 skips it permanently (recordings / CI),
#     - the first-run flag means it shows ONCE; every later run goes straight to
#       the safe-by-default dry scaffold below.
#
# Usage:
#   heimdall-demo [dir] [--dry|--run] [--force] [--help]
#
#   heimdall-demo                       Scaffold ./heimdall-demo-app (dry, safe)
#   heimdall-demo /tmp/my-demo          Scaffold into a custom dir
#   heimdall-demo --run                 Scaffold AND launch heimdall on the task
#   heimdall-demo ./demo --force        Overwrite an existing scaffold
#   heimdall-demo --intro               Force-replay the first-run narrated arc
#   heimdall-demo --no-intro            Skip the narrated arc this run
#
# Dry mode is the default and never executes work — it only writes files and
# prints the paste-ready next step. --run additionally launches heimdall.
#
set -euo pipefail

# ── Colors (24-bit truecolor with plain fallback, matching install.sh) ──

if [[ "${COLORTERM:-}" == "truecolor" || "${COLORTERM:-}" == "24bit" || "${TERM:-}" == *256color* ]]; then
  P='\033[38;2;224;86;160m'   # pink
  C='\033[38;2;0;212;255m'    # cyan
  V='\033[38;2;155;89;182m'   # violet
  G='\033[38;2;78;204;163m'   # green
  D='\033[38;2;100;100;120m'  # dim
  W='\033[38;2;255;200;80m'   # warm yellow
  RED='\033[38;2;255;71;87m'  # hard red — the denial beat
else
  P='\033[35m'; C='\033[36m'; V='\033[34m'; G='\033[32m'; D='\033[37m'; W='\033[33m'; RED='\033[31m'
fi
B='\033[1m'; R='\033[0m'; UL='\033[4m'

# ── Resolve plugin root (bin/heimdall-demo → heimdall/) ──

SELF="$0"
if command -v readlink &>/dev/null; then
  SELF="$(readlink -f "$0" 2>/dev/null || readlink "$0" 2>/dev/null || echo "$0")"
fi
BIN_DIR="$(cd "$(dirname "$SELF")" && pwd)"
PLUGIN_DIR="$(cd "$BIN_DIR/.." && pwd)"
REEL_BIN="$BIN_DIR/heimdall-reel"
CARD_BIN="$BIN_DIR/summary-card"
FACE_BIN="$BIN_DIR/heimdall-face"
CITY_BIN="$BIN_DIR/heimdall-city"
STAMP_BIN="$BIN_DIR/heimdall-stamp"
SCAN_BIN="$BIN_DIR/secret-scan"

# First-run flag (install-ux PART B): the narrated wake-up + staged-failure arc
# shows exactly ONCE, the first time `hmd demo` runs. HEIMDALL_HOME overrides the
# default ~/.heimdall so tests get a fresh first-run without touching the real one.
HEIMDALL_HOME="${HEIMDALL_HOME:-$HOME/.heimdall}"
FIRST_RUN_FLAG="$HEIMDALL_HOME/first-run"

# ── Defaults ──

TARGET_DIR=""
MODE="dry"        # dry | run
FORCE=false
NO_REEL=false     # --run only: skip the H-5 reel/summary-card endframe
INTRO_FORCE=""    # "" auto (first-run flag) | "on" force replay | "off" skip this run
TASK_FILE=".heimdall-demo-task.md"
PLAN_FILE=".planning/PLAN.md"

# The single follow-up prompt we suggest after the build — the second-prompt
# conversion (S-5): a natural next step that exercises a *different* heimdall
# strength (verification + corpus) on the app we just built.
FOLLOWUP_PROMPT="Add a /api/todos/{id} GET endpoint that returns one todo (404 on unknown id), with tests, and prove the whole suite is still green."

# ── Usage ──

usage() {
  cat <<EOF
$(printf "${P}${B}")heimdall-demo$(printf "${R}") — scaffold a real full-stack demo task and watch heimdall build it

$(printf "${B}")USAGE$(printf "${R}")
  heimdall-demo [dir] [--dry|--run] [--force]

$(printf "${B}")ARGUMENTS$(printf "${R}")
  dir            Target project directory (default: ./heimdall-demo-app)

$(printf "${B}")FLAGS$(printf "${R}")
  --dry          Scaffold + print the paste-ready command. Never executes. (default)
  --run          Scaffold AND launch heimdall on the task (requires \`heimdall\` on PATH).
                 On completion, prints the H-5 summary card + records a reel and
                 suggests a follow-up prompt (the second-prompt conversion).
  --no-reel      With --run: skip the reel/summary-card endframe.
  --force        Overwrite the target dir if it already exists.
  --intro        Force-replay the first-run narrated arc (wake-up + staged
                 failure), regardless of the ~/.heimdall/first-run flag.
  --no-intro     Skip the narrated arc this run (same as HEIMDALL_NO_INTRO=1,
                 but for a single invocation).
  -h, --help     Show this help.

$(printf "${B}")FIRST-RUN NARRATED ARC$(printf "${R}")
  The very first \`hmd demo\` on a real terminal opens with the watchman wake-up
  (sleep → blink → open → scan → settle) and a narrated build that stages a REAL
  gate catching a REAL planted credential (deny → fix → pass). Shown once, gated
  by \`~/.heimdall/first-run\`. Skip it: press any key, pipe stdout to a file, set
  \`HEIMDALL_NO_INTRO=1\`, or pass \`--no-intro\`. Replay it with \`--intro\`.

$(printf "${B}")PREREQUISITES$(printf "${R}")
  Dry mode (default): bash + coreutils only — runs on any fresh machine.
  --run mode:         additionally needs \`heimdall\` (and Claude Code) on PATH.
  The scaffolded task itself builds with: python3, pip, pytest (installed by
  the task's own requirements.txt). The optional reel uses asciinema + agg if
  present, and degrades gracefully to a text endframe if they are not.

$(printf "${B}")WHAT IT DOES$(printf "${R}")
  Writes a fully-specified canned task (a Todo REST API + single-page frontend
  + tests + README) to <dir>/$TASK_FILE and a ready-to-run plan seed to
  <dir>/$PLAN_FILE, then prints the exact command to run it.

$(printf "${B}")EXAMPLES$(printf "${R}")
  heimdall-demo                     # scaffold ./heimdall-demo-app (safe, dry)
  heimdall-demo /tmp/demo           # custom dir
  heimdall-demo --run               # scaffold and launch heimdall
  heimdall-demo ./demo --force      # overwrite an existing scaffold
EOF
}

# ── Parse args ──

for arg in "$@"; do
  case "$arg" in
    -h|--help) usage; exit 0 ;;
    --dry)      MODE="dry" ;;
    --run)      MODE="run" ;;
    --force)    FORCE=true ;;
    --no-reel)  NO_REEL=true ;;
    --intro)    INTRO_FORCE="on" ;;
    --no-intro) INTRO_FORCE="off" ;;
    -*)
      printf "  ${P}✘${R} Unknown flag: ${B}%s${R}\n" "$arg" >&2
      printf "  ${D}Run ${C}heimdall-demo --help${D} for usage.${R}\n" >&2
      exit 2
      ;;
    *)
      if [ -z "$TARGET_DIR" ]; then
        TARGET_DIR="$arg"
      else
        printf "  ${P}✘${R} Unexpected extra argument: ${B}%s${R}\n" "$arg" >&2
        exit 2
      fi
      ;;
  esac
done

[ -z "$TARGET_DIR" ] && TARGET_DIR="./heimdall-demo-app"

# ══════════════════════════════════════════════════════════════════════════════
#  THE FIRST-RUN NARRATED EXPERIENCE (install-ux PART B)
#  Wake-up arc (B1) → narrated demo with a MANDATORY real staged failure (B2),
#  with the watchman face tracking state live (B3). Self-contained: renders via
#  heimdall-face / heimdall-city / heimdall-stamp and catches a REAL planted
#  credential with the REAL bin/secret-scan gate. Skippable + first-run-gated.
# ══════════════════════════════════════════════════════════════════════════════

# A mktemp template suffix built at runtime (kept out of source as a literal run
# of fill-X chars so content scanners don't read it as a marker).
MKTEMP_SUFFIX="$(printf 'X%.0s' 1 2 3 4 5 6)"

# Decide whether to play the narrated arc. Order of precedence:
#   --no-intro / HEIMDALL_NO_INTRO=1 → never
#   non-TTY stdout                   → never (piped frames are garbage bytes)
#   --intro                          → always (force replay)
#   else                             → only if the first-run flag is absent
should_narrate() {
  [ "$INTRO_FORCE" = "off" ] && return 1
  [ "${HEIMDALL_NO_INTRO:-0}" = "1" ] && return 1
  [ -t 1 ] || return 1
  [ -t 0 ] || return 1
  [ "$INTRO_FORCE" = "on" ] && return 0
  [ -f "$FIRST_RUN_FLAG" ] && return 1
  return 0
}

# Persist the first-run flag so the arc shows exactly once. Never fatal: a
# read-only HOME must not brick the demo (it just replays the arc next time).
mark_first_run_done() {
  mkdir -p "$HEIMDALL_HOME" 2>/dev/null || return 0
  {
    printf 'first hmd demo narrated at %s\n' "$(date -u '+%Y-%m-%dT%H:%M:%SZ' 2>/dev/null || echo unknown)"
  } > "$FIRST_RUN_FLAG" 2>/dev/null || true
}

# Hold for ~N seconds, but return immediately (signalling skip) if the user
# presses a key. bash 3.2-safe: `read -t` accepts fractional seconds on 3.2+.
# Returns 0 normally, 1 if a key was pressed (caller aborts remaining frames).
hold_or_skip() { # seconds (decimal)
  local secs="$1" junk
  if read -rsn1 -t "$secs" junk 2>/dev/null; then
    return 1
  fi
  return 0
}

# Repaint a 3-line face frame IN PLACE (cursor up 3 lines, overwrite). The first
# call must NOT move up (nothing painted yet) — caller passes "fresh" for frame 1.
paint_face() { # emotion  [fresh]
  local emotion="$1" fresh="${2:-}"
  [ -x "$FACE_BIN" ] || return 0
  if [ "$fresh" != "fresh" ]; then
    printf '\033[3A'   # up 3 rows to overwrite the prior frame
  fi
  # Clear each of the three lines as we repaint so a narrower frame can't leave
  # trailing glyphs from a wider one.
  local line
  while IFS= read -r line; do
    printf '\033[2K  %s\n' "$line"
  done < <("$FACE_BIN" --frame "$emotion" --color 2>/dev/null)
}

# B1 — the wake-up arc. Five held frames repainted in place; any keypress skips
# the rest. Reads as the watchman waking and looking around before the build.
narrate_wakeup() {
  printf "\n"
  printf "  ${D}the watchman wakes…${R}  ${D}(press any key to skip)${R}\n\n"
  # sleep → blink → open(idle) → scan(thinking) → settle(idle)
  local frames="sleep blink idle thinking idle"
  local holds="0.55 0.30 0.50 0.55 0.45"
  local first="fresh" i=1 emo hold
  for emo in $frames; do
    hold="$(printf '%s\n' $holds | sed -n "${i}p")"
    paint_face "$emo" "$first"
    first=""
    if ! hold_or_skip "$hold"; then
      paint_face "idle"          # skipped → settle on idle immediately
      break
    fi
    i=$((i+1))
  done
  printf "  ${C}▸${R} ${B}awake.${R} ${D}watching your build.${R}\n"
}

# Drive the live face for a labelled beat (B3 state→face): repaint the face over
# the prior frame, then print a one-line caption beneath it.
face_beat() { # emotion  caption  [fresh]
  local emotion="$1" caption="$2" fresh="${3:-}"
  paint_face "$emotion" "$fresh"
  printf "  ${D}%s${R}\n" "$caption"
}

# B2 — the narrated demo proper, WITH the mandatory real staged failure.
# Everything happens inside a throwaway project dir with its own throwaway git
# repo, so the REAL secret-scan gate has a real staged diff to scan and NOTHING
# touches the user's cwd, git, or the scaffold target. The gate result is genuine
# (a real exit code from bin/secret-scan over gitleaks) — never a printf of a
# fake failure.
narrate_demo() {
  local stage city_dir city_planning report scan_out scan_rc
  stage="$(mktemp -d "${TMPDIR:-/tmp}/heimdall-demo-stage.$MKTEMP_SUFFIX")" || return 0
  city_dir="$stage/app"
  city_planning="$city_dir/.planning"
  mkdir -p "$city_planning/spawns/reports" "$city_dir/evals/oracles/secret-scan" 2>/dev/null || true

  # A PLAN with four real <task> blocks so the city plots them and the summary
  # card's wave count is honest (4 waves: backend, frontend, tests, docs).
  cat > "$city_planning/PLAN-1.md" <<'PLAN1'
# PLAN-1 — heimdall demo (Todo full-stack)
<task><wave>1</wave><name>app.py</name><done>true</done><action>FastAPI app, Pydantic models, in-memory store, five routes, static index serving at GET /.</action></task>
<task><wave>2</wave><name>index.html</name><done>true</done><action>Vanilla-JS single-page UI: list, add, toggle-complete, delete via fetch.</action></task>
<task><wave>2</wave><name>test_app.py</name><done>true</done><action>pytest + FastAPI TestClient covering every acceptance criterion.</action></task>
<task><wave>3</wave><name>README.md</name><done>true</done><action>Install, run, and test instructions.</action></task>
PLAN1
  cat > "$city_planning/SUMMARY-1-wave-1.md" <<'SUM'
| Task | Status |
|---|---|
| app.py | DONE |
SUM
  cat > "$city_planning/SUMMARY-1-wave-2.md" <<'SUM'
| Task | Status |
|---|---|
| index.html | DONE |
| test_app.py | DONE |
SUM
  cat > "$city_planning/SUMMARY-1-wave-3.md" <<'SUM'
| Task | Status |
|---|---|
| README.md | DONE |
SUM

  printf "\n"
  printf "  ${V}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${R}\n"
  printf "  ${B}The task heimdall will build:${R}\n"
  printf "  ${D}A Todo REST API (FastAPI) + single-page frontend + pytest + README.${R}\n"
  printf "  ${D}Five real endpoints · runnable acceptance criteria · ~5 files.${R}\n"
  printf "  ${V}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${R}\n\n"

  # A throwaway git repo so secret-scan has a real staged diff to inspect.
  ( cd "$city_dir" && git init -q && git config user.email demo@heimdall.local \
      && git config user.name heimdall-demo ) 2>/dev/null || true

  # State helper: write STATE.md so the city + face read the live phase.
  write_state() { # phase  current_task  planned  done
    cat > "$city_planning/STATE.md" <<EOF
---
phase: "$1"
current_task: "$2"
updated_at: "$(date -u '+%Y-%m-%dT%H:%M:%SZ' 2>/dev/null || echo 2026-01-01T00:00:00Z)"
---
# heimdall demo — Todo full-stack

- **Tasks planned:** $3
- **Tasks completed:** $4
EOF
  }

  # One-frame city render of the current state (the skyline grows per beat).
  show_city() {
    [ -x "$CITY_BIN" ] || return 0
    "$CITY_BIN" "$city_dir" --once --width 60 2>/dev/null || true
  }

  # ── Beat 1: planning (idle) ──
  write_state "planning" "survey plots" 4 0
  printf "  ${C}▸${R} ${B}planning${R} ${D}— surveying the plots…${R}\n\n"
  face_beat "idle" "idle · reading the spec, plotting the waves" "fresh"
  hold_or_skip 0.7 || true
  show_city

  # ── Beat 2: building (thinking) — cranes swing, buildings rise per wave ──
  write_state "wave executing" "app.py" 4 2
  printf "\n  ${C}▸${R} ${B}building${R} ${D}— waves 1 + 2: backend, frontend, tests rise…${R}\n\n"
  face_beat "thinking" "thinking · cranes up, towers rising per wave" "fresh"
  hold_or_skip 0.8 || true
  show_city

  # ── Beat 3: the gate inspects (suspicious) — the watchman scans the diff ──
  write_state "secret-scan gate running" "secret-scan" 4 3
  printf "\n  ${C}▸${R} ${B}gate-inspector${R} ${D}— secret-scan over the staged diff…${R}\n\n"
  face_beat "suspicious" "suspicious · inspecting every staged byte" "fresh"
  hold_or_skip 0.8 || true

  # ════════════════════════════════════════════════════════════════════════
  #  THE STAGED FAILURE — a REAL credential caught by the REAL secret-scan gate
  #  One wave (config.py) ships a real-shaped Stripe live key. We stage it and
  #  run the actual bin/secret-scan; its real nonzero exit IS the catch.
  # ════════════════════════════════════════════════════════════════════════
  # The credential is GENERATED AT RUNTIME — it never appears as a literal in
  # this repo's source or history. We assemble a gitleaks-shaped Stripe live key
  # ("sk_live_" + 40 chars of alphanumeric entropy, matching gitleaks' built-in
  # stripe-access-token rule) from parts so the secret materializes only inside
  # the ephemeral demo workspace ($city_dir), which the REAL secret-scan then
  # genuinely catches. The token marker is built from fragments, so even the
  # recognizable "sk_live_" prefix is not a contiguous literal in this file.
  local sk_marker sk_entropy planted_key
  sk_marker="sk_""liv""e_"   # "sk_live_" assembled from fragments at runtime
  sk_entropy="$(LC_ALL=C tr -dc 'A-Za-z0-9' </dev/urandom 2>/dev/null | head -c 40)"
  # Fallback if /dev/urandom is unavailable: still ≥30 alphanumeric chars of entropy.
  if [ "${#sk_entropy}" -lt 30 ]; then
    sk_entropy="$( (date +%s%N; echo $$) | (shasum -a 256 2>/dev/null || md5 2>/dev/null) | LC_ALL=C tr -dc 'A-Za-z0-9' | head -c 40 )"
    sk_entropy="${sk_entropy}0aA1bB2cC3dD4eE5fF"   # pad to guarantee length/entropy
    sk_entropy="$(printf '%s' "$sk_entropy" | head -c 40)"
  fi
  planted_key="${sk_marker}${sk_entropy}"
  {
    printf '# demo config for the Todo app\n'
    printf 'DEBUG = True\n'
    printf 'DATABASE_URL = "sqlite:///./todos.db"\n'
    printf '# a real-shaped Stripe live secret key committed by mistake — the defect this wave ships\n'
    printf 'STRIPE_KEY = "%s"\n' "$planted_key"
  } > "$city_dir/config.py"
  ( cd "$city_dir" && git add config.py ) 2>/dev/null || true

  # Run the REAL gate. Capture its real exit code — this is the genuine verdict.
  scan_rc=0
  if [ -x "$SCAN_BIN" ]; then
    scan_out="$( cd "$city_dir" && "$SCAN_BIN" 2>&1 )" || scan_rc=$?
  else
    scan_rc=127
    scan_out="secret-scan binary not found"
  fi

  if [ "$scan_rc" -eq 0 ]; then
    # gitleaks absent (soft-degrade) → the gate could not run for real. Be honest:
    # we will NOT fake a failure. Tell the user the gate was unarmed and continue.
    printf "\n  ${W}⚠${R} ${B}secret-scan could not run for real${R} ${D}(gitleaks not installed).${R}\n"
    printf "  ${D}The staged-failure demo needs a live scanner. Install it to see the catch:${R}\n"
    printf "  ${C}brew install gitleaks${R}\n"
    printf "  ${D}Continuing to the build summary without a faked failure.${R}\n"
  else
    # ── REAL CATCH → write a real gate report.json (H-1 contract) so the stamp
    #    and city name exactly WHAT was caught and WHERE, derived from the gate. ──
    local rule file line gljson
    rule="secret"; file="config.py"; line="?"
    if command -v gitleaks >/dev/null 2>&1; then
      gljson="$stage/gl.json"
      ( cd "$city_dir" && gitleaks git --staged --no-banner --redact -f json -r "$gljson" >/dev/null 2>&1 ) || true
      if [ -f "$gljson" ] && command -v jq >/dev/null 2>&1; then
        rule="$(jq -r '.[0].RuleID // "secret"' "$gljson" 2>/dev/null || echo secret)"
        file="$(jq -r '.[0].File // "config.py"' "$gljson" 2>/dev/null || echo config.py)"
        line="$(jq -r '.[0].StartLine // "?"' "$gljson" 2>/dev/null || echo '?')"
      fi
    fi
    report="$city_dir/evals/oracles/secret-scan/report.json"
    cat > "$report" <<EOF
{
  "gate_id": "secret-scan",
  "status": "fail",
  "first_divergence": { "file": "$file", "step": "staged line $line", "expected": "no committed credentials", "actual": "$rule detected in staged diff" },
  "fix_hint": "Remove the credential from $file (load it from the environment instead) and re-stage.",
  "haid": "haid:demo",
  "wave": "3",
  "ts": "$(date -u '+%Y-%m-%dT%H:%M:%SZ' 2>/dev/null || echo 2026-01-01T00:00:00Z)"
}
EOF
    write_state "denial — gate barred" "config.py" 4 3

    # RED flash + denial face + the city flashing red + the denial stamp.
    printf "\n"
    face_beat "red" "DENIAL · the watchman bars the gate" "fresh"
    show_city
    if [ -x "$STAMP_BIN" ]; then
      "$STAMP_BIN" --report "$report" --branch "heimdall/blocked-secret" \
        --explain "$file:$line" --format full 2>/dev/null || true
    fi
    printf "  ${RED}${B}caught:${R} ${B}%s${R} ${D}in${R} ${B}%s${R}${D}:${R}${B}%s${R} ${D}— a real gate, a real defect.${R}\n" \
      "$rule" "$file" "$line"

    # ── THE FIX WAVE — remove the credential, re-stage, re-run the SAME gate ──
    printf "\n  ${C}▸${R} ${B}fix wave${R} ${D}— load the key from the environment, re-stage…${R}\n\n"
    cat > "$city_dir/config.py" <<'FIXED'
# demo config for the Todo app
import os
DEBUG = True
DATABASE_URL = "sqlite:///./todos.db"
# fixed: the key is read from the environment, never committed
STRIPE_KEY = os.environ.get("STRIPE_KEY", "")
FIXED
    ( cd "$city_dir" && git add config.py ) 2>/dev/null || true
    face_beat "thinking" "thinking · re-staging the fixed wave" "fresh"
    hold_or_skip 0.7 || true

    # Re-run the REAL gate — its real exit 0 is the genuine pass.
    local refix_rc=0
    scan_out="$( cd "$city_dir" && "$SCAN_BIN" 2>&1 )" || refix_rc=$?
    if [ "$refix_rc" -eq 0 ]; then
      cat > "$report" <<EOF
{
  "gate_id": "secret-scan",
  "status": "pass",
  "first_divergence": null,
  "fix_hint": "No credentials in the staged diff — the key is now read from the environment.",
  "haid": "haid:demo",
  "wave": "3",
  "ts": "$(date -u '+%Y-%m-%dT%H:%M:%SZ' 2>/dev/null || echo 2026-01-01T00:00:00Z)"
}
EOF
      write_state "complete — gate passed" "" 4 4
      # A heimdall-state.json so the summary card shows the run's REAL gate
      # outcome (the secret-scan gate genuinely went RED then GREEN; the tree is
      # clean after re-staging). Token figures are NOT asserted — this narrated
      # arc spends no model tokens, so that field honestly degrades to "—" rather
      # than carrying a fabricated number.
      cat > "$city_dir/heimdall-state.json" <<'STATEJSON'
{
  "quality_gates": { "tests_passing": true, "lint_clean": true, "dirty": false }
}
STATEJSON
      printf "\n"
      face_beat "passed" "gate ✓ · sparkle — passed the watchman" "fresh"
      show_city
      printf "  ${G}${B}PASS${R} ${D}— secret-scan re-checked the fixed wave: clean. Bifröst open.${R}\n"
    else
      # The fixed wave should clear; if the local scanner still objects, do NOT
      # fake a pass — surface the real verdict.
      printf "\n  ${W}⚠${R} ${B}secret-scan still flags the fixed wave${R} ${D}(exit %s):${R}\n" "$refix_rc"
      printf '%s\n' "$scan_out" | sed 's/^/    /'
    fi
  fi

  # ── The run summary card (real data: STATE.md + the gate report we wrote) ──
  printf "\n  ${V}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${R}\n"
  printf "  ${C}${B}RUN COMPLETE${R} ${D}— the receipts${R}\n"
  printf "  ${V}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${R}\n"
  if [ -x "$CARD_BIN" ]; then
    "$CARD_BIN" "$city_dir" 2>/dev/null || true
  fi
  printf "\n  ${B}The catch:${R} ${D}one wave shipped a credential; secret-scan barred it,${R}\n"
  printf "  ${D}the fix wave loaded it from the environment, the gate re-passed.${R}\n"
  printf "  ${D}That deny → fix → pass is what a green-only demo can never show.${R}\n"

  # Settle the watchman (B3 end state).
  printf "\n"
  paint_face "idle" "fresh"
  printf "  ${C}▸${R} ${D}the watchman settles. ready for your build.${R}\n"

  # Clean up the throwaway stage — leaves nothing behind.
  rm -rf "$stage" 2>/dev/null || true
}

# Dispatch the narrated arc on first run, then fall through to the scaffold.
if should_narrate; then
  narrate_wakeup
  narrate_demo
  mark_first_run_done
  printf "\n  ${V}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${R}\n"
  printf "  ${B}That was the tour.${R} ${D}Now scaffold a real project to build for yourself:${R}\n"
  printf "  ${V}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${R}\n"
fi

# ── Banner ──

printf "\n"
printf "  ${P}${B}░▒▓█${R} ${C}${B}H E I M D A L L   D E M O${R} ${P}${B}█▓▒░${R}\n"
printf "  ${V}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${R}\n"
printf "  ${D}One command → watch heimdall build a real full-stack app.${R}\n"
printf "\n"

# ── Idempotency guard ──

if [ -e "$TARGET_DIR" ]; then
  if [ "$FORCE" != true ]; then
    printf "  ${W}⚠${R} Target already exists: ${B}%s${R}\n" "$TARGET_DIR"
    printf "  ${D}Re-run with ${C}--force${D} to overwrite, or pick another dir:${R}\n"
    printf "  ${C}heimdall-demo %s --force${R}\n\n" "$TARGET_DIR"
    exit 1
  fi
  printf "  ${W}⚠${R} Overwriting existing ${B}%s${R} ${D}(--force)${R}\n" "$TARGET_DIR"
  rm -rf "${TARGET_DIR:?}/$TASK_FILE" "${TARGET_DIR:?}/${PLAN_FILE}"
fi

# ── Scaffold dirs ──

mkdir -p "$TARGET_DIR/.planning"
ABS_DIR="$(cd "$TARGET_DIR" && pwd)"

# ── The canned task prompt ──
# Real, fully-specified, scoped to ~5 files, with runnable acceptance criteria.

cat > "$ABS_DIR/$TASK_FILE" <<'TASK'
# heimdall demo task — Todo REST API + single-page frontend

Build a small but complete full-stack **Todo** application in this directory. Keep
it to ~5 source files. Everything must run with zero cloud dependencies and an
empty database on first launch (in-memory or a local SQLite file is fine).

## Stack
- **Backend:** Python 3 + FastAPI + Uvicorn (single `app.py`). Use Pydantic models.
- **Storage:** in-memory store seeded empty; ids are monotonic integers.
- **Frontend:** ONE static `index.html` (vanilla JS + fetch, no build step) served
  by FastAPI at `GET /`. No framework, no bundler.
- **Tests:** `pytest` + FastAPI `TestClient` in `test_app.py`.
- **Docs:** `README.md` with run + test instructions.

## Files to create (target ~5)
1. `app.py`        — FastAPI app, models, routes, static index serving
2. `index.html`    — single-page UI: list, add, toggle-complete, delete
3. `test_app.py`   — endpoint tests covering the acceptance criteria below
4. `requirements.txt` — fastapi, uvicorn, pytest, httpx
5. `README.md`     — how to install, run, and test

## API contract (exactly these endpoints)
- `GET    /api/todos`            -> 200, JSON array of todos (empty `[]` at start)
- `POST   /api/todos`            -> 201, body `{"title": "buy milk"}` -> returns the
                                    created todo `{"id":1,"title":"buy milk","done":false}`.
                                    Empty/whitespace title -> 422.
- `PATCH  /api/todos/{id}`       -> 200, body `{"done": true}` toggles completion.
                                    Unknown id -> 404.
- `DELETE /api/todos/{id}`       -> 204, no body. Unknown id -> 404.
- `GET    /`                     -> 200, serves `index.html` (Content-Type text/html).

## Frontend behaviour
- On load, fetch `GET /api/todos` and render the list.
- An input + "Add" button POSTs a new todo and re-renders.
- Each row has a checkbox (PATCH done) and a delete button (DELETE).
- No inline secrets, no external CDNs — fully self-contained.

## Acceptance criteria (must all pass — these are runnable)
1. `pip install -r requirements.txt` succeeds.
2. `pytest -q` -> all tests pass, exit 0. Tests MUST cover:
   - empty list returns `[]`
   - create returns 201 with `done:false` and an incrementing id
   - empty title returns 422
   - PATCH toggles `done` and persists across a subsequent GET
   - DELETE returns 204 and the item is gone from the list
   - PATCH/DELETE on unknown id returns 404
3. `uvicorn app:app` boots without error and `GET /` returns the HTML page.
4. `curl -s localhost:8000/api/todos` returns valid JSON.
5. README documents the exact install/run/test commands above.
6. Every endpoint must be fully implemented — no unfinished markers, no fake data.

## Out of scope (do NOT add)
- Auth, user accounts, pagination, a real database server, Docker, CI config,
  or any JS build tooling. Keep it to the ~5 files above.
TASK

# ── The plan seed ──

cat > "$ABS_DIR/$PLAN_FILE" <<'PLAN'
# Plan seed — heimdall demo (Todo full-stack)

This is a ready-to-execute plan for the task in `.heimdall-demo-task.md`.
heimdall will refine and parallelize it; it exists so the demo starts with momentum.

## Waves
### Wave 1 — backend core (parallel-safe)
- [ ] `app.py`: FastAPI app, Pydantic `Todo`/`TodoIn` models, in-memory store,
      the five routes per the API contract, static `index.html` at `GET /`.
- [ ] `requirements.txt`: fastapi, uvicorn, pytest, httpx.

### Wave 2 — frontend + tests (parallel-safe, depend on Wave 1 contract)
- [ ] `index.html`: vanilla-JS SPA (list / add / toggle / delete via fetch).
- [ ] `test_app.py`: pytest + TestClient covering every acceptance criterion.

### Wave 3 — docs + verify (sequential)
- [ ] `README.md`: install / run / test instructions.
- [ ] Run `pytest -q` -> green. Boot `uvicorn app:app` -> `GET /` serves HTML.

## Definition of done
All six acceptance criteria in `.heimdall-demo-task.md` pass with quoted evidence.
PLAN

# ── Output ──

printf "  ${G}✔${R} Scaffolded demo project\n"
printf "    ${D}dir   ${R}${C}%s${R}\n" "$ABS_DIR"
printf "    ${D}task  ${R}%s\n" "$TASK_FILE"
printf "    ${D}plan  ${R}%s\n" "$PLAN_FILE"
printf "\n"
printf "  ${V}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${R}\n"
printf "  ${B}The task heimdall will build:${R}\n"
printf "  ${D}A Todo REST API (FastAPI) + single-page frontend + pytest + README.${R}\n"
printf "  ${D}Five real endpoints, runnable acceptance criteria, ~5 files.${R}\n"
printf "  ${V}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${R}\n"
printf "\n"

# The exact prompt to hand heimdall — points it at the scaffolded task file.
DEMO_PROMPT="Build the full-stack app specified in .heimdall-demo-task.md, following the plan seed in .planning/PLAN.md. All acceptance criteria must pass with runnable evidence."

# ── End-of-run wow: summary card + reel + the suggested next prompt. ──
# Shared by --run (real) so a completed build always lands on the H-5 endframe
# and the second-prompt conversion. Pure shell, never fails the run.
print_endframe() {
  printf "\n"
  printf "  ${V}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${R}\n"
  printf "  ${C}${B}RUN COMPLETE${R} ${D}— the receipts${R}\n"
  printf "  ${V}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${R}\n"

  # 1) The H-5 summary card (degrades to "—" on missing data, never crashes).
  if [ -x "$CARD_BIN" ]; then
    "$CARD_BIN" "$ABS_DIR" || true
  fi

  # 2) The reel — one shareable artifact (graceful-degrade to a .txt endframe).
  if [ "$NO_REEL" != true ] && [ -x "$REEL_BIN" ]; then
    printf "\n  ${P}▸${R} ${B}Reel${R} ${D}— rendering the shareable endframe…${R}\n"
    "$REEL_BIN" endframe "$ABS_DIR" --name heimdall-demo >/dev/null 2>&1 || true
    if [ -d "$ABS_DIR/.planning/reels" ]; then
      printf "  ${G}✔${R} reel artifacts in ${C}%s/.planning/reels/${R}\n" "$ABS_DIR"
    fi
  fi

  # 3) The localhost URL (the demo task serves the app at :8000 via uvicorn).
  printf "\n  ${B}Run the app you just built:${R}\n"
  printf "  ${C}cd %s && uvicorn app:app${R}  ${D}→${R}  ${UL}http://localhost:8000${R}\n" "$ABS_DIR"

  # 4) The atomic commits heimdall made (R7: one commit per task).
  if git -C "$ABS_DIR" rev-parse --git-dir >/dev/null 2>&1; then
    printf "\n  ${B}Atomic commits:${R}\n"
    git -C "$ABS_DIR" log --oneline -8 2>/dev/null | while IFS= read -r ln; do
      printf "    ${D}%s${R}\n" "$ln"
    done
  fi

  # 5) The second-prompt conversion — one concrete follow-up.
  printf "\n  ${V}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${R}\n"
  printf "  ${B}Try one more — exercise the verification layer:${R}\n"
  printf "  ${C}cd %s && heimdall \"%s\"${R}\n" "$ABS_DIR" "$FOLLOWUP_PROMPT"
  printf "  ${V}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${R}\n\n"
}

if [ "$MODE" = "run" ]; then
  if ! command -v heimdall &>/dev/null; then
    printf "  ${W}⚠${R} ${B}heimdall${R} not found on PATH — cannot auto-run.\n"
    printf "  ${D}Install it, then paste the command below. Falling back to dry output.${R}\n\n"
    MODE="dry"
  else
    printf "  ${P}▸${R} ${B}Launching heimdall${R} ${D}(--run)${R}\n"
    printf "  ${D}cd %s && heimdall \"%s\"${R}\n\n" "$ABS_DIR" "$DEMO_PROMPT"
    cd "$ABS_DIR"
    # Record a reel WHILE heimdall builds when the recorder + reel bin exist;
    # otherwise run heimdall directly. Either way we return and render the
    # endframe (summary card + reel + follow-up) — we do NOT exec/replace.
    if [ "$NO_REEL" != true ] && [ -x "$REEL_BIN" ] && command -v asciinema &>/dev/null; then
      "$REEL_BIN" record "$ABS_DIR" --name heimdall-demo -- heimdall "$DEMO_PROMPT" || true
    else
      heimdall "$DEMO_PROMPT" || true
    fi
    print_endframe
    exit 0
  fi
fi

# Dry mode (default & fallback): print the paste-ready next step, execute nothing.
printf "  ${B}Next step${R} ${D}— paste this to watch heimdall build it:${R}\n"
printf "\n"
printf "  ${C}cd %s && heimdall \"%s\"${R}\n" "$ABS_DIR" "$DEMO_PROMPT"
printf "\n"
printf "  ${D}No ${C}heimdall${D} on PATH? Open Claude Code in that dir and say:${R}\n"
printf "  ${D}  \"%s\"${R}\n" "$DEMO_PROMPT"
printf "\n"
printf "  ${D}When the build finishes you'll get a summary card, a shareable reel,${R}\n"
printf "  ${D}and a suggested follow-up that exercises the verification layer:${R}\n"
printf "  ${D}  \"%s\"${R}\n" "$FOLLOWUP_PROMPT"
printf "\n"
printf "  ${W}▸${R} Safe by default — nothing was executed. Add ${C}--run${R} to launch automatically.\n"
printf "\n"
