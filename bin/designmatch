#!/usr/bin/env bash
# designmatch — match a Claude Design HTML canonical to a React Native app
# to ≥95% visual parity. CLI dispatcher for the designmatch skill.
#
# Subcommands:
#   init <canonical-source> [--app-dir <path>] [--target <rel>] [--force]
#                 — one-shot bootstrap. Copies visual-qa.ts into the RN
#                   app, writes default state.vqa.json, registers the
#                   canonical source (URL or local path), updates
#                   .gitignore, and prints the wiring snippet.
#   wire          — app-side only (skip canonical setup). Same as init
#                   without the canonical source arg.
#   render <src> --out <png> [--state <json>] [--screen <name>] [--wait <ms|sel>]
#                 — Playwright canonical render at 1080x2444.
#   diff <canonical.png> <native.png> --out-dir <dir> [--threshold <n>]
#                 — pixelmatch + SSIM + composite triptych.
#   iterate <ScreenName> [--platform android|ios] [--device <id>]
#                 — per-screen loop: render + capture + diff + open.
#   action-types  — print sample ACTION_TYPES map for visual-qa.ts.
#   help          — this text.
#
# canonical-source forms:
#   - https://... URL (e.g. Claude Design link) → registered for lazy fetch
#   - /path/to/dir → copied wholesale into .designmatch/canonical/
#   - /path/to/file.html → copied as the canonical entry

set -euo pipefail

SELF="$0"
if command -v readlink &>/dev/null; then
  SELF=$(readlink -f "$0" 2>/dev/null || readlink "$0" 2>/dev/null || echo "$0")
fi
PLUGIN_DIR="$(cd "$(dirname "$SELF")/.." && pwd)"
SKILL_DIR="$PLUGIN_DIR/skills/designmatch"
ASSET_VQA="$SKILL_DIR/assets/visual-qa.ts"
SCRIPT_RENDER="$SKILL_DIR/scripts/render-canonical.js"
SCRIPT_DIFF="$SKILL_DIR/scripts/visual-diff.js"
SCRIPT_ITERATE="$SKILL_DIR/scripts/iterate-screen.sh"
SCRIPT_FETCH="$SKILL_DIR/scripts/fetch-canonical.js"

red()    { printf "\033[31m%s\033[0m" "$*"; }
green()  { printf "\033[32m%s\033[0m" "$*"; }
cyan()   { printf "\033[36m%s\033[0m" "$*"; }
dim()    { printf "\033[2m%s\033[0m" "$*"; }
die()    { echo "$(red "✗") $*" >&2; exit 1; }
ok()     { echo "$(green "✓") $*"; }
info()   { echo "$(cyan "▸") $*"; }

usage() {
  cat <<EOF
designmatch — match Claude Design HTML canonical to React Native at ≥95% visual parity.

Usage:
  designmatch init <canonical-source> [--app-dir <path>] [--target <rel>] [--force]
                                      [--no-fetch] [--port-all] [--headed]
  designmatch wire [--app-dir <path>] [--target <rel>] [--force]
  designmatch fetch [--app-dir <path>] [--force] [--headed]
  designmatch port <ScreenName> [--app-dir <path>] [--out <path>] [--guide-only] [--no-guide]
  designmatch port-all [--app-dir <path>] [--out-dir src/screens] [--force] [--no-guide]
  designmatch render <src> --out <png> [--state <json>] [--screen <n>] [--wait <ms|sel>]
  designmatch diff <canonical.png> <native.png> --out-dir <dir> [--threshold <n>]
  designmatch iterate <ScreenName> [--platform android|ios] [--device <id>]
  designmatch action-types
  designmatch help

Quick start — URL in, ready-to-translate out:
  designmatch init "https://api.anthropic.com/v1/design/h/HASH?open_file=App.html" \\
    --app-dir ./ --port-all
  # → 1) copies visual-qa.ts + state.vqa.json + .gitignore
  # → 2) Playwright-fetches the bundle to .designmatch/canonical/
  # → 3) ports every screen-*.jsx to src/screens/<Name>.tsx with TRANSLATION GUIDE
  # → 4) prints wiring snippet for App.tsx

  # Then translate each src/screens/<Name>.tsx top-down per the GUIDE and:
  designmatch iterate Home --platform android --device emulator-5554

Auth: if the canonical URL is behind login, add --headed to launch a
visible Chromium for interactive auth (fetch picks up after sign-in).
EOF
}

# Default Visual-QA seed (matches skills/designmatch SPEC).
default_state_json() {
  cat <<'JSON'
{
  "user": {
    "kycStatus": "verified",
    "phone_verified": true,
    "iso": "GBR",
    "name": "Visual QA"
  },
  "recipient": {
    "id": "vqa-r1",
    "name": "Test Recipient",
    "country": "IND",
    "phone": "+919999900000"
  },
  "bonus": {
    "balance": 1000,
    "ledger": [],
    "applyCapPct": 50
  },
  "transfer": {
    "sendingCountry": "GBR",
    "receivingCountry": "IND"
  }
}
JSON
}

# Resolve a sensible target path for visual-qa.ts inside an RN app.
resolve_target() {
  local app_dir="$1"
  if [ -d "$app_dir/src/lib" ];      then echo "src/lib/visual-qa.ts"
  elif [ -d "$app_dir/src/utils" ];  then echo "src/utils/visual-qa.ts"
  elif [ -d "$app_dir/src" ];        then echo "src/visual-qa.ts"
  elif [ -d "$app_dir/app" ];        then echo "app/visual-qa.ts"
  else                                    echo "visual-qa.ts"
  fi
}

# Validate RN project root (must have package.json with react-native dep).
validate_rn_app() {
  local app_dir="$1"
  [ -f "$app_dir/package.json" ] || die "no package.json in $app_dir — pass --app-dir <rn-project-root>"
  if ! grep -q '"react-native"' "$app_dir/package.json"; then
    echo "$(red "!") react-native not declared in $app_dir/package.json — proceeding anyway" >&2
  fi
}

# Copy visual-qa.ts into the app and write state.vqa.json. Shared by init + wire.
do_app_side() {
  local app_dir="$1" target_rel="$2" force="$3"
  local target_abs="$app_dir/$target_rel"

  if [ -e "$target_abs" ] && [ "$force" -eq 0 ]; then
    die "exists: $target_abs (use --force to overwrite)"
  fi

  mkdir -p "$(dirname "$target_abs")"
  cp "$ASSET_VQA" "$target_abs"
  ok "wrote $target_rel"

  mkdir -p "$app_dir/.designmatch/canonical" "$app_dir/.designmatch/screens"
  if [ ! -f "$app_dir/.designmatch/state.vqa.json" ] || [ "$force" -eq 1 ]; then
    default_state_json > "$app_dir/.designmatch/state.vqa.json"
    ok "wrote .designmatch/state.vqa.json"
  else
    info "kept existing .designmatch/state.vqa.json (use --force to overwrite)"
  fi

  # Update .gitignore (idempotent).
  local gi="$app_dir/.gitignore"
  if [ ! -f "$gi" ] || ! grep -q '^\.designmatch/canonical' "$gi"; then
    {
      [ -f "$gi" ] && tail -c1 "$gi" | read -r _ || true
      echo ""
      echo "# designmatch — canonical bundle + per-screen captures (regenerated)"
      echo ".designmatch/canonical/"
      echo ".designmatch/screens/"
    } >> "$gi"
    ok "updated .gitignore"
  fi
}

# Register canonical source (URL or local path) in .designmatch/config.json.
register_canonical() {
  local app_dir="$1" source="$2"
  local kind=""
  local stored=""
  local ts; ts=$(date -u +"%Y-%m-%dT%H:%M:%SZ")

  if [[ "$source" =~ ^https?:// ]]; then
    kind="url"
    stored="$source"
    ok "registered canonical URL"
    info "fetched lazily by Playwright at render time"
  elif [ -d "$source" ]; then
    kind="local-dir"
    cp -R "$source"/* "$app_dir/.designmatch/canonical/" 2>/dev/null || true
    stored=".designmatch/canonical"
    ok "copied canonical bundle from $source"
  elif [ -f "$source" ]; then
    kind="local-file"
    local html_name; html_name=$(basename "$source")
    cp "$source" "$app_dir/.designmatch/canonical/$html_name"
    # Also copy sibling files if it's part of a bundle (best-effort).
    local src_dir; src_dir=$(dirname "$source")
    for ext in jsx js css png svg; do
      cp "$src_dir"/*."$ext" "$app_dir/.designmatch/canonical/" 2>/dev/null || true
    done
    stored=".designmatch/canonical/$html_name"
    ok "copied canonical HTML: $html_name"
  else
    die "canonical-source not found: $source"
  fi

  cat > "$app_dir/.designmatch/config.json" <<JSON
{
  "canonical_source": "$stored",
  "kind": "$kind",
  "registered_at": "$ts",
  "viewport": { "width": 1080, "height": 2444, "deviceScaleFactor": 1 }
}
JSON
}

print_wiring() {
  local target_rel="$1"
  local import_path
  import_path=$(printf '%s' "$target_rel" | sed 's|\.ts$||; s|^src/|./src/|')
  cat <<EOF

──────────── WIRING ────────────
Add to your App.tsx (or root component):

  import {
    primeVisualQaFlag, applyVisualQaState, overrideFeatureFlags,
    useVqaLongPressDetector, toggleVqaAndRestart, VqaBadge,
  } from '$import_path';
  import RNRestart from 'react-native-restart';

  // At boot, before createStore:
  await primeVisualQaFlag();
  const store = createStore(...);
  applyVisualQaState(store.dispatch);
  const isFeatureEnabled = overrideFeatureFlags(originalIsFeatureEnabled);

  // In AppLogo component:
  const { onPress } = useVqaLongPressDetector(() => toggleVqaAndRestart(RNRestart));
  <Pressable onPress={onPress}>...</Pressable>

  // In root layout (inside SafeAreaProvider):
  <VqaBadge />

──────────── NEXT ────────────
1. Edit $target_rel → set ACTION_TYPES to match your reducers
   (run \`designmatch action-types\` for a starter)
2. Install peer deps if missing:
   npm i @react-native-async-storage/async-storage react-native-restart
3. Iterate a screen:
   designmatch iterate <ScreenName> --platform android --device <id>
EOF
}

cmd_init() {
  [ $# -gt 0 ] || die "init requires <canonical-source>. Run \`designmatch help\`."
  local source="$1"; shift

  local app_dir="$PWD"
  local target=""
  local force=0
  local no_fetch=0
  local port_all=0
  local headed=0
  while [ $# -gt 0 ]; do
    case "$1" in
      --app-dir)  app_dir="$2"; shift 2 ;;
      --target)   target="$2"; shift 2 ;;
      --force)    force=1; shift ;;
      --no-fetch) no_fetch=1; shift ;;
      --port-all) port_all=1; shift ;;
      --headed)   headed=1; shift ;;
      *) die "unknown flag: $1" ;;
    esac
  done

  app_dir="$(cd "$app_dir" && pwd)"
  validate_rn_app "$app_dir"
  [ -z "$target" ] && target=$(resolve_target "$app_dir")

  do_app_side "$app_dir" "$target" "$force"
  register_canonical "$app_dir" "$source"

  # Auto-fetch URL canonicals unless --no-fetch.
  local cfg="$app_dir/.designmatch/config.json"
  local kind_now
  kind_now=$(python3 -c "import json; print(json.load(open('$cfg')).get('kind',''))" 2>/dev/null || echo "")
  if [ "$kind_now" = "url" ] && [ "$no_fetch" -eq 0 ]; then
    local fetch_args=(--app-dir "$app_dir")
    [ "$headed" -eq 1 ] && fetch_args+=(--headed)
    cmd_fetch "${fetch_args[@]}" || die "fetch failed — pass --no-fetch to skip, or --headed for interactive auth"
  fi

  # Auto-port every screen if --port-all.
  if [ "$port_all" -eq 1 ]; then
    local pa_args=(--app-dir "$app_dir")
    [ "$force" -eq 1 ] && pa_args+=(--force)
    cmd_port_all "${pa_args[@]}"
  fi

  print_wiring "$target"
}

cmd_wire() {
  local app_dir="$PWD"
  local target=""
  local force=0
  while [ $# -gt 0 ]; do
    case "$1" in
      --app-dir) app_dir="$2"; shift 2 ;;
      --target)  target="$2"; shift 2 ;;
      --force)   force=1; shift ;;
      *) die "unknown flag: $1" ;;
    esac
  done

  app_dir="$(cd "$app_dir" && pwd)"
  validate_rn_app "$app_dir"
  [ -z "$target" ] && target=$(resolve_target "$app_dir")

  do_app_side "$app_dir" "$target" "$force"
  print_wiring "$target"
}

cmd_render() {
  command -v node >/dev/null || die "node required for render"
  [ -f "$SCRIPT_RENDER" ] || die "missing $SCRIPT_RENDER"
  exec node "$SCRIPT_RENDER" "$@"
}

cmd_diff() {
  command -v node >/dev/null || die "node required for diff"
  [ -f "$SCRIPT_DIFF" ] || die "missing $SCRIPT_DIFF"
  exec node "$SCRIPT_DIFF" "$@"
}

cmd_iterate() {
  [ -f "$SCRIPT_ITERATE" ] || die "missing $SCRIPT_ITERATE"
  exec bash "$SCRIPT_ITERATE" "$@"
}

cmd_action_types() {
  cat <<'TS'
// Sample ACTION_TYPES — paste into visual-qa.ts and edit to match your reducers.
// The names on the right are action `type` strings your reducers handle.
export const ACTION_TYPES = {
  USER_SET:                 'user/set',
  RECIPIENT_ADD:            'recipient/add',
  RECIPIENT_SELECT:         'recipient/setSelected',
  BONUS_SET:                'bonus/set',
  TRANSFER_SET_COUNTRIES:   'transfer/setCountries',
} as const;
TS
}

cmd_fetch() {
  local app_dir="$PWD"
  local headed=0
  local force=0
  while [ $# -gt 0 ]; do
    case "$1" in
      --app-dir) app_dir="$2"; shift 2 ;;
      --headed)  headed=1; shift ;;
      --force)   force=1; shift ;;
      *) die "unknown flag: $1" ;;
    esac
  done

  app_dir="$(cd "$app_dir" && pwd)"
  local cfg="$app_dir/.designmatch/config.json"
  [ -f "$cfg" ] || die "no .designmatch/config.json — run \`designmatch init <url>\` first"

  command -v node >/dev/null || die "node required for fetch"
  command -v python3 >/dev/null || die "python3 required for config IO"
  [ -f "$SCRIPT_FETCH" ] || die "missing $SCRIPT_FETCH"

  local kind url
  kind=$(python3 -c "import json; print(json.load(open('$cfg')).get('kind',''))" 2>/dev/null || echo "")
  url=$(python3 -c "import json; print(json.load(open('$cfg')).get('canonical_source',''))" 2>/dev/null || echo "")

  if [ "$kind" != "url" ]; then
    if [ "$force" -eq 0 ]; then
      info "canonical already local (kind=$kind) — pass --force to re-fetch"
      return 0
    fi
    url=$(python3 -c "import json; print(json.load(open('$cfg')).get('original_url',''))" 2>/dev/null || echo "")
    [ -n "$url" ] || die "cannot re-fetch: no original_url stored in config"
  fi

  local out_dir="$app_dir/.designmatch/canonical"
  mkdir -p "$out_dir"

  local fetch_args=(--url "$url" --out-dir "$out_dir")
  [ "$headed" -eq 1 ] && fetch_args+=(--headed)

  info "fetching canonical bundle (Playwright)"
  node "$SCRIPT_FETCH" "${fetch_args[@]}" >/dev/null \
    || die "fetch failed — try \`designmatch fetch --headed\` for interactive auth, or save the bundle manually and re-init with the local path"

  # Promote config: url → local-dir, preserve original URL for re-fetch.
  local ts; ts=$(date -u +"%Y-%m-%dT%H:%M:%SZ")
  python3 - "$cfg" "$ts" <<'PY'
import json, sys
p, ts = sys.argv[1], sys.argv[2]
c = json.load(open(p))
if not c.get("original_url"):
    c["original_url"] = c.get("canonical_source", "")
c["canonical_source"] = ".designmatch/canonical"
c["kind"] = "local-dir"
c["fetched_at"] = ts
json.dump(c, open(p, "w"), indent=2)
PY

  ok "fetched canonical → .designmatch/canonical/ (kind: url → local-dir)"
}

cmd_port_all() {
  local app_dir="$PWD"
  local out_dir="src/screens"
  local force=0
  local no_guide=0
  while [ $# -gt 0 ]; do
    case "$1" in
      --app-dir)  app_dir="$2"; shift 2 ;;
      --out-dir)  out_dir="$2"; shift 2 ;;
      --force)    force=1; shift ;;
      --no-guide) no_guide=1; shift ;;
      *) die "unknown flag: $1" ;;
    esac
  done

  app_dir="$(cd "$app_dir" && pwd)"
  local cfg="$app_dir/.designmatch/config.json"
  [ -f "$cfg" ] || die "no .designmatch/config.json — run \`designmatch init <url>\` first"

  command -v python3 >/dev/null || die "python3 required"
  local kind canonical_source
  kind=$(python3 -c "import json; print(json.load(open('$cfg')).get('kind',''))" 2>/dev/null || echo "")
  canonical_source=$(python3 -c "import json; print(json.load(open('$cfg')).get('canonical_source',''))" 2>/dev/null || echo "")

  if [ "$kind" = "url" ]; then
    info "canonical is URL — auto-fetching first"
    cmd_fetch --app-dir "$app_dir" || die "auto-fetch failed"
    kind=$(python3 -c "import json; print(json.load(open('$cfg')).get('kind',''))" 2>/dev/null || echo "")
    canonical_source=$(python3 -c "import json; print(json.load(open('$cfg')).get('canonical_source',''))" 2>/dev/null || echo "")
  fi

  local canonical_dir=""
  case "$kind" in
    local-dir)  canonical_dir="$app_dir/$canonical_source" ;;
    local-file) canonical_dir="$(dirname "$app_dir/$canonical_source")" ;;
    *) die "cannot port-all: unknown kind \"$kind\"" ;;
  esac
  [ -d "$canonical_dir" ] || die "canonical dir not found: $canonical_dir"

  local out_abs="$app_dir/$out_dir"
  mkdir -p "$out_abs"

  local files
  files=$(find "$canonical_dir" -maxdepth 4 -type f \
    \( -iname 'screen-*.jsx' -o -iname 'screen-*.tsx' \
       -o -iname '*Screen.jsx' -o -iname '*Screen.tsx' \) 2>/dev/null)

  [ -n "$files" ] || die "no screen sources found under $canonical_dir (looked for screen-*.{jsx,tsx} and *Screen.{jsx,tsx})"

  local count=0 skipped=0 failed=0
  while IFS= read -r src; do
    [ -n "$src" ] || continue
    local base name target
    base=$(basename "$src")
    name="${base%.*}"          # strip ext
    name="${name#screen-}"     # strip leading screen-
    name="${name%Screen}"      # strip trailing Screen
    name="$(printf '%s' "${name:0:1}" | tr '[:lower:]' '[:upper:]')${name:1}"

    target="$out_abs/$name.tsx"
    if [ -e "$target" ] && [ "$force" -eq 0 ]; then
      info "skip $name (exists; use --force to overwrite)"
      skipped=$((skipped + 1))
      continue
    fi

    local port_args=("$name" --app-dir "$app_dir" --out "$target")
    [ "$no_guide" -eq 1 ] && port_args+=(--no-guide)
    if ( cmd_port "${port_args[@]}" ) >/dev/null 2>&1; then
      ok "ported $base → ${target#$app_dir/}"
      count=$((count + 1))
    else
      info "fail $name (port error)"
      failed=$((failed + 1))
    fi
  done <<< "$files"

  echo ""
  ok "port-all: $count ported, $skipped skipped, $failed failed → $out_dir/"
  info "next: translate each $out_dir/*.tsx top-down per TRANSLATION GUIDE, then \`designmatch iterate <Screen>\`"
}

# Web JSX → React Native translation guide. Prepended to ported source so
# the translation step has the idiom map inline.
print_translation_guide() {
  cat <<'GUIDE'
// ════════════════════════════════════════════════════════════════════
// designmatch TRANSLATION GUIDE — web JSX → React Native
// ════════════════════════════════════════════════════════════════════
// Methodology: port the source, do NOT eyeball pixels. PNG is the
// verification gate; the JSX below is the spec. Translate top-down,
// then `designmatch iterate <Screen>` to verify with the diff harness.
//
// IDIOM MAP
//
//   Element / attribute (web)    →  React Native
//   ──────────────────────────────────────────────
//   <div>                        →  <View>
//   <span> <p> <h1>..<h6>        →  <Text>
//   <img src=>                   →  <Image source={{ uri }} />
//   <button onClick=>            →  <Pressable onPress=>
//   <a href=>                    →  <Pressable onPress={() => Linking.openURL()}>
//   <input>                      →  <TextInput>
//   <svg>...</svg>               →  react-native-svg primitives
//
//   className="..."              →  style={s.<name>} via StyleSheet.create
//   Tailwind classes             →  resolve each class to RN style props
//   style={{ padding: 16 }}      →  style={{ padding: normalize(16) }}
//   px values                    →  normalize(n) — always-on
//
//   display: flex                →  default; RN root is column!
//   flex-row                     →  flexDirection: 'row'
//   justify-content              →  justifyContent
//   align-items                  →  alignItems
//   gap: N                       →  gap: normalize(N)  (RN ≥ 0.71)
//
//   font-weight: 600/700/800     →  Platform.OS === 'android'
//                                     ? { fontFamily: 'Family-Bold' }
//                                     : { fontWeight: '600' }
//                                   (see anti-pattern #2)
//   font-family                  →  fontFamily: '<RN-registered-name>'
//
//   onClick / onChange           →  onPress / onChangeText (TextInput)
//   onMouseEnter / hover         →  no equivalent — drop or use Pressable
//   onScroll                     →  onScroll on ScrollView/FlatList
//
//   position: absolute           →  same
//   z-index                      →  zIndex + elevation (Android)
//
//   useState / useEffect         →  unchanged (React-shared)
//   document / window            →  remove or replace with RN APIs
//   localStorage                 →  AsyncStorage
//
// STRUCTURAL RULES (from designmatch SKILL.md, must hold):
//   • Wrap all px values in normalize() — no literal px in StyleSheet.
//   • <Text> default font is body — headings MUST specify display family.
//   • Single safe-area: Screen wrapper OR inner container, never both.
//   • Header: native stack header OR in-screen PushHeader, never both.
//
// PROCESS:
//   1. Read the canonical source below verbatim.
//   2. Translate top-down. Keep variable names + structure identical.
//   3. Replace web idioms with RN per the map above.
//   4. Save to your screen file, then:
//        designmatch iterate <ScreenName> --platform android --device <id>
//   5. PNG diff is the verification gate. Refine until SSIM ≥ 0.95
//      OR pixel-diff ≤ 5%.
//
// ════════════════════════════════════════════════════════════════════
GUIDE
}

cmd_port() {
  local screen=""
  local app_dir="$PWD"
  local out=""
  local guide_only=0
  local no_guide=0
  while [ $# -gt 0 ]; do
    case "$1" in
      --app-dir)    app_dir="$2"; shift 2 ;;
      --out)        out="$2"; shift 2 ;;
      --guide-only) guide_only=1; shift ;;
      --no-guide)   no_guide=1; shift ;;
      -*) die "unknown flag: $1" ;;
      *)  [ -z "$screen" ] && { screen="$1"; shift; } || die "unexpected arg: $1" ;;
    esac
  done

  if [ "$guide_only" -eq 1 ]; then
    print_translation_guide
    exit 0
  fi

  [ -n "$screen" ] || die "port requires <ScreenName>. Run \`designmatch help\`."

  app_dir="$(cd "$app_dir" && pwd)"
  local cfg="$app_dir/.designmatch/config.json"
  [ -f "$cfg" ] || die "no .designmatch/config.json — run \`designmatch init\` first"

  command -v python3 >/dev/null || die "python3 required to read config.json"
  local kind canonical_source
  kind=$(python3 -c "import json,sys; print(json.load(open('$cfg')).get('kind',''))" 2>/dev/null || echo "")
  canonical_source=$(python3 -c "import json,sys; print(json.load(open('$cfg')).get('canonical_source',''))" 2>/dev/null || echo "")

  # Auto-fetch URL canonicals transparently — port should "just work" on URLs.
  if [ "$kind" = "url" ]; then
    info "canonical is URL — auto-fetching first"
    cmd_fetch --app-dir "$app_dir" || die "auto-fetch failed — try \`designmatch fetch --headed\` for interactive auth"
    kind=$(python3 -c "import json; print(json.load(open('$cfg')).get('kind',''))" 2>/dev/null || echo "")
    canonical_source=$(python3 -c "import json; print(json.load(open('$cfg')).get('canonical_source',''))" 2>/dev/null || echo "")
  fi

  local canonical_dir=""
  case "$kind" in
    local-dir)
      canonical_dir="$app_dir/$canonical_source" ;;
    local-file)
      canonical_dir="$(dirname "$app_dir/$canonical_source")" ;;
    url)
      die "fetch did not complete (kind still url) — check fetch output above" ;;
    *)
      die "unknown canonical kind: \"$kind\" in $cfg" ;;
  esac

  [ -d "$canonical_dir" ] || die "canonical dir not found: $canonical_dir"

  # Resolve source file — try common patterns first, then case-insensitive find.
  local found=""
  for pat in \
    "screen-${screen}.jsx" "screen-${screen}.tsx" \
    "${screen}Screen.jsx" "${screen}Screen.tsx" \
    "${screen}.jsx" "${screen}.tsx" \
    "Screen${screen}.jsx" "Screen${screen}.tsx"; do
    if [ -f "$canonical_dir/$pat" ]; then found="$canonical_dir/$pat"; break; fi
  done
  if [ -z "$found" ]; then
    found=$(find "$canonical_dir" -maxdepth 4 -type f \( -iname "*${screen}*.jsx" -o -iname "*${screen}*.tsx" -o -iname "*${screen}*.js" \) 2>/dev/null | head -1)
  fi
  [ -n "$found" ] && [ -f "$found" ] || die "no source matching screen \"$screen\" under $canonical_dir"

  emit_port() {
    [ "$no_guide" -eq 0 ] && print_translation_guide
    echo ""
    echo "// ─── canonical source: $(basename "$found") ───"
    cat "$found"
  }

  if [ -n "$out" ]; then
    mkdir -p "$(dirname "$out")"
    emit_port > "$out"
    ok "ported $(basename "$found") → $out"
    info "next: translate idioms per guide, then \`designmatch iterate $screen\` to verify"
  else
    emit_port
  fi
}

main() {
  local cmd="${1:-help}"
  [ $# -gt 0 ] && shift || true
  case "$cmd" in
    init)          cmd_init "$@" ;;
    wire)          cmd_wire "$@" ;;
    fetch)         cmd_fetch "$@" ;;
    port)          cmd_port "$@" ;;
    port-all)      cmd_port_all "$@" ;;
    render)        cmd_render "$@" ;;
    diff)          cmd_diff "$@" ;;
    iterate)       cmd_iterate "$@" ;;
    action-types)  cmd_action_types ;;
    help|-h|--help) usage ;;
    *) echo "unknown command: $cmd" >&2; usage; exit 1 ;;
  esac
}

main "$@"
