#!/usr/bin/env bash
# heimdall-watch — run sentinels on HUMAN commits (spec H-3 watch mode).
#
# The retention feature: sentinels run not only during a full Heimdall build but
# on the human's own commits, so Heimdall stays useful between big runs. This is
# passive daily value — a human commits, the watch fires the relevant sentinels
# against that commit (clean-checkout sanity + secret scan + doc-sync), and each
# writes its standard report.json. The verdicts are surfaced; nothing blocks the
# human's local commit (watch is advisory-by-default; wire it as a pre-push hook
# to make security blocking).
#
# Two modes:
#   once   — run the watch sentinels against a target commit (default HEAD) ONCE.
#            This is what a git post-commit / post-merge hook calls.
#   poll   — watch the repo HEAD; whenever it changes (a new human commit lands),
#            run the watch sentinels against the new HEAD. Ctrl-C to stop.
#
# Which sentinels run on a human commit (the passive set):
#   - sanity     (clean-checkout build+test of the new commit)
#   - security   (secret scan over the new commit range)
#   - doc-sync   (doc drift introduced by the commit)
# Bloat and spec-drift are wave-scoped (need criteria/spec refs) and are NOT run
# blind on arbitrary human commits — running them without their refs would only
# ever honest-skip, which is noise. They run via heimdall-spawn during builds.
#
# Each sentinel is dispatched through heimdall-spawn so the SAME lane cap +
# budget + report collection applies. A synthesized background spawn json is
# written per run under .planning/spawns/watch/.
#
# Usage:
#   heimdall-watch once [--repo <root>] [--ref <commit>]
#   heimdall-watch poll [--repo <root>] [--interval <seconds>]
#   -h | --help
#
# Exit codes (once): 0 = all watch sentinels pass/skip; 1 = a sentinel failed;
#   2 = usage/IO error. (poll runs until interrupted.)
set -euo pipefail

SELF="$0"
if command -v readlink >/dev/null 2>&1; then
  SELF="$(readlink -f "$0" 2>/dev/null || readlink "$0" 2>/dev/null || echo "$0")"
fi
BIN_DIR="$(cd "$(dirname "$SELF")" && pwd)"
ROOT_DEFAULT="$(cd "$BIN_DIR/.." && pwd)"
SPAWN="$BIN_DIR/heimdall-spawn"

command -v jq >/dev/null 2>&1 || { echo "error: jq is required" >&2; exit 2; }
[ -x "$SPAWN" ] || [ -f "$SPAWN" ] || { echo "error: heimdall-spawn not found at $SPAWN" >&2; exit 2; }

usage() { sed -n '2,46p' "$SELF"; }

WATCH_KINDS=(sanity security doc_sync)

# Write a synthesized background spawn json for a watch sentinel against a
# commit range, then run it through heimdall-spawn. Echoes the resulting status.
_run_watch_sentinel() {
  local root="$1" kind="$2" ref="$3" range="$4"
  local dir="$root/.planning/spawns/watch"
  mkdir -p "$dir"
  local sid="watch-$kind-$(echo "$ref" | cut -c1-8)"
  local sj="$dir/$sid.json"

  # Minimal-context brief: refs only. diff_ref = the commit; range for security.
  jq -n \
    --arg haid "${HEIMDALL_HAID:-haid:local}" \
    --arg kind "$kind" \
    --arg diff "$range" \
    --arg ref "$ref" \
    --arg range "$range" \
    '{haid:$haid, kind:$kind, trigger:"watch",
      context:{diff_ref:$ref, range:$range},
      budget_tokens:15000, timeout_min:10, lane:"background"}' >"$sj"

  local rc=0
  bash "$SPAWN" run "$sj" --repo "$root" || rc=$?
  # rc: 0 pass/skip/partial/queued-handled, 1 fail, 2 io, 3 queued.
  echo "$rc"
}

# Run the full watch set against a commit. Returns 0 if none failed.
_watch_once() {
  local root="$1" ref="$2"
  local sha; sha="$(git -C "$root" rev-parse --verify "$ref" 2>/dev/null || true)"
  [ -n "$sha" ] || { echo "error: cannot resolve ref '$ref' in $root" >&2; return 2; }

  # Range = the single commit (parent..commit). Root commit -> the commit itself.
  local parent range
  parent="$(git -C "$root" rev-parse --verify "$sha^" 2>/dev/null || true)"
  if [ -n "$parent" ]; then range="$parent..$sha"; else range="$sha"; fi

  echo "── heimdall-watch: human commit $(echo "$sha" | cut -c1-8) ($range) ──"
  local any_fail=0 k rc
  for k in "${WATCH_KINDS[@]}"; do
    rc="$(_run_watch_sentinel "$root" "$k" "$sha" "$range" | tail -1)"
    [ "$rc" = "1" ] && any_fail=1
  done
  if [ "$any_fail" -eq 1 ]; then
    echo "heimdall-watch: at least one sentinel FAILED on $(echo "$sha" | cut -c1-8) — see reports under .planning/spawns/reports/" >&2
    return 1
  fi
  echo "heimdall-watch: all watch sentinels green/skipped on $(echo "$sha" | cut -c1-8)."
  return 0
}

# ── Arg parse ─────────────────────────────────────────────────────────
SUB="${1:-}"; shift || true
ROOT="$ROOT_DEFAULT"
REF="HEAD"
INTERVAL=5
while [ $# -gt 0 ]; do
  case "$1" in
    --repo)     ROOT="${2:?--repo needs a path}"; shift 2 ;;
    --ref)      REF="${2:?--ref needs a value}"; shift 2 ;;
    --interval) INTERVAL="${2:?--interval needs seconds}"; shift 2 ;;
    -h|--help)  usage; exit 0 ;;
    *) echo "error: unknown arg: $1" >&2; usage >&2; exit 2 ;;
  esac
done

git -C "$ROOT" rev-parse --git-dir >/dev/null 2>&1 || { echo "error: not a git repo: $ROOT" >&2; exit 2; }

case "$SUB" in
  once)
    _watch_once "$ROOT" "$REF"
    ;;
  poll)
    echo "heimdall-watch poll: watching $ROOT HEAD every ${INTERVAL}s (Ctrl-C to stop)"
    last="$(git -C "$ROOT" rev-parse HEAD 2>/dev/null || echo none)"
    # Run once for the current HEAD up front.
    _watch_once "$ROOT" "$last" || true
    while true; do
      sleep "$INTERVAL"
      cur="$(git -C "$ROOT" rev-parse HEAD 2>/dev/null || echo none)"
      if [ "$cur" != "$last" ] && [ "$cur" != "none" ]; then
        last="$cur"
        _watch_once "$ROOT" "$cur" || true
      fi
    done
    ;;
  -h|--help|"")
    usage; exit 0 ;;
  *)
    echo "error: unknown subcommand: $SUB" >&2; usage >&2; exit 2 ;;
esac
