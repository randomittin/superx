#!/usr/bin/env bash
# secret-scan — gitleaks secret-scanning gate over STAGED changes.
#
# Why this exists: a credential once landed in history during a near-miss
# (SECURITY-REMEDIATION.md Step 6.2). A one-time history scrub cleans the past;
# this gate prevents recurrence by scanning what is being COMMITTED — before it
# can ever enter history — not all dangling history. It complements the existing
# pre-push falsify/corpus gates as a commit-time guard.
#
# Scope: scans the STAGED diff only (the bytes about to become a commit), so it
# is fast and catches the secret at the exact moment it would be recorded.
#
# Degradation contract:
#   - commit-time (default): if gitleaks is NOT installed, WARN loudly and exit 0.
#     A missing scanner must not brick every commit on a dev box; the warning
#     tells the user to `brew install gitleaks`.
#   - push-time (--require / SECRET_SCAN_REQUIRE=1): gitleaks absence is a HARD
#     block. Pre-push is the last line before secrets leave the machine; there
#     the scanner MUST be present or the push is refused.
#
# Exit codes:
#   0  clean (or gitleaks absent in non-required mode — warned, not blocked)
#   1  finding (a secret was detected in the staged changes) — finding is shown
#   2  required mode and gitleaks is absent (hard block for pre-push)
#
# Usage:
#   secret-scan            scan staged changes, soft-degrade if gitleaks missing
#   secret-scan --require  scan staged changes, hard-fail if gitleaks missing

set -euo pipefail

REQUIRE=0
for arg in "$@"; do
  case "$arg" in
    --require) REQUIRE=1 ;;
  esac
done
# Allow env override (hooks pass it via env, args via CLI)
if [ "${SECRET_SCAN_REQUIRE:-0}" = "1" ]; then REQUIRE=1; fi

# --- gitleaks presence check ---------------------------------------------
if ! command -v gitleaks >/dev/null 2>&1; then
  if [ "$REQUIRE" = "1" ]; then
    cat >&2 <<'EOF'
BLOCKED: gitleaks is not installed and this is a HARD secret-scanning gate.
Pre-push is the last line of defense before secrets leave this machine.
Install it, then retry:

    brew install gitleaks

(or see https://github.com/gitleaks/gitleaks#installing)
EOF
    exit 2
  fi
  cat >&2 <<'EOF'
WARNING: gitleaks is not installed — staged changes were NOT scanned for secrets.
This commit is allowed (a missing scanner must not brick your commits), but you
are committing UNGUARDED. Install the scanner so the gate can protect you:

    brew install gitleaks

(or see https://github.com/gitleaks/gitleaks#installing)
EOF
  exit 0
fi

# --- choose the staged-scan invocation -----------------------------------
# gitleaks 8.19+ : `gitleaks git --staged`     (preferred)
# gitleaks <8.19 : `gitleaks protect --staged` (deprecated alias)
# Fallback       : scan the staged diff via `gitleaks stdin` if neither exists.
SCAN_OUT=""
SCAN_RC=0

if gitleaks git --help >/dev/null 2>&1; then
  SCAN_OUT=$(gitleaks git --staged --no-banner --redact 2>&1) && SCAN_RC=0 || SCAN_RC=$?
elif gitleaks protect --help >/dev/null 2>&1; then
  SCAN_OUT=$(gitleaks protect --staged --no-banner --redact 2>&1) && SCAN_RC=0 || SCAN_RC=$?
else
  # Documented fallback: pipe the staged diff through `gitleaks stdin`.
  SCAN_OUT=$(git diff --cached | gitleaks stdin --no-banner --redact 2>&1) && SCAN_RC=0 || SCAN_RC=$?
fi

if [ "$SCAN_RC" -eq 0 ]; then
  exit 0
fi

# Nonzero from gitleaks == leaks found (or a hard scan error). Show the finding.
echo "BLOCKED: gitleaks detected a secret in the staged changes." >&2
echo "Remove the credential from the staged diff before committing." >&2
echo "------------------------------------------------------------" >&2
printf '%s\n' "$SCAN_OUT" >&2
echo "------------------------------------------------------------" >&2
exit 1
