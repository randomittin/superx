#!/usr/bin/env bash
# heimdall-spawn ‚Äî Background Spawn Framework orchestrator (spec H-3).
#
# A standard way to run auxiliary instances (sentinels) that NEVER block the
# build lane and NEVER bloat the main context. Each spawn does ONE job, writes
# ONE report.json (the shared 8-field gate-report contract), and dies. Stateless.
#
# What this orchestrator does for a spawn:
#   1. Read the spawn contract json (.planning/spawns/<spawn_id>.json).
#   2. Enforce the LANE CAP ‚Äî background lane is capped (default 2 concurrent)
#      so sentinels never starve the `build` lane. A 3rd background spawn QUEUES
#      behind the running two (FIFO) until a slot frees.
#   3. Enforce the PER-SPAWN TOKEN BUDGET + timeout ‚Äî overrun => the spawn's
#      report is marked partial and flagged (metrics.budget_overrun), never
#      silently dropped.
#   4. Hydrate the MINIMAL-CONTEXT brief (capsule refs only ‚Äî never a full plan;
#      see sentinels/lib/brief.sh) and refuse a spawn whose context smuggles a
#      whole plan.
#   5. Dispatch to the matching sentinel under sentinels/, collect its
#      report.json, and surface the verdict.
#
# Spawn contract (.planning/spawns/<spawn_id>.json):
#   { "haid": "rj.mbp/sentinel-2",
#     "kind": "sanity|bloat|spec_drift|security|doc_sync",
#     "trigger": "post_wave|pre_commit|pre_push|schedule|watch",
#     "context": { capsule/criteria refs only ‚Äî never a full plan },
#     "budget_tokens": 15000, "timeout_min": 10, "lane": "background" }
#
# Usage:
#   heimdall-spawn run <spawn-json>   [--repo <root>]   run one spawn now
#   heimdall-spawn lane-status        [--repo <root>]   show running/queued bg
#   heimdall-spawn brief <spawn-json> [--repo <root>]   print the minimal brief
#   -h | --help
#
# Lane state lives under <repo>/.planning/spawns/lane/ (atomic mkdir slot dirs).
# Reports land under <repo>/.planning/spawns/reports/<spawn_id>.report.json.
#
# Exit codes: 0 = spawn ran and its report.status is pass/skipped; 1 = report
# status fail; 2 = usage / IO error; 3 = queued/no slot within wait window.
set -euo pipefail

SELF="$0"
if command -v readlink >/dev/null 2>&1; then
  SELF="$(readlink -f "$0" 2>/dev/null || readlink "$0" 2>/dev/null || echo "$0")"
fi
BIN_DIR="$(cd "$(dirname "$SELF")" && pwd)"
ROOT_DEFAULT="$(cd "$BIN_DIR/.." && pwd)"
SENTINELS_DIR="$ROOT_DEFAULT/sentinels"
# shellcheck source=../sentinels/lib/brief.sh
. "$SENTINELS_DIR/lib/brief.sh"

command -v jq >/dev/null 2>&1 || { echo "error: jq is required" >&2; exit 2; }

BG_CAP="${HEIMDALL_BG_CAP:-2}"          # max concurrent background spawns
QUEUE_WAIT_S="${HEIMDALL_QUEUE_WAIT_S:-0}"  # seconds to wait for a slot (0 = no wait)

usage() { sed -n '2,52p' "$SELF"; }

# ‚îÄ‚îÄ Lane slot management (atomic mkdir; build lane is never capped) ‚îÄ‚îÄ‚îÄ
lane_dir() { echo "$1/.planning/spawns/lane"; }

# Count live background slots, reaping dead ones (pid no longer alive).
_reap_and_count() {
  local ld="$1" n=0
  [ -d "$ld" ] || { echo 0; return 0; }
  local slot pid
  for slot in "$ld"/slot.*; do
    [ -d "$slot" ] || continue
    pid="$(cat "$slot/pid" 2>/dev/null || echo "")"
    if [ -n "$pid" ] && kill -0 "$pid" 2>/dev/null; then
      n=$(( n + 1 ))
    else
      rm -rf "$slot"   # stale slot from a dead spawn -> reclaim
    fi
  done
  echo "$n"
}

# Try to claim a background slot. Echoes the slot dir on success, empty on full.
_claim_slot() {
  local ld="$1" sid="$2"
  mkdir -p "$ld"
  local live; live="$(_reap_and_count "$ld")"
  if [ "$live" -ge "$BG_CAP" ]; then echo ""; return 0; fi
  # Atomic claim: a uniquely-named slot dir. mkdir fails if it already exists.
  local slot="$ld/slot.$$.$sid"
  if mkdir "$slot" 2>/dev/null; then
    echo "$$" >"$slot/pid"
    echo "$sid" >"$slot/spawn"
    echo "$slot"
  else
    echo ""
  fi
}

_release_slot() { [ -n "${1:-}" ] && rm -rf "$1" 2>/dev/null || true; }

# Map a spawn `kind` to its sentinel script + arg builder.
_sentinel_for_kind() {
  case "$1" in
    sanity)     echo "$SENTINELS_DIR/sanity.sh" ;;
    spec_drift) echo "$SENTINELS_DIR/spec-drift.sh" ;;
    security)   echo "$SENTINELS_DIR/security.sh" ;;
    bloat)      echo "$SENTINELS_DIR/bloat.sh" ;;
    doc_sync)   echo "$SENTINELS_DIR/doc-sync.sh" ;;
    *)          echo "" ;;
  esac
}

# ‚îÄ‚îÄ Subcommand: brief ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ
cmd_brief() {
  local sj="$1" root="$2"
  brief_hydrate "$sj" "$root"
}

# ‚îÄ‚îÄ Subcommand: lane-status ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ
cmd_lane_status() {
  local root="$1" ld; ld="$(lane_dir "$root")"
  local live; live="$(_reap_and_count "$ld")"
  echo "background lane: $live/$BG_CAP slots in use (cap=$BG_CAP)"
  if [ -d "$ld" ]; then
    local slot
    for slot in "$ld"/slot.*; do
      [ -d "$slot" ] || continue
      echo "  running: $(cat "$slot/spawn" 2>/dev/null) (pid $(cat "$slot/pid" 2>/dev/null))"
    done
  fi
  local q="$root/.planning/spawns/queue.jsonl"
  if [ -s "$q" ]; then
    echo "queued (waiting for a slot):"
    jq -r '"  " + .spawn_id + " (" + .kind + ")"' "$q" 2>/dev/null || true
  fi
}

# Append a spawn to the FIFO background queue (when no slot is free).
_enqueue() {
  local root="$1" sid="$2" kind="$3"
  local q="$root/.planning/spawns/queue.jsonl"
  mkdir -p "$(dirname "$q")"
  local lock="$root/.planning/spawns/.queue.lock"
  while ! mkdir "$lock" 2>/dev/null; do sleep 0.05; done
  jq -nc --arg s "$sid" --arg k "$kind" --argjson ts "$(date +%s)" \
    '{spawn_id:$s, kind:$k, enqueued_at:$ts}' >>"$q"
  rmdir "$lock" 2>/dev/null || true
}

# ‚îÄ‚îÄ Subcommand: run ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ
cmd_run() {
  local sj="$1" root="$2"
  [ -f "$sj" ] || { echo "error: spawn json not found: $sj" >&2; exit 2; }

  # Validate the spawn contract minimally.
  local kind trigger lane budget timeout sid
  kind="$(jq -r '.kind // empty' "$sj")"
  trigger="$(jq -r '.trigger // empty' "$sj")"
  lane="$(jq -r '.lane // "background"' "$sj")"
  budget="$(jq -r '.budget_tokens // 15000' "$sj")"
  timeout="$(jq -r '.timeout_min // 10' "$sj")"
  sid="$(basename "$sj" .json)"

  [ -n "$kind" ] || { echo "error: spawn json missing .kind" >&2; exit 2; }
  case "$kind" in sanity|bloat|spec_drift|security|doc_sync) ;; *)
    echo "error: unknown spawn kind '$kind'" >&2; exit 2 ;; esac

  # Minimal-context rule: refuse a brief that smuggles a full plan.
  if ! brief_assert_no_plan "$sj"; then
    echo "error: spawn context references a full plan ‚Äî forbidden by the minimal-context rule (spec H-3). Use capsule refs." >&2
    exit 2
  fi

  local sentinel; sentinel="$(_sentinel_for_kind "$kind")"
  [ -n "$sentinel" ] && [ -f "$sentinel" ] || {
    echo "error: no sentinel implements kind '$kind' (looked for $sentinel)" >&2; exit 2; }

  local report="$root/.planning/spawns/reports/$sid.report.json"
  mkdir -p "$(dirname "$report")"

  # Lane cap applies to the background lane only; build lane is uncapped.
  local slot=""
  if [ "$lane" = "background" ]; then
    local ld; ld="$(lane_dir "$root")"
    slot="$(_claim_slot "$ld" "$sid")"
    if [ -z "$slot" ]; then
      # No free slot. Optionally wait QUEUE_WAIT_S, polling; else enqueue + exit 3.
      local waited=0
      while [ "$waited" -lt "$QUEUE_WAIT_S" ] && [ -z "$slot" ]; do
        sleep 1; waited=$(( waited + 1 ))
        slot="$(_claim_slot "$ld" "$sid")"
      done
      if [ -z "$slot" ]; then
        _enqueue "$root" "$sid" "$kind"
        local live; live="$(_reap_and_count "$ld")"
        echo "QUEUED: background lane full ($live/$BG_CAP) ‚Äî '$sid' queued behind running spawns (FIFO). Re-run when a slot frees, or set HEIMDALL_QUEUE_WAIT_S to wait." >&2
        exit 3
      fi
    fi
  fi
  # Ensure the slot is always released, even on error/timeout.
  trap '_release_slot "$slot"' EXIT

  # Build the brief (printed to the spawn's log; the sentinel itself is fed refs).
  echo "‚îÄ‚îÄ heimdall-spawn: $sid (kind=$kind, trigger=$trigger, lane=$lane) ‚îÄ‚îÄ"
  brief_hydrate "$sj" "$root" || true

  # Assemble sentinel args from the spawn context (refs only).
  local diff_ref criteria spec invariants range
  diff_ref="$(jq -r '.context.diff_ref // empty' "$sj")"
  criteria="$(jq -r '.context.criteria_file // empty' "$sj")"
  spec="$(jq -r '.context.spec // empty' "$sj")"
  invariants="$(jq -r '.context.invariants // empty' "$sj")"
  range="$(jq -r '.context.range // empty' "$sj")"

  local -a args=(--repo "$root" --report "$report")
  case "$kind" in
    sanity)
      [ -n "$diff_ref" ] && args+=(--ref "${diff_ref##*..}")  # newest end of range
      ;;
    spec_drift)
      [ -n "$spec" ]       && args+=(--spec "$root/$spec")
      [ -n "$criteria" ]   && args+=(--criteria "$root/$criteria")
      [ -n "$invariants" ] && args+=(--invariants "$root/$invariants")
      ;;
    security)
      [ -n "$range" ] && args+=(--range "$range")
      ;;
    bloat)
      [ -n "$diff_ref" ] && args+=(--diff "$diff_ref")
      local crit_ids; crit_ids="$(jq -r '(.context.criteria // []) | join(",")' "$sj")"
      [ -n "$crit_ids" ] && args+=(--criteria "$crit_ids")
      ;;
    doc_sync)
      [ -n "$diff_ref" ] && args+=(--diff "$diff_ref")
      ;;
  esac

  # Enforce per-spawn timeout. Token-budget overrun is detected from the
  # sentinel's own metrics (a sentinel that captured a tokens_used metric over
  # budget) OR a timeout ‚Äî either way we mark the report partial + flagged.
  local timeout_s=$(( timeout * 60 ))
  local rc=0
  local timed_out=0
  if command -v timeout >/dev/null 2>&1; then
    timeout "$timeout_s" bash "$sentinel" "${args[@]}" || rc=$?
    [ "$rc" -eq 124 ] && timed_out=1
  else
    # No coreutils `timeout`: run with a watchdog so we still bound the spawn.
    bash "$sentinel" "${args[@]}" &
    local spid=$!
    ( sleep "$timeout_s"; kill -0 "$spid" 2>/dev/null && kill -TERM "$spid" 2>/dev/null ) &
    local wpid=$!
    wait "$spid" || rc=$?
    kill "$wpid" 2>/dev/null || true
    [ "$rc" -ge 128 ] && timed_out=1
  fi

  # Budget/overrun flagging: if the sentinel did not produce a report (timeout
  # before write) OR overran the token budget, mark partial + flag. We never
  # fake a verdict; partial preserves whatever the report holds (or notes none).
  if [ "$timed_out" -eq 1 ]; then
    if [ -f "$report" ]; then
      jq --argjson budget "$budget" --argjson tmin "$timeout" \
        '.status="partial" | .metrics.budget_overrun=true | .metrics.budget_tokens=$budget | .metrics.timeout_min=$tmin | .metrics.partial_reason="timeout"' \
        "$report" >"$report.tmp" && mv "$report.tmp" "$report"
    else
      # No report at all: synthesize a partial-flagged report so the contract holds.
      local haid; haid="$(jq -r '.haid // "haid:local"' "$sj")"
      jq -n --arg gate "sentinel-$kind" --arg haid "$haid" \
        --argjson budget "$budget" --argjson tmin "$timeout" \
        --arg ts "$(date -u +%FT%TZ)" \
        '{gate_id:$gate, status:"partial", first_divergence:null,
          metrics:{budget_overrun:true, budget_tokens:$budget, timeout_min:$tmin, partial_reason:"timeout-before-report"},
          fix_hint:"Spawn exceeded its timeout before writing a report. Raise timeout_min or narrow the spawn scope.",
          haid:$haid, wave:null, ts:$ts}' >"$report"
    fi
    echo "PARTIAL: spawn '$sid' exceeded ${timeout}min timeout ‚Äî report flagged partial (budget_overrun)." >&2
    rc=0
  fi

  # Token-budget overrun check (if the sentinel recorded tokens_used).
  if [ -f "$report" ]; then
    local used; used="$(jq -r '.metrics.tokens_used // empty' "$report")"
    if [ -n "$used" ] && [ "$used" -gt "$budget" ] 2>/dev/null; then
      jq --argjson budget "$budget" \
        '.status="partial" | .metrics.budget_overrun=true | .metrics.budget_tokens=$budget | .metrics.partial_reason="token-budget"' \
        "$report" >"$report.tmp" && mv "$report.tmp" "$report"
      echo "PARTIAL: spawn '$sid' overran token budget ($used > $budget) ‚Äî flagged." >&2
    fi
  fi

  # Surface the verdict from the report (consumers read report.json, not stdout).
  local status
  status="$(jq -r '.status // "missing"' "$report" 2>/dev/null || echo missing)"
  echo "spawn '$sid' -> status=$status  report=$report"
  case "$status" in
    pass|skipped|partial) exit 0 ;;
    fail)                 exit 1 ;;
    *)                    echo "error: spawn produced no valid report.json" >&2; exit 2 ;;
  esac
}

# ‚îÄ‚îÄ Arg parse ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ
SUB="${1:-}"; shift || true
ROOT="$ROOT_DEFAULT"
POS=()
while [ $# -gt 0 ]; do
  case "$1" in
    --repo) ROOT="${2:?--repo needs a path}"; shift 2 ;;
    -h|--help) usage; exit 0 ;;
    --*) echo "error: unknown flag: $1" >&2; usage >&2; exit 2 ;;
    *) POS+=("$1"); shift ;;
  esac
done

case "$SUB" in
  run)         [ "${#POS[@]}" -ge 1 ] || { echo "error: run needs <spawn-json>" >&2; exit 2; }; cmd_run "${POS[0]}" "$ROOT" ;;
  brief)       [ "${#POS[@]}" -ge 1 ] || { echo "error: brief needs <spawn-json>" >&2; exit 2; }; cmd_brief "${POS[0]}" "$ROOT" ;;
  lane-status) cmd_lane_status "$ROOT" ;;
  -h|--help|"") usage; exit 0 ;;
  *) echo "error: unknown subcommand: $SUB" >&2; usage >&2; exit 2 ;;
esac
