# --auto: use auto-mode instead of dangerously-skip-permissions (safer)
PERMISSION_FLAG="--dangerously-skip-permissions"
SKIP_CHECKPOINT=false
if [[ "${1:-}" == "--auto" ]]; then
  PERMISSION_FLAG="--permission-mode auto"
  shift
fi
if [[ "${1:-}" == "--skip-checkpoint" || "${1:-}" == "--fresh" ]]; then
  SKIP_CHECKPOINT=true
  shift
fi

# --no-autocommit / --autocommit: toggle auto-commit for this project
if [[ "${1:-}" == "--no-autocommit" ]]; then
  touch "$WORK_DIR/.superx-no-autocommit"
  printf "  \033[38;2;255;200;80m▸ Auto-commit OFF\033[0m for %s\n" "$WORK_DIR"
  printf "  Re-enable: superx --autocommit\n\n"
  exit 0
fi
if [[ "${1:-}" == "--autocommit" ]]; then
  rm -f "$WORK_DIR/.superx-no-autocommit"
  printf "  \033[38;2;78;204;163m▸ Auto-commit ON\033[0m for %s\n" "$WORK_DIR"
  exit 0
fi

# --skills: list, search, or install skills from registry
if [[ "${1:-}" == "--skills" ]]; then
  apply_superx_theme 2>/dev/null || true
  registry="$PLUGIN_DIR/skills-registry.json"
  skills_dir="$HOME/.claude/skills"

  if [[ "${2:-}" == "install" && -n "${3:-}" ]]; then
    # Install a specific skill by name or repo
    name="${3}"
    repo=""
    if [[ "$name" == */* ]]; then
      # Direct repo URL
      repo="$name"
      name=$(basename "$repo" | sed 's/\.git$//')
    elif [ -f "$registry" ]; then
      repo=$(python3 -c "
import json
with open('$registry') as f:
    reg = json.load(f)
for s in reg.get('skills', []):
    if s['name'] == '$name':
        print(s['repo']); break
" 2>/dev/null)
    fi
    if [ -z "$repo" ]; then
      echo "  Skill '$name' not found in registry. Use: superx --skills install owner/repo"
      exit 1
    fi
    skill_path="$skills_dir/$name"
    if [ -d "$skill_path" ]; then
      echo "  Skill '$name' already installed at $skill_path"
      exit 0
    fi
    mkdir -p "$skills_dir"
    printf "  Installing %s from %s...\n" "$name" "$repo"
    git clone --depth 1 "https://github.com/${repo}.git" "$skill_path"
    echo "  ✔ Installed to $skill_path"
    exit 0
  fi

  if [[ "${2:-}" == "search" && -n "${3:-}" ]]; then
    # Search GitHub for skills
    query="${3}"
    printf "  Searching GitHub for claude-code skills matching '%s'...\n\n" "$query"
    gh api search/repositories --method GET \
      -f q="topic:claude-code ${query} sort:stars" \
      -f per_page=10 \
      --jq '.items[] | "  ★\(.stargazers_count | tostring | if length < 5 then . + " " * (5 - length) else . end)  \(.full_name)\n         \(.description // "no description")\n"' 2>/dev/null
    exit 0
  fi

  if [[ "${2:-}" == "update" ]]; then
    # Update all installed skills
    for d in "$skills_dir"/*/; do
      [ -d "$d/.git" ] || continue
      name=$(basename "$d")
      printf "  Updating %s..." "$name"
      git -C "$d" pull --ff-only --quiet 2>/dev/null && printf " ✔\n" || printf " (skipped)\n"
    done
    exit 0
  fi

  if [[ "${2:-}" == "remove" && -n "${3:-}" ]]; then
    skill_path="$skills_dir/${3}"
    if [ -d "$skill_path" ]; then
      rm -rf "$skill_path"
      echo "  ✔ Removed ${3}"
    else
      echo "  Skill '${3}' not found"
    fi
    exit 0
  fi

  # Default: list installed + registry
  echo ""
  printf "  \033[1mInstalled skills:\033[0m\n"
  if [ -d "$skills_dir" ] && [ "$(ls -A "$skills_dir" 2>/dev/null)" ]; then
    for d in "$skills_dir"/*/; do
      [ -d "$d" ] || continue
      name=$(basename "$d")
      desc=""
      if [ -f "$d/SKILL.md" ]; then
        desc=$(grep -m1 "^description:" "$d/SKILL.md" 2>/dev/null | sed 's/^description: *//')
      fi
      printf "  \033[38;2;78;204;163m✔\033[0m %-25s %s\n" "$name" "$desc"
    done
  else
    echo "  (none)"
  fi

  if [ -f "$registry" ]; then
    echo ""
    printf "  \033[1mAvailable from registry:\033[0m\n"
    python3 -c "
import json
with open('$registry') as f:
    reg = json.load(f)
import os
skills_dir = os.path.expanduser('~/.claude/skills')
for s in reg.get('skills', []):
    installed = '✔' if os.path.isdir(os.path.join(skills_dir, s['name'])) else ' '
    print(f'  {installed} {s[\"name\"]:<25} {s[\"description\"]}')
" 2>/dev/null
  fi

  echo ""
  echo "  Commands:"
  echo "    superx --skills                    List installed & available skills"
  echo "    superx --skills install <name>     Install from registry"
  echo "    superx --skills install owner/repo Install from GitHub"
  echo "    superx --skills search <query>     Search GitHub for skills"
  echo "    superx --skills update             Update all installed skills"
  echo "    superx --skills remove <name>      Remove a skill"
  echo ""
  exit 0
fi

# ── Check for updates (non-blocking, fast) ──

check_for_update() {
  [ -d "$PLUGIN_DIR/.git" ] || return 0
  # Fetch every run (fast, non-blocking)
  git -C "$PLUGIN_DIR" fetch origin --force --quiet 2>/dev/null || return 0
  local local_hash=$(git -C "$PLUGIN_DIR" rev-parse HEAD 2>/dev/null)
  local remote_hash=$(git -C "$PLUGIN_DIR" rev-parse origin/main 2>/dev/null)
  if [ "$local_hash" != "$remote_hash" ] && [ -n "$remote_hash" ]; then
    local behind=$(git -C "$PLUGIN_DIR" rev-list HEAD..origin/main --count 2>/dev/null || echo "?")
    printf "  \033[38;2;255;200;80m⚡ Update available (%s commits behind). Run: superx --update\033[0m\n\n" "$behind"
  fi
}

# ── Load last checkpoint (mechanical — always injected) ──

load_checkpoint_context() {
  CHECKPOINT_CONTEXT=""
  if [ "$SKIP_CHECKPOINT" = true ]; then
    printf "  \033[38;2;255;200;80m▸ Checkpoint skipped\033[0m (--skip-checkpoint)\n"
    return 0
  fi
  local cp="$WORK_DIR/.planning/CHECKPOINT.md"
  local state="$WORK_DIR/.planning/STATE.md"
  local settings="$WORK_DIR/.planning/settings.json"

  # Load project settings (commands, parallelism, model routing, preferences)
  if [ -f "$settings" ]; then
    CHECKPOINT_CONTEXT="
--- PROJECT SETTINGS (from .planning/settings.json) ---
$(cat "$settings")
--- END SETTINGS ---
Use these settings: test/lint/build commands, parallelism config, model overrides, directories to avoid. Do NOT rediscover — they are already known.
"
    printf "  \033[38;2;78;204;163m▸ Project settings loaded\033[0m\n"
  fi

  # Load checkpoint handoff note
  if [ -f "$cp" ]; then
    CHECKPOINT_CONTEXT="${CHECKPOINT_CONTEXT}
--- LAST CHECKPOINT (from previous session) ---
$(head -100 "$cp")
--- END CHECKPOINT ---
Read .planning/CHECKPOINT.md for full context. Resume from where it says.
"
    printf "  \033[38;2;0;212;255m▸ Checkpoint loaded\033[0m — resuming from last session\n"
  elif [ -f "$state" ]; then
    local phase=$(grep -m1 "^current_phase:" "$state" 2>/dev/null | sed 's/current_phase: *//')
    if [ -n "$phase" ] && [ "$phase" != "0" ]; then
      CHECKPOINT_CONTEXT="${CHECKPOINT_CONTEXT}
--- PRIOR STATE ---
Phase: $phase. Read .planning/STATE.md for decisions, blockers, progress.
--- END STATE ---
"
      printf "  \033[38;2;100;100;120m▸ State loaded\033[0m — phase: %s\n" "$phase"
    fi
  fi
}

