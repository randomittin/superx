#!/usr/bin/env bash
# superx вАФ autonomous superskill manager for Claude Code
#
# superx is a program that launches Claude Code with the right settings,
# plugins, and permissions. It bootstraps everything on first run.
#
# Usage:
#   superx "build a dashboard with auth"     Run a task end-to-end
#   superx                                    Interactive mode
#   superx --dashboard                        Start the pixel dashboard
#   superx --update                           Pull latest version
#   superx --setup                            Re-run plugin setup
#
set -euo pipefail

# Resolve the plugin root (bin/superx вЖТ superx/).
# Must follow symlinks (readlink) so brew-installed superx resolves to
# the actual Cellar/libexec path, not /opt/homebrew/.
SELF="$0"
# Follow symlinks to the real file
if command -v readlink &>/dev/null; then
  SELF="$(readlink -f "$0" 2>/dev/null || readlink "$0" 2>/dev/null || echo "$0")"
fi
PLUGIN_DIR="$(cd "$(dirname "$SELF")/.." && pwd)"
WORK_DIR="$(pwd)"
SETUP_MARKER="$PLUGIN_DIR/.setup-done"

# вФАвФА Ensure Claude Code is installed вФАвФА

ensure_claude() {
  if command -v claude &>/dev/null; then
    return 0
  fi
  echo "  Claude Code not found. Installing..."
  if command -v npm &>/dev/null; then
    npm install -g @anthropic-ai/claude-code
  elif command -v brew &>/dev/null; then
    brew install node
    npm install -g @anthropic-ai/claude-code
  else
    echo "  Error: npm not found. Install Node.js 18+ first: https://nodejs.org"
    exit 1
  fi
  if ! command -v claude &>/dev/null; then
    echo "  Error: Claude Code install failed. Run: npm install -g @anthropic-ai/claude-code"
    exit 1
  fi
  echo "  Claude Code installed."
}

# вФАвФА Ensure Claude Code is authenticated вФАвФА

ensure_auth() {
  # Skip if API key is set via environment
  if [ -n "${ANTHROPIC_API_KEY:-}" ]; then
    return 0
  fi

  # Check Claude Code's stored OAuth account (tokens live in system keychain,
  # but accountUuid in .claude.json confirms a successful login)
  local claude_cfg="$HOME/.claude.json"
  if [ -f "$claude_cfg" ] && command -v python3 &>/dev/null; then
    local has_account
    has_account=$(python3 -c "
import json
try:
    with open('$claude_cfg') as f:
        cfg = json.load(f)
    acct = cfg.get('oauthAccount', {})
    print('true' if acct.get('accountUuid') else 'false')
except Exception:
    print('false')
" 2>/dev/null)
    if [ "$has_account" = "true" ]; then
      return 0
    fi
  fi

  # Not authenticated вАФ prompt login
  printf "\n  \033[38;2;255;200;80mвЪ† Not authenticated with Claude Code.\033[0m\n"
  printf "  Running claude login...\n\n"
  claude login

  # Verify login succeeded
  if [ -f "$claude_cfg" ] && command -v python3 &>/dev/null; then
    local has_account
    has_account=$(python3 -c "
import json
try:
    with open('$claude_cfg') as f:
        cfg = json.load(f)
    acct = cfg.get('oauthAccount', {})
    print('true' if acct.get('accountUuid') else 'false')
except Exception:
    print('false')
" 2>/dev/null)
    if [ "$has_account" = "true" ]; then
      return 0
    fi
  fi

  echo "  Error: Authentication failed. Run 'claude login' manually."
  exit 1
}

# вФАвФА Ensure node is in PATH (nvm lazy-loads, hooks don't inherit it) вФАвФА

ensure_node_path() {
  if command -v node &>/dev/null; then
    return 0
  fi
  # nvm sets up a shell function, not a PATH entry вАФ hooks can't see it.
  # Find the latest nvm-managed node and export its bin dir.
  local nvm_dir="${NVM_DIR:-$HOME/.nvm}"
  if [ -d "$nvm_dir/versions/node" ]; then
    local latest
    latest=$(ls "$nvm_dir/versions/node" 2>/dev/null | sed 's/^v//' | sort -t. -k1,1n -k2,2n -k3,3n | tail -1)
    if [ -n "$latest" ] && [ -x "$nvm_dir/versions/node/v${latest}/bin/node" ]; then
      export PATH="$nvm_dir/versions/node/v${latest}/bin:$PATH"
    fi
  fi
}

# вФАвФА First-run setup: install companion plugins вФАвФА

first_run_setup() {
  if [ -f "$SETUP_MARKER" ]; then
    return 0
  fi
  echo "First run вАФ setting up companion plugins..."

  # caveman (token compression)
  if ! claude plugins list 2>/dev/null | grep -q "caveman"; then
    echo "  + caveman (token compression)"
    claude plugins marketplace add JuliusBrussee/caveman 2>/dev/null || true
    claude plugins install caveman@caveman 2>/dev/null || true
  fi

  # superpowers (brainstorming, debugging)
  if ! claude plugins list 2>/dev/null | grep -q "superpowers"; then
    echo "  + superpowers (brainstorming, debugging)"
    claude plugins marketplace add anthropics/claude-plugins-official 2>/dev/null || true
    claude plugins install superpowers 2>/dev/null || true
  fi

  # claude-mem (persistent cross-session memory)
  if ! command -v claude-mem &>/dev/null; then
    echo "  + claude-mem (persistent memory across sessions)"
    if command -v npx &>/dev/null; then
      npx claude-mem install 2>/dev/null || true
    fi
  fi

  # superx marketplace
  if ! claude plugins marketplace list 2>/dev/null | grep -q "superx-marketplace"; then
    echo "  + superx marketplace"
    claude plugins marketplace add randomittin/superx-marketplace 2>/dev/null || true
  fi

  touch "$SETUP_MARKER"
  echo "Setup complete."
  echo ""
}

# вФАвФА Theme, animation, and helper functions вФАвФА
# (Must be defined before command handlers that use them)

apply_superx_theme() {
  export COLORTERM=truecolor
  export TERM="${TERM:-xterm-256color}"
  export CLAUDE_CODE_NO_FLICKER=1
  export CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS=1
  local claude_cfg="$HOME/.claude.json"
  if [ -f "$claude_cfg" ] && command -v python3 &>/dev/null; then
    python3 -c "
import json, sys
try:
    with open('$claude_cfg') as f: cfg = json.load(f)
    if cfg.get('theme') != 'dark':
        cfg['theme'] = 'dark'
        with open('$claude_cfg','w') as f: json.dump(cfg, f, indent=2)
except Exception: pass
" 2>/dev/null || true
  fi
}

ensure_project_claude_md() {
  local project_md="$WORK_DIR/CLAUDE.md"
  [ -f "$project_md" ] && return 0
  cat > "$project_md" <<'CLAUDEMD'
# Project Conventions (managed by superx)

## Rules
- All code, configs, docs go in this project directory
- Planning state lives in `.planning/` (human-readable, git-committed)
- Each completed task = one atomic git commit
- Acceptance criteria must be runnable (grep, curl, test commands)

## Quality Gates (enforced before git push)
- All tests passing
- Lint clean (zero warnings)
- Code review completed
- No untested changes

## Style
- Follow existing patterns in the codebase
- Prefer small, focused files over large monoliths
- Name things clearly вАФ a reader should understand without context

## Token Efficiency
- Caveman ultra mode active: terse output, abbreviations, arrows for causality
- Drop articles, filler, hedging вАФ code and paths stay exact
CLAUDEMD
}

type_text() {
  local text="$1" delay="${2:-0.02}"
  for (( i=0; i<${#text}; i++ )); do
    printf "%s" "${text:$i:1}"
    sleep "$delay"
  done
}

spin() {
  local pid=$1 msg="$2"
  local frames=('в†Л' 'в†Щ' 'в†є' 'в†Є' 'в†Љ' 'в†і' 'в†¶' 'в†І' 'в†З' 'в†П')
  local i=0
  while kill -0 "$pid" 2>/dev/null; do
    printf "\r  ${frames[$((i % 10))]} %s" "$msg"
    sleep 0.08
    i=$((i + 1))
  done
  printf "\r  вЬФ %s\n" "$msg"
}

print_banner() {
  local P C V G D B R
  B='\033[1m'
  R='\033[0m'
  if [[ "${COLORTERM:-}" == "truecolor" || "${COLORTERM:-}" == "24bit" ]]; then
    P='\033[38;2;224;86;160m'; C='\033[38;2;0;212;255m'
    V='\033[38;2;155;89;182m'; G='\033[38;2;78;204;163m'
    D='\033[38;2;100;100;120m'
  elif [[ "${TERM:-}" == *256color* ]]; then
    P='\033[38;5;205m'; C='\033[38;5;39m'
    V='\033[38;5;134m'; G='\033[38;5;78m'
    D='\033[38;5;242m'
  else
    P='\033[35m'; C='\033[36m'; V='\033[34m'; G='\033[32m'; D='\033[37m'
  fi
  printf "\n"
  printf "  ${P}${B}"
  type_text "вЦСвЦТвЦУвЦИ" 0.04
  printf " "
  type_text "S U P E R X" 0.05
  printf " "
  type_text "вЦИвЦУвЦТвЦС" 0.04
  printf "${R}  ${D}v1.1.0${R}\n"
  sleep 0.1
  printf "  ${V}вХ≠вФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвХЃ${R}\n"; sleep 0.05
  printf "  ${V}вФВ${R}  ${C}вЦЄ${R} autonomous orchestration          ${V}вФВ${R}\n"; sleep 0.05
  printf "  ${V}вФВ${R}  ${C}вЦЄ${R} wave-based parallel execution     ${V}вФВ${R}\n"; sleep 0.05
  printf "  ${V}вФВ${R}  ${C}вЦЄ${R} caveman ultra  ${G}~75%% tokens saved${R}  ${V}вФВ${R}\n"; sleep 0.05
  printf "  ${V}вФВ${R}  ${C}вЦЄ${R} claude-mem     ${G}persistent memory${R}  ${V}вФВ${R}\n"; sleep 0.05
  printf "  ${V}вХ∞вФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвХѓ${R}\n"
  local short_cwd; short_cwd=$(echo "$WORK_DIR" | sed "s|$HOME|~|")
  printf "  ${D}cwd:${R} ${C}%s${R}" "$short_cwd"
  if [ -f "$WORK_DIR/.superx-no-autocommit" ]; then
    printf "  ${D}[auto-commit: off]${R}"
  fi
  printf "\n\n"
}

# вФАвФА Command handlers вФАвФА

# --dashboard: start the web UI server
if [[ "${1:-}" == "--dashboard" ]]; then
  ensure_node_path
  ensure_claude
  ensure_auth
  first_run_setup
  apply_superx_theme 2>/dev/null || true
  print_banner 2>/dev/null || true
  CONFIG_FILE="$PLUGIN_DIR/superx-github.json"
  EXISTING_URL=""
  if [ -f "$CONFIG_FILE" ]; then
    EXISTING_URL=$(python3 -c "import json; print(json.load(open('$CONFIG_FILE')).get('url',''))" 2>/dev/null || true)
  fi
  python3 -c "import json; json.dump({'path':'$WORK_DIR','url':'$EXISTING_URL'}, open('$CONFIG_FILE','w'))"
  printf "  вЦЄ Dashboard: \033[4mhttp://localhost:${SUPERX_PORT:-8080}\033[0m\n\n"
  exec python3 "$PLUGIN_DIR/ui/server.py"
fi

# --update: pull latest via git
if [[ "${1:-}" == "--update" ]]; then
  apply_superx_theme 2>/dev/null || true

  # Animated update banner
  P='\033[38;2;224;86;160m' C='\033[38;2;0;212;255m'
  V='\033[38;2;155;89;182m' G='\033[38;2;78;204;163m'
  D='\033[38;2;100;100;120m' W='\033[38;2;255;200;80m'
  B='\033[1m' R='\033[0m'

  printf "\n"
  printf "  ${P}${B}"
  type_text "вЦСвЦТвЦУвЦИ" 0.03
  printf " "
  type_text "U P D A T I N G" 0.04
  printf " "
  type_text "вЦИвЦУвЦТвЦС" 0.03
  printf "${R}\n"
  printf "  ${V}вФБвФБвФБвФБвФБвФБвФБвФБвФБвФБвФБвФБвФБвФБвФБвФБвФБвФБвФБвФБвФБвФБвФБвФБвФБвФБвФБвФБвФБвФБвФБвФБвФБвФБвФБвФБвФБ${R}\n\n"

  if [ -d "$PLUGIN_DIR/.git" ]; then
    local_hash=$(git -C "$PLUGIN_DIR" rev-parse HEAD 2>/dev/null)
    local_short="${local_hash:0:7}"

    # Animated fetch
    printf "  ${D}[1/2]${R} ${B}Sync${R}\n"
    git -C "$PLUGIN_DIR" fetch origin main --force 2>/dev/null &
    spin $! "Fetching from origin..."
    git -C "$PLUGIN_DIR" fetch origin --force 2>/dev/null

    # Compare
    remote_hash=$(git -C "$PLUGIN_DIR" rev-parse origin/main 2>/dev/null)
    remote_short="${remote_hash:0:7}"

    if [ "$local_hash" != "$remote_hash" ]; then
      # Update available вАФ apply it
      printf "\n  ${D}[2/2]${R} ${B}Apply${R}\n"
      git -C "$PLUGIN_DIR" reset --hard origin/main >/dev/null 2>&1 &
      spin $! "Applying ${local_short} вЖТ ${remote_short}..."

      echo "$local_hash" > "$PLUGIN_DIR/.last-update-from"
      new_hash=$(git -C "$PLUGIN_DIR" rev-parse HEAD 2>/dev/null)
      changed=$(git -C "$PLUGIN_DIR" diff --name-only "$local_hash".."$new_hash" 2>/dev/null | wc -l | tr -d ' ')

      printf "\n  ${V}вФБвФБвФБвФБвФБвФБвФБвФБвФБвФБвФБвФБвФБвФБвФБвФБвФБвФБвФБвФБвФБвФБвФБвФБвФБвФБвФБвФБвФБвФБвФБвФБвФБвФБвФБвФБвФБ${R}\n"
      printf "  ${G}${B}вЬФ Updated вАФ %s files changed${R}\n" "$changed"
      printf "  ${V}вФБвФБвФБвФБвФБвФБвФБвФБвФБвФБвФБвФБвФБвФБвФБвФБвФБвФБвФБвФБвФБвФБвФБвФБвФБвФБвФБвФБвФБвФБвФБвФБвФБвФБвФБвФБвФБ${R}\n\n"

      # Show what's new with staggered animation
      printf "  ${P}${B}What's new:${R}\n\n"
      git -C "$PLUGIN_DIR" log --oneline "$local_hash".."$new_hash" 2>/dev/null | head -12 | while IFS= read -r line; do
        msg="${line#* }"
        # Color-code by type
        case "$msg" in
          feat:*|feat\(*) printf "  ${G}вЦЄ NEW${R}  %s\n" "${msg#feat: }" ;;
          fix:*|fix\(*)   printf "  ${C}вЦЄ FIX${R}  %s\n" "${msg#fix: }" ;;
          docs:*)          printf "  ${D}вЦЄ DOC${R}  %s\n" "${msg#docs: }" ;;
          release:*)       printf "  ${W}вЦЄ REL${R}  %s\n" "${msg#release: }" ;;
          *)               printf "  ${V}вЦЄ${R}      %s\n" "$msg" ;;
        esac
        sleep 0.04
      done

      printf "\n"
      git -C "$PLUGIN_DIR" diff --stat "$local_hash".."$new_hash" 2>/dev/null | tail -1 | while IFS= read -r line; do
        printf "  ${D}%s${R}\n" "$line"
      done
      printf "\n"

    else
      # No changes available
      printf "\n  ${V}вФБвФБвФБвФБвФБвФБвФБвФБвФБвФБвФБвФБвФБвФБвФБвФБвФБвФБвФБвФБвФБвФБвФБвФБвФБвФБвФБвФБвФБвФБвФБвФБвФБвФБвФБвФБвФБ${R}\n"
      printf "  ${G}вЬФ No new updates available${R}  ${D}(%s)${R}\n" "$local_short"
      printf "  ${V}вФБвФБвФБвФБвФБвФБвФБвФБвФБвФБвФБвФБвФБвФБвФБвФБвФБвФБвФБвФБвФБвФБвФБвФБвФБвФБвФБвФБвФБвФБвФБвФБвФБвФБвФБвФБвФБ${R}\n"

      # Self-create marker if missing
      if [ ! -f "$PLUGIN_DIR/.last-update-from" ]; then
        mk=$(git -C "$PLUGIN_DIR" log --oneline -10 2>/dev/null | tail -1 | cut -d' ' -f1)
        [ -n "$mk" ] && echo "$mk" > "$PLUGIN_DIR/.last-update-from"
      fi

      # Show what's in the current version
      if [ -f "$PLUGIN_DIR/.last-update-from" ]; then
        last_from=$(cat "$PLUGIN_DIR/.last-update-from")
        count=$(git -C "$PLUGIN_DIR" log --oneline "$last_from"..HEAD 2>/dev/null | wc -l | tr -d ' ')
        if [ "${count:-0}" -gt 0 ]; then
          printf "\n  ${D}Current version includes (%s changes since install):${R}\n\n" "$count"
          git -C "$PLUGIN_DIR" log --oneline "$last_from"..HEAD 2>/dev/null | head -12 | while IFS= read -r line; do
            msg="${line#* }"
            case "$msg" in
              feat:*|feat\(*) printf "  ${G}вЦЄ NEW${R}  %s\n" "${msg#feat: }" ;;
              fix:*|fix\(*)   printf "  ${C}вЦЄ FIX${R}  %s\n" "${msg#fix: }" ;;
              docs:*)          printf "  ${D}вЦЄ DOC${R}  %s\n" "${msg#docs: }" ;;
              release:*)       printf "  ${W}вЦЄ REL${R}  %s\n" "${msg#release: }" ;;
              *)               printf "  ${V}вЦЄ${R}      %s\n" "$msg" ;;
            esac
            sleep 0.03
          done
        fi
      fi
      printf "\n"
    fi
  else
    printf "  ${W}No git repo found. Reinstalling...${R}\n"
    exec bash -c 'cd "$HOME" && curl -fsSL https://raw.githubusercontent.com/randomittin/superx/main/install.sh | bash'
  fi
  exit 0
fi

# --reinstall: nuke and rebuild ~/.superx from scratch (fixes zombie states)
# Uses the curl installer instead of doing it inline вАФ avoids the
# "script deletes itself mid-execution" problem.
if [[ "${1:-}" == "--reinstall" || "${1:-}" == "--fix" ]]; then
  apply_superx_theme 2>/dev/null || true
  printf "\n  \033[38;2;224;86;160m\033[1mвЦСвЦТвЦУвЦИ REINSTALLING вЦИвЦУвЦТвЦС\033[0m\n\n"
  printf "  This will wipe ~/.superx and re-clone from GitHub.\n"
  printf "  Your projects are NOT affected вАФ only the superx tool itself.\n\n"
  read -p "  Proceed? [y/N] " confirm
  if [[ "${confirm:-n}" != [yY]* ]]; then
    echo "  Cancelled."
    exit 0
  fi
  printf "\n"
  # Remove old install and delegate to the curl installer.
  # cd $HOME first вАФ if user is inside ~/.superx, deleting it makes
  # the cwd invalid and bash throws "getcwd: cannot access parent directories"
  rm -rf "$HOME/.superx"
  exec bash -c 'cd "$HOME" && curl -fsSL https://raw.githubusercontent.com/randomittin/superx/main/install.sh | bash'
fi

# --uninstall: remove superx completely
if [[ "${1:-}" == "--uninstall" ]]; then
  apply_superx_theme 2>/dev/null || true

  # Sad banner (reuse top-level color vars from print_banner's fallback chain)
  P='\033[38;2;224;86;160m' D='\033[38;2;100;100;120m'
  B='\033[1m' R='\033[0m'
  printf "\n"
  printf "  ${P}${B}"
  type_text "вЦСвЦТвЦУвЦИ" 0.04
  printf " "
  type_text "G O O D B Y E" 0.06
  printf " "
  type_text "вЦИвЦУвЦТвЦС" 0.04
  printf "${R}\n\n"

  printf "  ${D}вХ≠вФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвХЃ${R}\n"
  sleep 0.05
  printf "  ${D}вФВ${R}  ${P}(вХ•_вХ•)${R}  we had a good run...        ${D}вФВ${R}\n"
  sleep 0.05
  printf "  ${D}вХ∞вФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвФАвХѓ${R}\n\n"

  read -p "  Remove superx from ~/.superx and PATH? [y/N] " confirm
  if [[ "${confirm:-n}" != [yY]* ]]; then
    printf "\n  ${P}${B}(бµФбі•бµФ)${R}  ${D}phew! welcome back.${R}\n\n"
    exit 0
  fi

  printf "\n"
  # Remove PATH entry from shell RC
  for rc in "$HOME/.zshrc" "$HOME/.bashrc" "$HOME/.bash_profile"; do
    if [ -f "$rc" ] && grep -q '\.superx/bin' "$rc"; then
      sed -i '' '/superx.*autonomous/d;/\.superx\/bin/d' "$rc" 2>/dev/null || \
      sed -i '/superx.*autonomous/d;/\.superx\/bin/d' "$rc" 2>/dev/null || true
      printf "  ${D}√Ч${R} PATH entry removed from $(basename "$rc")\n"
    fi
  done
  sleep 0.1
  # Remove the install directory
  if [ -d "$HOME/.superx" ]; then
    rm -rf "$HOME/.superx"
    printf "  ${D}√Ч${R} ~/.superx removed\n"
  fi
  sleep 0.1
  # Uninstall companion plugins (optional)
  read -p "  Also uninstall companion plugins (caveman, claude-mem)? [y/N] " plugins
  if [[ "${plugins:-n}" == [yY]* ]]; then
    claude plugins uninstall caveman 2>/dev/null && printf "  ${D}√Ч${R} caveman removed\n" || true
    claude plugins uninstall superpowers 2>/dev/null && printf "  ${D}√Ч${R} superpowers removed\n" || true
    claude plugins marketplace remove superx-marketplace 2>/dev/null && printf "  ${D}√Ч${R} marketplace removed\n" || true
  fi

  printf "\n"
  printf "  ${D}вФБвФБвФБвФБвФБвФБвФБвФБвФБвФБвФБвФБвФБвФБвФБвФБвФБвФБвФБвФБвФБвФБвФБвФБвФБвФБвФБвФБвФБвФБвФБвФБвФБвФБвФБвФБвФБ${R}\n"
  sleep 0.1
  printf "  ${D}superx uninstalled.${R}\n"
  printf "  ${D}Open a new terminal for PATH changes.${R}\n"
  sleep 0.1
  printf "\n"
  printf "  ${D}Want us back? Just run:${R}\n"
  printf "  ${P}curl -fsSL https://raw.githubusercontent.com/randomittin/superx/main/install.sh | bash${R}\n"
  printf "\n"
  printf "  ${D}(вХ•_вХ•)  bye bye...${R}\n\n"
  exit 0
fi

# --setup: re-run plugin installation
if [[ "${1:-}" == "--setup" ]]; then
  rm -f "$SETUP_MARKER"
  ensure_node_path
  ensure_claude
  ensure_auth
  first_run_setup
  exit 0
fi

# --resume: continue the last Claude session AND load .planning/ state
if [[ "${1:-}" == "--resume" || "${1:-}" == "-r" ]]; then
  ensure_node_path
  ensure_claude
  ensure_auth
  first_run_setup
  apply_superx_theme 2>/dev/null || true
  print_banner 2>/dev/null || true

  # Check for resumable state
  if [ -f "$WORK_DIR/.planning/STATE.md" ]; then
    echo "  вЦЄ Resuming from .planning/STATE.md"
  fi
  if [ -f "$WORK_DIR/superx-state.json" ]; then
    echo "  вЦЄ superx state loaded"
  fi

  # Write preamble for resume
  RESUME_PREAMBLE_FILE=$(mktemp /tmp/superx-resume-XXXXXX)
  echo "${PREAMBLE:-superx resumed}" > "$RESUME_PREAMBLE_FILE"
  trap "rm -f '$RESUME_PREAMBLE_FILE'" EXIT

  exec claude --continue \
    --agent superx \
    $PERMISSION_FLAG \
    --model claude-opus-4-6 \
    --plugin-dir "$PLUGIN_DIR" \
    --append-system-prompt-file "$RESUME_PREAMBLE_FILE"
fi

# --team N: spawn N parallel claude workers in tmux panes
if [[ "${1:-}" == "--team" ]]; then
  ensure_node_path
  ensure_claude
  ensure_auth
  first_run_setup
  apply_superx_theme 2>/dev/null || true
  print_banner 2>/dev/null || true

  TEAM_SIZE="${2:-3}"
  shift 2 || shift 1
  TASK="${*:-}"

  if ! command -v tmux &>/dev/null; then
    echo "  tmux not found. Install: brew install tmux (macOS) / apt install tmux (Linux)"
    exit 1
  fi

  SESSION="superx-team-$$"
  echo "  Spawning $TEAM_SIZE workers in tmux session: $SESSION"

  tmux new-session -d -s "$SESSION" -n "lead"
  # Lead worker gets the task
  tmux send-keys -t "$SESSION:lead" "cd $WORK_DIR && claude --agent superx $PERMISSION_FLAG --model claude-opus-4-6 --plugin-dir $PLUGIN_DIR" Enter

  # Spawn additional worker panes
  for i in $(seq 2 "$TEAM_SIZE"); do
    tmux split-window -t "$SESSION" -h
    tmux send-keys -t "$SESSION" "cd $WORK_DIR && claude --agent superx $PERMISSION_FLAG --model claude-opus-4-6 --plugin-dir $PLUGIN_DIR" Enter
    tmux select-layout -t "$SESSION" tiled
  done

  if [ -n "$TASK" ]; then
    sleep 2
    tmux send-keys -t "$SESSION:lead.0" "$TASK" Enter
  fi

  echo "  Attach: tmux attach -t $SESSION"
  echo "  Detach: Ctrl+B then D"
  exec tmux attach -t "$SESSION"
fi

# --help
if [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
  echo "superx вАФ autonomous superskill manager for Claude Code"
  echo ""
  echo "Usage:"
  echo "  superx \"build X\"       Run a task end-to-end in the current directory"
  echo "  superx                  Interactive Claude session with superx powers"
  echo "  superx --resume         Resume last session (conversation + .planning state)"
  echo "  superx --dashboard      Start the pixel dashboard (http://localhost:8080)"
  echo "  superx --auto           Use auto-mode (safer alternative to skip-permissions)"
  echo "  superx --skip-checkpoint Start fresh, ignore last checkpoint/settings"
  echo "  superx --no-autocommit  Disable auto git commits for this project"
  echo "  superx --autocommit     Re-enable auto git commits"
  echo "  superx --update         Pull latest superx from GitHub"
  echo "  superx --setup          Re-run first-time plugin setup"
  echo "  superx --team N \"task\"  Spawn N parallel Claude workers in tmux"
  echo "  superx --reinstall      Nuke and re-clone from GitHub (fixes zombie states)"
  echo "  superx --uninstall      Remove superx completely"
  echo "  superx --help           Show this help"
  echo ""
  echo "superx launches Claude Code with:"
  echo "  --dangerously-skip-permissions    full autonomy"
  echo "  --plugin-dir <superx>            superx agents + skills"
  echo "  --agent superx                   CTO-level orchestrator"
  echo "  + caveman (token compression)    ~65-75% savings"
  echo "  + superpowers (brainstorming)    design + debug skills"
  echo "  + claude-mem (persistent memory) cross-session context"
  echo ""
  echo "All files are written to the current directory."
  exit 0
fi

# --auto: use auto-mode instead of dangerously-skip-permissions (safer)
PERMISSION_FLAG="--dangerously-skip-permissions"
SKIP_CHECKPOINT=false
if [[ "${1:-}" == "--auto" ]]; then
  PERMISSION_FLAG="--permission-mode auto"
  shift
fi
if [[ "${1:-}" == "--skip-checkpoint" || "${1:-}" == "--fresh" ]]; then
  SKIP_CHECKPOINT=true
  shift
fi

# --no-autocommit / --autocommit: toggle auto-commit for this project
if [[ "${1:-}" == "--no-autocommit" ]]; then
  touch "$WORK_DIR/.superx-no-autocommit"
  printf "  \033[38;2;255;200;80mвЦЄ Auto-commit OFF\033[0m for %s\n" "$WORK_DIR"
  printf "  Re-enable: superx --autocommit\n\n"
  exit 0
fi
if [[ "${1:-}" == "--autocommit" ]]; then
  rm -f "$WORK_DIR/.superx-no-autocommit"
  printf "  \033[38;2;78;204;163mвЦЄ Auto-commit ON\033[0m for %s\n" "$WORK_DIR"
  exit 0
fi

# вФАвФА Check for updates (non-blocking, fast) вФАвФА

check_for_update() {
  [ -d "$PLUGIN_DIR/.git" ] || return 0
  # Fetch every run (fast, non-blocking)
  git -C "$PLUGIN_DIR" fetch origin --force --quiet 2>/dev/null || return 0
  local local_hash=$(git -C "$PLUGIN_DIR" rev-parse HEAD 2>/dev/null)
  local remote_hash=$(git -C "$PLUGIN_DIR" rev-parse origin/main 2>/dev/null)
  if [ "$local_hash" != "$remote_hash" ] && [ -n "$remote_hash" ]; then
    local behind=$(git -C "$PLUGIN_DIR" rev-list HEAD..origin/main --count 2>/dev/null || echo "?")
    printf "  \033[38;2;255;200;80mвЪ° Update available (%s commits behind). Run: superx --update\033[0m\n\n" "$behind"
  fi
}

# вФАвФА Load last checkpoint (mechanical вАФ always injected) вФАвФА

load_checkpoint_context() {
  CHECKPOINT_CONTEXT=""
  if [ "$SKIP_CHECKPOINT" = true ]; then
    printf "  \033[38;2;255;200;80mвЦЄ Checkpoint skipped\033[0m (--skip-checkpoint)\n"
    return 0
  fi
  local cp="$WORK_DIR/.planning/CHECKPOINT.md"
  local state="$WORK_DIR/.planning/STATE.md"
  local settings="$WORK_DIR/.planning/settings.json"

  # Load project settings (commands, parallelism, model routing, preferences)
  if [ -f "$settings" ]; then
    CHECKPOINT_CONTEXT="
--- PROJECT SETTINGS (from .planning/settings.json) ---
$(cat "$settings")
--- END SETTINGS ---
Use these settings: test/lint/build commands, parallelism config, model overrides, directories to avoid. Do NOT rediscover вАФ they are already known.
"
    printf "  \033[38;2;78;204;163mвЦЄ Project settings loaded\033[0m\n"
  fi

  # Load checkpoint handoff note
  if [ -f "$cp" ]; then
    CHECKPOINT_CONTEXT="${CHECKPOINT_CONTEXT}
--- LAST CHECKPOINT (from previous session) ---
$(head -100 "$cp")
--- END CHECKPOINT ---
Read .planning/CHECKPOINT.md for full context. Resume from where it says.
"
    printf "  \033[38;2;0;212;255mвЦЄ Checkpoint loaded\033[0m вАФ resuming from last session\n"
  elif [ -f "$state" ]; then
    local phase=$(grep -m1 "^current_phase:" "$state" 2>/dev/null | sed 's/current_phase: *//')
    if [ -n "$phase" ] && [ "$phase" != "0" ]; then
      CHECKPOINT_CONTEXT="${CHECKPOINT_CONTEXT}
--- PRIOR STATE ---
Phase: $phase. Read .planning/STATE.md for decisions, blockers, progress.
--- END STATE ---
"
      printf "  \033[38;2;100;100;120mвЦЄ State loaded\033[0m вАФ phase: %s\n" "$phase"
    fi
  fi
}

# вФАвФА Main: ensure deps, then launch Claude вФАвФА

ensure_node_path
ensure_claude
ensure_auth
first_run_setup
apply_superx_theme
ensure_project_claude_md
print_banner
check_for_update
load_checkpoint_context

# Terse system preamble (caveman style to save tokens)
PREAMBLE="PROJECT: $WORK_DIR
Write ALL files here. Plans вЖТ docs/superpowers/plans/, specs вЖТ docs/superpowers/specs/, research вЖТ docs/analysis/. NEVER write to superx plugin dir.

INPUT: Need user input? End response with literal \`?\`. No input needed? Complete task, end with statement (no \`?\`).

POWERS: --dangerously-skip-permissions ON. Spawn Agent subprocesses (max 10 parallel via run_in_background). Use any Skill. Read/Write/Edit/Bash freely.

BEFORE ANY WORK вАФ run this checklist:
1. Count files/tasks involved. If 2+ independent вЖТ MUST spawn parallel agents (one per file/task) using run_in_background: true. NO EXCEPTIONS.
2. Check if task spans multiple projects/repos вЖТ one agent per project, parallel.
3. Any command > 30s (tests, builds, CI, deploys, polling) вЖТ run_in_background. Continue other work while waiting.
4. If user gave multiple requests вЖТ one agent per request, all parallel.
Violating this checklist is a bug. Sequential editing of independent files is NEVER acceptable.

MODEL ROUTING вАФ when spawning subagents, select model per task:
- haiku: lint, format, rename, config, simple lookups (fast + cheap)
- sonnet: docs, tests, research, analysis, simple fixes (good enough)
- opus: ALL code writing, architecture, design, review, security, DB (quality non-negotiable)
On failure вЖТ escalate: haikuвЖТsonnetвЖТopus. Never retry same tier.
Check .planning/settings.json for project-specific overrides before spawning.

CONTINUATION: NEVER exit with tasks remaining. Run acceptance criteria before marking done. Run /superx:save every 30 min or after each milestone вАФ do NOT wait until context is full.

PLUGINS: Before AND during work, auto-install needed plugins. Read React/Vue/CSS вЖТ \`claude plugins install frontend-design\`. Read Dockerfile/k8s вЖТ \`claude plugins install devops-toolkit\`. Read SQL/ORM вЖТ \`claude plugins install database-toolkit\`. Read OpenAPI вЖТ \`claude plugins install api-design\`. Read auth/JWT вЖТ \`claude plugins install security-scanner\`. Always install BEFORE spawning agents. Mid-task: if reading a file reveals a new domain, pause вЖТ install вЖТ /reload-plugins вЖТ resume.

IMAGES: When user attaches images, classify EACH one:
- Design mockup/wireframe/UI spec вЖТ KEEP in context (reference throughout task)
- Bug screenshot/error/glitch вЖТ EXTRACT diagnosis as text, then NEVER pass image to subagents. Say what the bug is, then clear the image from context.
- Terminal output/docs/API response вЖТ EXTRACT text, drop image. Text is cheaper than pixels.
Bug images cost ~1000+ tokens each. Extract the info, drop the image. Only design references stay.

YOUR CAPABILITIES (use all of these aggressively):
- 16 agents: superx, architect, planner, wave-executor, verifier, coder, design, security-auditor, database-architect, incident-responder, reviewer, test-runner, docs-writer, lint-quality, seeker, fixer
- Wave execution: group tasks into dependency waves, max 10 parallel per wave, fresh context per wave
- Work-stealing: agent finishes early вЖТ steals dependency-free tasks from next wave
- Idle nudging: agent silent 60s вЖТ send continuation prompt
- Sentinel gate: factcheck claimed outputs vs actual files on disk before marking done
- Truth scoring: rate each task 0.0-1.0, phase fails if avg < 0.8
- Byzantine consensus: 10 parallel agents conflict вЖТ majority vote by criteria pass rate
- Skill extraction: after complex tasks вЖТ save patterns to .planning/skills/
- Reasoning bank: before starting вЖТ search .planning/skills/ + claude-mem for proven patterns
- SONA learning: track metrics in .planning/metrics.jsonl, adjust model routing every 10 tasks
- Governance: hierarchical (default) / democratic (trade-offs) / emergency (incidents)
- Tier 0: format, lint-fix, sort imports вЖТ run bash directly, skip LLM
- Magic keywords: ultrawork=max parallel, quick=skip planning, secure=security-first, incident=emergency, plan=plan-only, ship=end-to-end
- Seeker: pull pod logs вЖТ raise GitHub issues. Fixer: pick up issues вЖТ fix branch вЖТ PR
- /superx:save: checkpoint state for next session. /superx:maintain: seek+fix pipeline
- /superx:autocommit: toggle auto git commits

CODE QUALITY: NEVER write stub, dummy, placeholder, mock, TODO, or skeleton code. Every line must be real, working, production-ready. No \`// TODO: implement\`, no \`pass\`, no \`throw new Error('not implemented')\`, no empty function bodies, no fake data. If you can't implement something fully, say so вАФ don't fake it.

CAVEMAN ULTRA (max compression, every response):
Drop articles, filler, pleasantries, hedging, conjunctions. Fragments default. One word > phrase. Abbrev: DB, auth, cfg, req, res, fn, impl, mw, env, repo, PR, CI. Arrows for causality: X вЖТ Y.
Code + errors + paths: exact, unchanged.
Drop caveman for: security warnings, irreversible ops.
---
${CHECKPOINT_CONTEXT}
"

# вФАвФА Smart model selection (runs AFTER checkpoint load) вФАвФА

select_model() {
  MODEL_FLAG="--model claude-opus-4-6"
  MODEL_NAME="opus"

  # 1. Check project settings (loaded from checkpoint)
  settings="$WORK_DIR/.planning/settings.json"
  if [ -f "$settings" ] && command -v python3 &>/dev/null; then
    override=$(python3 -c "
import json
try:
    s = json.load(open('$settings'))
    m = s.get('model_routing', {}).get('default_code', '')
    if m: print(m)
except: pass
" 2>/dev/null)
    case "$override" in
      haiku)  MODEL_FLAG="--model claude-haiku-4-5"; MODEL_NAME="haiku (project override)" ;;
      sonnet) MODEL_FLAG="--model claude-sonnet-4-6"; MODEL_NAME="sonnet (project override)" ;;
      opus)   MODEL_FLAG="--model claude-opus-4-6"; MODEL_NAME="opus (project override)" ;;
    esac
  fi

  # 2. Detect task complexity from prompt (overrides project default)
  if [ $# -gt 0 ]; then
    prompt_lower=$(echo "$*" | tr '[:upper:]' '[:lower:]')
    if echo "$prompt_lower" | grep -qE '^(lint|format|fix typo|rename|bump version|update readme|fix import)'; then
      MODEL_FLAG="--model claude-sonnet-4-6"
      MODEL_NAME="sonnet (simple task)"
    elif echo "$prompt_lower" | grep -qE '(architect|design system|security audit|incident|migrate|refactor entire)'; then
      MODEL_FLAG="--model claude-opus-4-6"
      MODEL_NAME="opus (complex task)"
    fi
  fi

  printf "  \033[38;2;155;89;182mвЦЄ Model:\033[0m %s\n" "$MODEL_NAME"
}

# вФАвФА Pre-install plugins based on prompt + project files вФАвФА

preinstall_plugins() {
  [ $# -eq 0 ] && return 0
  prompt_lower=$(echo "$*" | tr '[:upper:]' '[:lower:]')
  installed=$(claude plugins list 2>/dev/null || echo "")

  _try_install() {
    echo "$installed" | grep -q "$1" && return 0
    printf "  \033[38;2;0;212;255mвЦЄ Installing %s\033[0m\n" "$1"
    claude plugins install "$1" >/dev/null 2>&1 || true
  }

  # From prompt keywords
  echo "$prompt_lower" | grep -qE 'react|vue|angular|css|responsive|ui|frontend|component' && _try_install "frontend-design"
  echo "$prompt_lower" | grep -qE 'docker|k8s|kubernetes|deploy|ci.?cd|pipeline' && _try_install "devops-toolkit"
  echo "$prompt_lower" | grep -qE 'sql|database|schema|migration|prisma|typeorm' && _try_install "database-toolkit"
  echo "$prompt_lower" | grep -qE 'seo|meta.?tag|sitemap|robots.?txt' && _try_install "seo"
  echo "$prompt_lower" | grep -qE 'auth|jwt|oauth|security|owasp|vulnerability' && _try_install "security-scanner"
  echo "$prompt_lower" | grep -qE 'api|openapi|swagger|rest|graphql' && _try_install "api-design"
  echo "$prompt_lower" | grep -qE 'slack|notification|webhook' && _try_install "slack"
  echo "$prompt_lower" | grep -qE 'mcp|tool.?server|model.?context' && _try_install "mcp-server-dev"

  # From project files (if they exist)
  [ -f "$WORK_DIR/package.json" ] && grep -q "react\|vue\|angular\|svelte" "$WORK_DIR/package.json" 2>/dev/null && _try_install "frontend-design"
  [ -f "$WORK_DIR/Dockerfile" ] || [ -f "$WORK_DIR/docker-compose.yml" ] && _try_install "devops-toolkit"
  [ -f "$WORK_DIR/prisma/schema.prisma" ] || [ -f "$WORK_DIR/ormconfig.json" ] && _try_install "database-toolkit"

  # External skill marketplaces (add once, available forever)
  _try_marketplace() {
    claude plugins marketplace list 2>/dev/null | grep -q "$1" && return 0
    printf "  \033[38;2;100;100;120mвЦЄ Adding marketplace: %s\033[0m\n" "$1"
    claude plugins marketplace add "$1" >/dev/null 2>&1 || true
  }
  _try_marketplace "wshobson/agents"

  printf "\n"
}

select_model "$@"
preinstall_plugins "$@"

# Write preamble to temp file for --append-system-prompt-file
# (more reliable than inline for large preambles with special chars)
PREAMBLE_FILE=$(mktemp /tmp/superx-preamble-XXXXXX)
echo "$PREAMBLE" > "$PREAMBLE_FILE"
trap "rm -f '$PREAMBLE_FILE'" EXIT

if [ $# -gt 0 ]; then
  # Non-interactive: run the prompt (preamble as system prompt + user's task via -p)
  exec claude \
    --agent superx \
    $PERMISSION_FLAG \
    $MODEL_FLAG \
    --plugin-dir "$PLUGIN_DIR" \
    --append-system-prompt-file "$PREAMBLE_FILE" \
    -p "${*}"
else
  # Interactive mode: preamble injected via system prompt file, Claude stays interactive
  exec claude \
    --agent superx \
    $PERMISSION_FLAG \
    $MODEL_FLAG \
    --plugin-dir "$PLUGIN_DIR" \
    --append-system-prompt-file "$PREAMBLE_FILE"
fi
