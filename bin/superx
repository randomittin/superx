#!/usr/bin/env bash
# superx — autonomous superskill manager for Claude Code
#
# superx is a program that launches Claude Code with the right settings,
# plugins, and permissions. It bootstraps everything on first run.
#
# Usage:
#   superx "build a dashboard with auth"     Run a task end-to-end
#   superx                                    Interactive mode
#   superx --dashboard                        Start the pixel dashboard
#   superx --update                           Pull latest version
#   superx --setup                            Re-run plugin setup
#
set -euo pipefail

# Resolve the plugin root (bin/superx → superx/)
PLUGIN_DIR="$(cd "$(dirname "$0")/.." && pwd)"
WORK_DIR="$(pwd)"
SETUP_MARKER="$PLUGIN_DIR/.setup-done"

# ── Ensure Claude Code is installed ──

ensure_claude() {
  if command -v claude &>/dev/null; then
    return 0
  fi
  echo "Claude Code not found. Installing..."
  if command -v npm &>/dev/null; then
    npm install -g @anthropic-ai/claude-code
  elif command -v brew &>/dev/null; then
    brew install node
    npm install -g @anthropic-ai/claude-code
  else
    echo "Error: npm not found. Install Node.js 18+ first: https://nodejs.org"
    exit 1
  fi
  if ! command -v claude &>/dev/null; then
    echo "Error: Claude Code install failed. Run: npm install -g @anthropic-ai/claude-code"
    exit 1
  fi
  echo "Claude Code installed."
}

# ── First-run setup: install companion plugins ──

first_run_setup() {
  if [ -f "$SETUP_MARKER" ]; then
    return 0
  fi
  echo "First run — setting up companion plugins..."

  # caveman (token compression)
  if ! claude plugins list 2>/dev/null | grep -q "caveman"; then
    echo "  + caveman (token compression)"
    claude plugins marketplace add JuliusBrussee/caveman 2>/dev/null || true
    claude plugins install caveman@caveman 2>/dev/null || true
  fi

  # superpowers (brainstorming, debugging)
  if ! claude plugins list 2>/dev/null | grep -q "superpowers"; then
    echo "  + superpowers (brainstorming, debugging)"
    claude plugins marketplace add anthropics/claude-plugins-official 2>/dev/null || true
    claude plugins install superpowers 2>/dev/null || true
  fi

  # claude-mem (persistent cross-session memory)
  if ! command -v claude-mem &>/dev/null; then
    echo "  + claude-mem (persistent memory across sessions)"
    if command -v npx &>/dev/null; then
      npx claude-mem install 2>/dev/null || true
    fi
  fi

  # superx marketplace
  if ! claude plugins marketplace list 2>/dev/null | grep -q "superx-marketplace"; then
    echo "  + superx marketplace"
    claude plugins marketplace add randomittin/superx-marketplace 2>/dev/null || true
  fi

  touch "$SETUP_MARKER"
  echo "Setup complete."
  echo ""
}

# ── Command handlers ──

# --dashboard: start the web UI server
if [[ "${1:-}" == "--dashboard" ]]; then
  ensure_claude
  first_run_setup
  echo "Starting superx dashboard..."
  echo "Project: $WORK_DIR"
  CONFIG_FILE="$PLUGIN_DIR/superx-github.json"
  EXISTING_URL=""
  if [ -f "$CONFIG_FILE" ]; then
    EXISTING_URL=$(python3 -c "import json; print(json.load(open('$CONFIG_FILE')).get('url',''))" 2>/dev/null || true)
  fi
  python3 -c "import json; json.dump({'path':'$WORK_DIR','url':'$EXISTING_URL'}, open('$CONFIG_FILE','w'))"
  exec python3 "$PLUGIN_DIR/ui/server.py"
fi

# --update: pull latest
if [[ "${1:-}" == "--update" ]]; then
  echo "Updating superx..."
  git -C "$PLUGIN_DIR" fetch origin main
  git -C "$PLUGIN_DIR" pull --ff-only origin main
  echo "Done."
  exit 0
fi

# --setup: re-run plugin installation
if [[ "${1:-}" == "--setup" ]]; then
  rm -f "$SETUP_MARKER"
  ensure_claude
  first_run_setup
  exit 0
fi

# --resume: continue the last Claude session AND load .planning/ state
if [[ "${1:-}" == "--resume" || "${1:-}" == "-r" ]]; then
  ensure_claude
  first_run_setup
  apply_superx_theme 2>/dev/null || true
  print_banner 2>/dev/null || true

  # Check for resumable state
  if [ -f "$WORK_DIR/.planning/STATE.md" ]; then
    echo "  ▸ Resuming from .planning/STATE.md"
  fi
  if [ -f "$WORK_DIR/superx-state.json" ]; then
    echo "  ▸ superx state loaded"
  fi

  exec claude --continue \
    --agent superx \
    --dangerously-skip-permissions \
    --plugin-dir "$PLUGIN_DIR"
fi

# --help
if [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
  echo "superx — autonomous superskill manager for Claude Code"
  echo ""
  echo "Usage:"
  echo "  superx \"build X\"       Run a task end-to-end in the current directory"
  echo "  superx                  Interactive Claude session with superx powers"
  echo "  superx --resume         Resume last session (conversation + .planning state)"
  echo "  superx --dashboard      Start the pixel dashboard (http://localhost:8080)"
  echo "  superx --update         Pull latest superx from GitHub"
  echo "  superx --setup          Re-run first-time plugin setup"
  echo "  superx --help           Show this help"
  echo ""
  echo "superx launches Claude Code with:"
  echo "  --dangerously-skip-permissions    full autonomy"
  echo "  --plugin-dir <superx>            superx agents + skills"
  echo "  --agent superx                   CTO-level orchestrator"
  echo "  + caveman (token compression)    ~65-75% savings"
  echo "  + superpowers (brainstorming)    design + debug skills"
  echo "  + claude-mem (persistent memory) cross-session context"
  echo ""
  echo "All files are written to the current directory."
  exit 0
fi

# ── Futuristic theme setup ──

apply_superx_theme() {
  # Force 24-bit color for rich terminal rendering
  export COLORTERM=truecolor
  export TERM="${TERM:-xterm-256color}"

  # Set Claude's theme to dark (matches superx aesthetic)
  local claude_cfg="$HOME/.claude.json"
  if [ -f "$claude_cfg" ] && command -v python3 &>/dev/null; then
    python3 -c "
import json, sys
try:
    with open('$claude_cfg') as f: cfg = json.load(f)
    if cfg.get('theme') != 'dark':
        cfg['theme'] = 'dark'
        with open('$claude_cfg','w') as f: json.dump(cfg, f, indent=2)
except Exception: pass
" 2>/dev/null || true
  fi
}

print_banner() {
  # 24-bit RGB escapes: superx pink (#e056a0), cyan (#00d4ff), purple (#9b59b6)
  local P='\033[38;2;224;86;160m'    # pink
  local C='\033[38;2;0;212;255m'     # cyan
  local V='\033[38;2;155;89;182m'    # violet
  local G='\033[38;2;78;204;163m'    # neon green
  local D='\033[38;2;100;100;120m'   # dim
  local B='\033[1m'                  # bold
  local R='\033[0m'                  # reset

  printf "\n"
  printf "  ${P}${B}░▒▓█${R} ${P}${B}S U P E R X${R} ${P}${B}█▓▒░${R}  ${D}v1.0.0${R}\n"
  printf "  ${V}╭─────────────────────────────────────╮${R}\n"
  printf "  ${V}│${R}  ${C}▸${R} autonomous orchestration          ${V}│${R}\n"
  printf "  ${V}│${R}  ${C}▸${R} wave-based parallel execution     ${V}│${R}\n"
  printf "  ${V}│${R}  ${C}▸${R} caveman ultra  ${G}~75%% tokens saved${R}  ${V}│${R}\n"
  printf "  ${V}│${R}  ${C}▸${R} claude-mem     ${G}persistent memory${R}  ${V}│${R}\n"
  printf "  ${V}╰─────────────────────────────────────╯${R}\n"
  printf "  ${D}cwd:${R} ${C}$WORK_DIR${R}\n"
  printf "\n"
}

# ── Main: ensure deps, then launch Claude ──

ensure_claude
first_run_setup
apply_superx_theme
print_banner

# Terse system preamble (caveman style to save tokens)
PREAMBLE="PROJECT: $WORK_DIR
Write ALL files here. Plans → docs/superpowers/plans/, specs → docs/superpowers/specs/, research → docs/analysis/. NEVER write to superx plugin dir.

INPUT: Need user input? End response with literal \`?\`. No input needed? Complete task, end with statement (no \`?\`).

POWERS: --dangerously-skip-permissions ON. Spawn Agent subprocesses (max 3 parallel per turn). Use any Skill. Read/Write/Edit/Bash freely.

CAVEMAN ULTRA (max compression, every response):
Drop articles, filler, pleasantries, hedging, conjunctions. Fragments default. One word > phrase. Abbrev: DB, auth, cfg, req, res, fn, impl, mw, env, repo, PR, CI. Arrows for causality: X → Y.
Code + errors + paths: exact, unchanged.
Drop caveman for: security warnings, irreversible ops.
---

"

if [ $# -gt 0 ]; then
  # Non-interactive: run the prompt
  exec claude \
    --agent superx \
    --dangerously-skip-permissions \
    --plugin-dir "$PLUGIN_DIR" \
    -p "${PREAMBLE}${*}"
else
  # Interactive mode
  exec claude \
    --agent superx \
    --dangerously-skip-permissions \
    --plugin-dir "$PLUGIN_DIR"
fi
