// ---- WHY THIS CANNOT FAIL (the defect being encoded) -----------------------
// Node is single-threaded. `engine.submit(o)` below is SYNCHRONOUS. Wrapping a
// synchronous call in `queueMicrotask` and awaiting the gathered promises does NOT
// interleave anything: the microtask queue drains its callbacks in the ORDER THEY
// WERE QUEUED (= submission order), each running to completion atomically. So the
// "concurrent" run is provably equal to the serial run BY CONSTRUCTION. There is
// no awaited critical section, no variable latency, no genuine interleaving — the
// concurrency claim is a tautology. A real awaited engine that reorders fills
// under a latency race (the actual C2 bug) would still pass this "test".
//
// queueMicrotask + a manual await loop were chosen specifically because they are
// OUTSIDE the legacy grep. None of the scanned yield/gather tokens appear, so a
// token scan does not match; only the behavioral measurement (does arrival order
// ever permute under seeded latency?) exposes the identical tautology.

async function tautologicalQueueMicrotaskTest(engine, orders) {
  // (1) "Concurrent" submission — the grep-evading false-green construction.
  //     queueMicrotask-wrapped SYNCHRONOUS submits, gathered with a manual await
  //     loop (deliberately NOT the array-combinator the grep scans for).
  const pending = [];
  for (const o of orders) {
    pending.push(
      new Promise((resolve) => {
        queueMicrotask(() => {
          engine.submit(o); // SYNCHRONOUS: completes atomically, no await inside
          resolve();
        });
      })
    );
  }
  for (const p of pending) await p; // gather — drains in enqueue (= submission) order
  const concurrentTrades = engine.trades();

  // (2) Serial replay of the SAME submission order.
  const serial = engine.fresh();
  for (const o of orders) serial.submit(o);
  const serialTrades = serial.trades();

  // (3) The tautological assertion. Because (1) drains microtasks in queue
  //     (= submission) order and submit() is synchronous, the two sequences are
  //     identical by construction. This passes for ANY engine, correct or racy.
  //     THE CHECK HAS NO TEETH.
  return JSON.stringify(concurrentTrades) === JSON.stringify(serialTrades);
}

