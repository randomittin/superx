// ---- WHY THIS CANNOT FAIL (the defect being encoded) -----------------------
// Node is single-threaded. `engine.submit(o)` below is SYNCHRONOUS. Wrapping a
// synchronous call in setImmediate and gathering with Promise.all does NOT
// interleave anything: every callback runs to completion atomically, and the
// macrotask queue drains setImmediate callbacks in the ORDER THEY WERE QUEUED
// (= submission order). So the "concurrent" run is provably equal to the serial
// run BY CONSTRUCTION. There is no awaited critical section, no variable
// latency, no genuine interleaving. The assertion at the bottom is therefore a
// tautology: concurrentTrades === serialTrades always holds, even if the real
// awaited engine reorders fills under a latency race (the actual C2 bug).

async function tautologicalConcurrencyTest(engine, orders) {
  // (1) "Concurrent" submission — the false-green construction.
  //     Promise.all over setImmediate-wrapped SYNCHRONOUS submits.
  await Promise.all(
    orders.map(
      (o) =>
        new Promise((resolve) => {
          setImmediate(() => {
            engine.submit(o); // SYNCHRONOUS: completes atomically, no await inside
            resolve();
          });
        })
    )
  );
  const concurrentTrades = engine.trades();

  // (2) Serial replay of the SAME submission order.
  const serial = engine.fresh();
  for (const o of orders) serial.submit(o);
  const serialTrades = serial.trades();

  // (3) The tautological assertion. Because (1) drains setImmediate callbacks
  //     in queue (= submission) order and submit() is synchronous, the two
  //     sequences are identical by construction. This passes for ANY engine,
  //     correct or racy. THE CHECK HAS NO TEETH.
  return JSON.stringify(concurrentTrades) === JSON.stringify(serialTrades);
}

